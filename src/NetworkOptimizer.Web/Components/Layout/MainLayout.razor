@inherits LayoutComponentBase
@implements IDisposable
@using NetworkOptimizer.Web.Services
@using System.Reflection
@inject UniFiConnectionService ConnectionService
@inject PullToRefreshState PullToRefreshState
@inject IJSRuntime JS

<div class="app-container">
    <div class="sidebar-overlay @(sidebarOpen ? "visible" : "")" @onclick="CloseSidebar"></div>
    <div class="sidebar @(sidebarOpen ? "open" : "")">
        <a href="/" class="sidebar-header" @onclick="CloseSidebar">
            <img src="images/network-optimizer-logo.png" alt="Network Optimizer" class="sidebar-logo" />
            <p class="app-subtitle"><strong>for UniFi</strong></p>
        </a>
        <NavMenu OnNavigate="CloseSidebar" />
    </div>

    <div class="main-content">
        <div class="pull-to-refresh">
            <svg class="ptr-spinner" viewBox="0 0 24 24" overflow="visible" fill="none" stroke="currentColor" stroke-width="2">
                <defs>
                    <marker id="ptr-arrow" markerWidth="4" markerHeight="4" refX="0" refY="2" orient="auto" overflow="visible">
                        <path d="M0,0 L4,2 L0,4" fill="currentColor" stroke="none"/>
                    </marker>
                </defs>
                <path d="M21 12a9 9 0 1 1-6.219-8.56" stroke-linecap="round" marker-end="url(#ptr-arrow)"/>
            </svg>
        </div>
        <header class="top-bar">
            <button class="hamburger-btn" @onclick="ToggleSidebar" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="/" class="mobile-logo">
                <img src="images/network-optimizer-logo.png" alt="Network Optimizer" />
            </a>
            <div class="status-indicators">
                @if (ConnectionService.IsConnected)
                {
                    <div class="status-item status-connected">
                        <span class="status-icon">●</span>
                        <span>Console Connected</span>
                    </div>
                }
                else
                {
                    <div class="status-item status-disconnected">
                        <span class="status-icon">●</span>
                        <span>Console Disconnected</span>
                    </div>
                }
            </div>
            <div class="header-actions">
                <SiteSwitcher />
                <a href="/api/auth/logout" class="logout-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                    </svg>
                    <span>Logout</span>
                </a>
            </div>
        </header>

        <UpdateNotificationBanner />

        <main class="page-content">
            <article class="content">
                @Body
            </article>
        </main>

        <footer class="app-footer">
            <p>&copy; 2026 Ozark Connect - Network Optimizer
                @if (AppVersionInfo.ReleaseVersion is { } releaseVersion)
                {
                    <a href="https://github.com/Ozark-Connect/NetworkOptimizer/releases/tag/v@(releaseVersion)" target="_blank" rel="noopener">v@(AppVersionInfo.Informational)</a>
                }
                else
                {
                    <span>(source build)</span>
                }
            </p>
        </footer>
    </div>
</div>

<ScrollRestoration />

<script>
    // Mobile scroll behaviors: auto-hide top bar, collapse identity bar
    // Targets .main-content (scroll container on mobile) and .page-content (desktop)
    (function() {
        function getScrollEl() {
            if (window.innerWidth <= 1024) return document.querySelector('.main-content');
            return document.querySelector('.page-content');
        }
        var lastScrollTop = 0;
        var scrollUpAccum = 0; // cumulative upward scroll distance
        var currentEl = null;

        function attachListener(el) {
            if (!el || el === currentEl) return;
            if (currentEl) currentEl.removeEventListener('scroll', onScroll);
            currentEl = el;
            lastScrollTop = el.scrollTop;
            el.addEventListener('scroll', onScroll, { passive: true });
        }

        var autoHideTimer = null;

        function isContentScrollable() {
            return currentEl && currentEl.scrollHeight > currentEl.clientHeight + 10;
        }

        function startAutoHideTimer(topBar) {
            clearAutoHideTimer();
            var page = document.querySelector('[data-autohide-nav]');
            if (!page) return;
            var delay = parseInt(page.getAttribute('data-autohide-nav')) || 3000;
            autoHideTimer = setTimeout(function() {
                var sidebarOpen = document.querySelector('.sidebar.open');
                if (sidebarOpen) return;
                // Site switcher menu lives inside the top bar; hiding the bar would make
                // the open menu inherit pointer-events: none and freeze it on screen
                if (document.querySelector('.site-switcher-menu')) return;
                if (topBar && !topBar.classList.contains('top-bar-hidden')) {
                    topBar.classList.add('top-bar-hidden');
                    setTimeout(function() { if (topBar.classList.contains('top-bar-hidden') && currentEl && currentEl.scrollHeight - topBar.offsetHeight > currentEl.clientHeight + 10) topBar.classList.add('top-bar-collapsed'); }, 350);
                    if (currentEl) currentEl.style.scrollPaddingTop = '0px';
                    var identityBar = document.querySelector('.identity-bar');
                    if (identityBar) identityBar.classList.remove('below-topbar');
                }
            }, delay);
        }

        function clearAutoHideTimer() {
            if (autoHideTimer) { clearTimeout(autoHideTimer); autoHideTimer = null; }
        }

        function onScroll() {
            var st = currentEl.scrollTop;

            // Identity bar collapse (all screen sizes)
            var identityBar = document.querySelector('.identity-bar');
            if (identityBar) {
                identityBar.classList.toggle('identity-collapsed', st > 80);
            }

            // Mobile-only: top bar hide/show, below-topbar offset
            if (window.innerWidth <= 1024) {
                var topBar = document.querySelector('.top-bar');

                var nearBottom = currentEl.scrollHeight - st - currentEl.clientHeight < 40;
                if (st <= 0 && !(topBar.classList.contains('top-bar-hidden') && lastScrollTop > 60)) {
                    topBar.classList.remove('top-bar-hidden', 'top-bar-collapsed');
                    currentEl.style.scrollPaddingTop = '70px';
                    startAutoHideTimer(topBar);
                    scrollUpAccum = 0;
                    lastScrollTop = st;
                } else if (topBar) {
                    var delta = lastScrollTop - st; // positive = scrolling up
                    if (delta > 0) {
                        scrollUpAccum += delta;
                    } else {
                        scrollUpAccum = 0; // reset on any downward scroll
                    }

                    if (st > lastScrollTop && st > 60 && isContentScrollable() && !document.querySelector('.site-switcher-menu')) {
                        topBar.classList.add('top-bar-hidden');
                        currentEl.style.scrollPaddingTop = '0px';
                        clearAutoHideTimer();
                    } else if (!nearBottom && scrollUpAccum > 60) {
                        // Require 60px cumulative upward scroll, not near bottom
                        topBar.classList.remove('top-bar-hidden', 'top-bar-collapsed');
                        currentEl.style.scrollPaddingTop = '70px';
                        startAutoHideTimer(topBar);
                        scrollUpAccum = 0;
                    }
                    lastScrollTop = st;
                }

                if (identityBar) {
                    identityBar.classList.toggle('below-topbar', topBar && !topBar.classList.contains('top-bar-hidden'));
                }
            }

            // Footer: fade in when near bottom (opacity, no layout shift)
            var footer = document.querySelector('.app-footer');
            if (footer) {
                var nearBottom = currentEl.scrollHeight - st - currentEl.clientHeight < 30;
                footer.classList.toggle('footer-visible', nearBottom);
            }
        }

        // Set scroll state on navigation (called from scrollRestoration.js)
        // hidden=true: fragment nav (hide bar, no padding)
        // hidden=false: page nav (show bar, add padding)
        window.__setScrollState = function(hidden) {
            lastScrollTop = 0;
            scrollUpAccum = 0;
            if (window.innerWidth <= 1024) {
                var topBar = document.querySelector('.top-bar');
                if (topBar) {
                    if (hidden) {
                        topBar.classList.add('top-bar-hidden');
                        clearAutoHideTimer();
                    } else {
                        topBar.classList.remove('top-bar-hidden', 'top-bar-collapsed');
                        startAutoHideTimer(topBar);
                    }
                }
                if (currentEl) {
                    currentEl.style.scrollPaddingTop = hidden ? '0px' : '70px';
                }
            }
        };

        attachListener(getScrollEl());
        window.addEventListener('resize', function() { attachListener(getScrollEl()); });
        window.addEventListener('orientationchange', function() {
            setTimeout(function() { window.scrollBy(0, 1); window.scrollBy(0, -1); }, 100);
        });

        // Show nav bar when content shrinks below scrollable (e.g. tab switch to short content)
        var pageContent = document.querySelector('.page-content');
        if (window.innerWidth <= 1024 && pageContent) {
            new ResizeObserver(function() {
                var topBar = document.querySelector('.top-bar');
                if (topBar && topBar.classList.contains('top-bar-hidden') && !isContentScrollable()) {
                    topBar.classList.remove('top-bar-hidden', 'top-bar-collapsed');
                    if (currentEl) currentEl.style.scrollPaddingTop = '70px';
                    startAutoHideTimer(topBar);
                }
            }).observe(pageContent);
        }

        // Restart auto-hide timer when sidebar closes
        var sidebar = document.querySelector('.sidebar');
        if (sidebar) {
            new MutationObserver(function() {
                if (!sidebar.classList.contains('open')) {
                    var topBar = document.querySelector('.top-bar');
                    if (topBar) startAutoHideTimer(topBar);
                }
            }).observe(sidebar, { attributes: true, attributeFilter: ['class'] });
        }
        window.__setPtrRef = function(ref) { window.__ptrDotNetRef = ref; };
        // Custom pull-to-refresh (replaces native, blocked by overscroll-behavior)
        (function() {
            if (window.innerWidth > 1024) return;
            var container = document.querySelector('.main-content');
            var indicator = document.querySelector('.pull-to-refresh');
            if (!container || !indicator) return;

            var startY = 0;
            var pulling = false;
            var hasMoved = false;
            var THRESHOLD = 90;
            var DEAD_ZONE = THRESHOLD / 3;
            var RESISTANCE_ZERO = 0.7;
            var RESISTANCE_MIN = 2.1;
            var RESISTANCE_MAX = 2.5;
            var resistance = RESISTANCE_MAX;
            var spinner = indicator.querySelector('.ptr-spinner');

            container.addEventListener('touchstart', function(e) {
                if (container.scrollTop <= 0) {
                    startY = e.touches[0].pageY;
                    pulling = true;
                    hasMoved = false;
                    indicator.classList.remove('ptr-refreshing');
                    indicator.classList.remove('ptr-ready');
                    // Adaptive resistance: no overflow = light pull, any overflow = near-max.
                    // Zero-scroll pages get lighter resistance (0.7x = ~63px finger travel).
                    // Pages with overflow start at 2.1x and ramp to 2.5x by 500px.
                    var overflow = container.scrollHeight - container.clientHeight;
                    if (overflow <= 5) {
                        resistance = RESISTANCE_ZERO;
                    } else {
                        var t = Math.min(overflow / 500, 1);
                        resistance = RESISTANCE_MIN + t * (RESISTANCE_MAX - RESISTANCE_MIN);
                    }
                }
            }, { passive: true });

            container.addEventListener('touchmove', function(e) {
                if (!pulling) return;
                hasMoved = true;
                var pullDist = (e.touches[0].pageY - startY) / resistance;
                if (pullDist <= 0) { pullDist = 0; pulling = false; }
                var capped = Math.min(pullDist, THRESHOLD * 1.3);
                var ready = pullDist >= THRESHOLD;
                indicator.style.transform = 'translateY(' + capped + 'px)';
                indicator.style.opacity = Math.min(pullDist / THRESHOLD, 1);
                // Scale only starts growing after 1/3 of threshold (dead zone)
                var scaleProgress = Math.max(0, (pullDist - DEAD_ZONE) / (THRESHOLD - DEAD_ZONE));
                var scale = 1 + Math.min(scaleProgress, 1) * 0.4;
                spinner.style.transform = 'rotate(' + (pullDist / THRESHOLD * 360) + 'deg) scale(' + scale + ')';
                indicator.classList.toggle('ptr-ready', ready);
            }, { passive: true });

            function resetIndicator() {
                spinner.style.removeProperty('transform');
                indicator.style.transform = '';
                indicator.style.opacity = '0';
                indicator.classList.remove('ptr-refreshing');
            }

            container.addEventListener('touchend', function() {
                if (!pulling) return;
                pulling = false;
                if (hasMoved && indicator.classList.contains('ptr-ready')) {
                    spinner.style.removeProperty('transform');
                    indicator.classList.add('ptr-refreshing');
                    indicator.style.transform = 'translateY(' + THRESHOLD + 'px)';
                    indicator.style.opacity = '1';
                    // Try Blazor page refresh callback, fall back to full reload
                    if (window.__ptrDotNetRef) {
                        window.__ptrDotNetRef.invokeMethodAsync('OnPullToRefresh').then(function(handled) {
                            if (!handled) {
                                setTimeout(function() { location.reload(); }, 600);
                            } else {
                                // Keep spinner visible briefly so user sees feedback
                                setTimeout(resetIndicator, 400);
                            }
                        }).catch(function() {
                            setTimeout(function() { location.reload(); }, 600);
                        });
                    } else {
                        setTimeout(function() { location.reload(); }, 600);
                    }
                } else {
                    spinner.style.removeProperty('transform');
                    indicator.style.transform = '';
                    indicator.style.opacity = '0';
                }
            });
        })();
    })();
</script>

@code {
    private bool sidebarOpen = false;
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("__setPtrRef", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task<bool> OnPullToRefresh()
    {
        var callback = PullToRefreshState.RefreshCallback;
        if (callback == null)
            return false;

        try
        {
            await InvokeAsync(async () =>
            {
                await callback();
                PullToRefreshState.NotifyStateChanged?.Invoke();
            });
            return true;
        }
        catch
        {
            // Stale callback from a previous page - fall back to reload
            return false;
        }
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private void CloseSidebar()
    {
        sidebarOpen = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
