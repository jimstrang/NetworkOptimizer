@if (Device != null)
{
    var deviceHref = $"/monitoring?tab=devices&device={Uri.EscapeDataString(Device.Mac ?? "")}";
    <a href="@deviceHref" class="device-card device-card-link device-@Device.StatusInfo.CssClass">
        <div class="device-header">
            <div class="device-icon">
                @{
                    var imagePath = GetDeviceImagePath(Device.Model);
                }
                @if (!string.IsNullOrEmpty(imagePath))
                {
                    <img src="@imagePath" alt="@Device.Model" class="device-image" />
                }
                else
                {
                    <span class="device-emoji">@GetDeviceIcon(Device.Type)</span>
                }
            </div>
            <div class="device-info">
                <h4 class="device-name">@Device.Name</h4>
                <div class="device-meta">
                    <span class="device-type">@Device.TypeDisplayName</span>
                    <div class="device-status">
                        <span class="status-dot @Device.StatusInfo.CssClass"></span>
                        <span class="status-text">@Device.StatusInfo.Label</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="device-body">
            <div class="device-detail">
                <span class="detail-label">IP Address:</span>
                <span class="detail-value">@Device.IpAddress</span>
            </div>
            @if (!string.IsNullOrEmpty(Device.Model))
            {
                <div class="device-detail">
                    <span class="detail-label">Model:</span>
                    <span class="detail-value">@Device.Model</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Device.Firmware))
            {
                <div class="device-detail">
                    <span class="detail-label">Firmware:</span>
                    <span class="detail-value">@Device.Firmware</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Device.Uptime))
            {
                <div class="device-detail">
                    <span class="detail-label">Uptime:</span>
                    <span class="detail-value">@Device.Uptime</span>
                </div>
            }
            @if (Device.ClientCount.HasValue)
            {
                <div class="device-detail">
                    <span class="detail-label">Clients:</span>
                    <span class="detail-value">@Device.ClientCount</span>
                </div>
            }
            @if (HasLiveData)
            {
                <div class="device-live-stats">
                    @if (Device.LiveCpuPercent.HasValue || Device.LiveMemoryPercent.HasValue || Device.LiveTemperatureC.HasValue)
                    {
                        <div class="device-health-stats">
                            @if (Device.LiveCpuPercent.HasValue)
                            {
                                <span>CPU @($"{Device.LiveCpuPercent.Value:0}%")</span>
                            }
                            @if (Device.LiveMemoryPercent.HasValue)
                            {
                                <span>Mem @($"{Device.LiveMemoryPercent.Value:0}%")</span>
                            }
                            @if (Device.LiveTemperatureC.HasValue)
                            {
                                <span>@($"{Device.LiveTemperatureC.Value:0} °C")</span>
                            }
                        </div>
                    }
                    @if (Device.LiveLatencyMs.HasValue)
                    {
                        <div class="device-latency @(Device.LiveLossPercent > 5 ? "latency-degraded" : "")">
                            <span class="latency-label">Ping</span>
                            <span class="latency-value">@($"{Device.LiveLatencyMs.Value:0.000} ms")</span>
                            @if (Device.LiveLossPercent > 0)
                            {
                                <span class="latency-loss">@($"{Device.LiveLossPercent:0.#}% loss")</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </a>
}

<style>
    .device-image {
        width: 48px;
        height: 48px;
        object-fit: contain;
    }

    .device-emoji {
        font-size: 2rem;
    }

    .device-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }
    .device-card-link:hover {
        border-color: var(--primary-color);
    }

    .device-live-stats {
        margin-top: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--bg-tertiary);
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        font-size: 0.85rem;
    }
    .device-rate {
        display: flex;
        gap: 0.5rem;
    }
    .device-rate .rate-down {
        color: var(--speed-download-color);
    }
    .device-rate .rate-up {
        color: var(--speed-upload-color);
    }
    .device-latency {
        color: var(--text-secondary);
    }
    .device-latency.latency-degraded {
        color: var(--warning-color);
    }
    .device-latency .latency-label {
        color: var(--text-muted);
        margin-right: 0.25rem;
    }
    .device-latency .latency-loss {
        color: var(--danger-color);
        margin-left: 0.25rem;
    }
    .device-health-stats {
        display: flex;
        gap: 0.75rem;
        color: var(--text-muted);
        font-size: 0.8rem;
    }
</style>

@using NetworkOptimizer.Web.Services
@using NetworkOptimizer.Core.Enums
@inject IWebHostEnvironment Environment

@code {
    [Parameter]
    public DeviceInfo? Device { get; set; }

    private bool HasLiveData => Device != null
        && (Device.LiveRateInBps.HasValue
            || Device.LiveRateOutBps.HasValue
            || Device.LiveLatencyMs.HasValue
            || Device.LiveCpuPercent.HasValue);

    private static string FormatBps(double? bps)
    {
        if (!bps.HasValue) return "-";
        var v = bps.Value;
        if (v >= 1_000_000_000) return $"{v / 1_000_000_000:0.##} Gbps";
        if (v >= 1_000_000) return $"{v / 1_000_000:0.##} Mbps";
        if (v >= 1_000) return $"{v / 1_000:0.##} Kbps";
        return $"{v:0} bps";
    }

    private string? GetDeviceImagePath(string? model)
    {
        if (string.IsNullOrEmpty(model))
            return null;

        // Convention: model name lowercase + .png (e.g., "UCG-Fiber" → "ucg-fiber.png")
        var imageFile = $"{model.ToLowerInvariant()}.png";
        var imagePath = Path.Combine(Environment.WebRootPath, "images", "devices", imageFile);

        if (File.Exists(imagePath))
            return $"/images/devices/{imageFile}";

        return null;
    }

    // Fallback icons when device image is unavailable
    private string GetDeviceIcon(DeviceType deviceType)
    {
        return deviceType switch
        {
            DeviceType.Gateway => "🌐",
            DeviceType.Switch => "🔀",
            DeviceType.AccessPoint => "📡",
            DeviceType.CellularModem => "📶",
            DeviceType.BuildingBridge => "🌉",
            DeviceType.CloudKey => "☁️",
            DeviceType.DeviceBridge => "🔗",
            DeviceType.SmartPower => "⚡",
            _ => "🖥️"
        };
    }
}
