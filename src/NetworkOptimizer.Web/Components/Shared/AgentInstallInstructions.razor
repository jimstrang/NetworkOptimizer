@using System.Text
@inject AgentServerUrlProvider AgentServerUrl

@* Agent enrollment token plus how to stand the agent up, shared by the site
   wizard and the Multi-Site settings panel. Always the published-release
   one-liners (Docker, bare metal, on-gateway) - even on a source-built server,
   the agent should come from a release, not a hand-built binary. The
   configured central server URL is filled in so nothing is hand-typed. *@

<div class="agent-install">
<div class="alert alert-success">
    Enrollment token: <code>@Token</code><br />
    Copy it now - it is shown only once and expires in 24 hours if unused.
</div>

@if (string.IsNullOrWhiteSpace(ServerUrl))
{
    <p class="form-hint">
        This server's reverse-proxied HTTPS address isn't set (<code>REVERSE_PROXIED_HOST_NAME</code>), so
        the command below shows a placeholder. Set it so agents have an address to dial back to - the same
        host serves the app and the agent tunnel.
    </p>
}

    <p class="section-description">
        On the site's agent box, install with Docker or as a bare-metal systemd service - pick one. Either
        way the agent dials out to <code>@ServerDisplay</code> over HTTPS only, with no inbound access to the
        site.
    </p>

    <h4 class="agent-flavor-title">Docker</h4>
    <p class="form-hint">Pulls the agent image and compose template, writes the config, and starts it.</p>
    <pre><code>@DockerOneLiner()</code></pre>

    <h4 class="agent-flavor-title">Bare metal (systemd)</h4>
    <p class="form-hint">
        No Docker required - downloads a self-contained binary and installs a <code>netopt-agent</code>
        systemd service.
    </p>
    <pre><code>@NativeOneLiner()</code></pre>

    <h4 class="agent-flavor-title">On a UniFi gateway</h4>
    <p class="form-hint">
        Run the agent on the gateway itself (any current UniFi gateway - UCG, UXG, UDM, UDR, EFG) instead of a separate box.
        Monitoring-only - it installs to <code>/data</code> with a memory-fenced service. UniFi gateways
        SSH in as root, so run it there directly:
    </p>
    <pre><code>@GatewayOneLiner()</code></pre>
    @if (LanSpeedTest)
    {
        <p class="form-hint">
            LAN speed testing isn't hosted on the gateway - use the Docker or bare-metal command above on a
            separate box for that.
        </p>
    }

    <p class="form-hint">
        Full options and troubleshooting are in the
        <a href="https://github.com/Ozark-Connect/NetworkOptimizer/blob/main/src/NetworkOptimizer.Agent/README.md" target="_blank" rel="noopener">agent deployment guide</a>.
        The server URL just has to be reachable from the site: over a VPN or site-to-site VPN, or a public
        address. If it isn't reachable over a VPN, expose this server's reverse proxy - on a UniFi gateway
        at this server's site: UniFi Network &gt; Settings &gt; Policy Table &gt; Port Forwarding (usually
        443/TCP).
    </p>
</div>

@code {
    /// <summary>The one-time enrollment token shown to the operator.</summary>
    [Parameter, EditorRequired]
    public string Token { get; set; } = "";

    /// <summary>Whether the agent should also host the LAN speed test server at the site.</summary>
    [Parameter]
    public bool LanSpeedTest { get; set; }

    /// <summary>The agent-facing HTTPS base URL, derived from REVERSE_PROXIED_HOST_NAME.</summary>
    private string? ServerUrl => AgentServerUrl.Url;

    private string ServerDisplay => string.IsNullOrWhiteSpace(ServerUrl) ? "this server" : ServerUrl!.TrimEnd('/');

    private string ServerValue => string.IsNullOrWhiteSpace(ServerUrl) ? "https://your-network-optimizer" : ServerUrl!.TrimEnd('/');

    private string DockerOneLiner()
    {
        var sb = new StringBuilder();
        sb.Append("curl -fsSL https://raw.githubusercontent.com/Ozark-Connect/NetworkOptimizer/main/scripts/agent/install-docker.sh | bash -s -- \\\n");
        sb.Append($"  --server \"{ServerValue}\" \\\n");
        sb.Append($"  --token \"{Token}\"");
        if (LanSpeedTest)
            sb.Append(" \\\n  --lan-speed-test");
        return sb.ToString();
    }

    private string NativeOneLiner()
    {
        var sb = new StringBuilder();
        sb.Append("curl -fsSL https://raw.githubusercontent.com/Ozark-Connect/NetworkOptimizer/main/scripts/agent/install-native.sh | sudo bash -s -- \\\n");
        sb.Append($"  --server \"{ServerValue}\" \\\n");
        sb.Append($"  --token \"{Token}\"");
        if (LanSpeedTest)
            sb.Append(" \\\n  --lan-speed-test");
        return sb.ToString();
    }

    // Monitoring-only gateway installer: no --lan-speed-test (the router must not
    // host a speed-test server), and no sudo (UniFi gateways SSH in as root).
    private string GatewayOneLiner()
    {
        var sb = new StringBuilder();
        sb.Append("curl -fsSL https://raw.githubusercontent.com/Ozark-Connect/NetworkOptimizer/main/scripts/agent/install-agent-gateway.sh | bash -s -- \\\n");
        sb.Append($"  --server \"{ServerValue}\" \\\n");
        sb.Append($"  --token \"{Token}\"");
        return sb.ToString();
    }
}
