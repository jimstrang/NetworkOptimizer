@using System.Net
@using Microsoft.EntityFrameworkCore
@using NetworkOptimizer.Monitoring
@using NetworkOptimizer.Web.Services
@using NetworkOptimizer.Web.Endpoints
@using NetworkOptimizer.Core.Enums
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.Storage.Services
@inject NetworkOptimizer.Storage.Services.SiteDbContextFactory SiteDb
@inject SiteContextService SiteCtx
@inject UniFiConnectionService ConnectionService
@inject ICredentialProtectionService CredentialProtection
@inject ILoggerFactory LoggerFactory
@inject AgentSnmpQueryService AgentSnmpQuery

<div class="card">
    <div class="card-header card-header-collapsible" @onclick="ToggleCollapse">
        <div class="card-title-group">
            <h2 class="card-title">SNMP Devices <span class="card-title-suffix">and Custom OIDs</span></h2>
        </div>
        <div class="card-header-right">
            <span class="status-badge status-active" @onclick:stopPropagation="true">@SummaryLabel()</span>
            <span class="issue-type-chevron">@(_collapsed ? "▼" : "▲")</span>
        </div>
    </div>
    <div class="expand-wrapper @(!_collapsed ? "expanded" : "")">
        <div class="expand-content">
            <div class="card-body">
                <p class="section-description">
                    Every adopted device and where it sits in the SNMP polling lifecycle. A device is
                    only polled when SNMP is enabled on it (a <strong>Location</strong> or
                    <strong>Contact</strong> is set in UniFi) and it keeps answering.
                </p>

                @if (Devices.Count == 0)
                {
                    <div class="empty-state">
                        <p>No devices discovered yet. They'll appear once UniFi reports adopted devices.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Device</th>
                                    <th>SNMP</th>
                                    <th>Polling status</th>
                                    <th class="hide-mobile">Last polled</th>
                                    <th style="width: 2.5rem;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Devices.OrderBy(d => d.DeviceType).ThenBy(d => d.Name))
                                {
                                    var isExpanded = _expandedDeviceMac == d.Mac;
                                    <tr class="@(isExpanded ? "snmp-row-expanded" : "")" @onclick="() => ToggleDevice(d.Mac)" style="cursor: pointer;">
                                        <td>
                                            <span class="snmp-device-name">@d.Name</span>
                                            <span class="status-badge status-neutral snmp-device-type">@d.DeviceType.ToDisplayName()</span>
                                        </td>
                                        <td>
                                            @if (d.SnmpEnabled)
                                            {
                                                <span class="status-indicator status-active"></span>
                                                <span data-tooltip="An SNMP Location or Contact is set in UniFi, so SNMP is enabled on this device.">On</span>
                                            }
                                            else
                                            {
                                                <span class="status-indicator status-inactive"></span>
                                                <span class="text-muted" data-tooltip-wrap data-tooltip="This device either doesn't support SNMP, or it does but just needs a Location or Contact set in UniFi. See the help below.">Check / Unsupported</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="status-badge @StatusBadgeClass(d.PollState)" data-tooltip-wrap data-tooltip="@StatusTooltip(d)">
                                                @StatusLabel(d.PollState)
                                            </span>
                                        </td>
                                        <td class="hide-mobile">
                                            @if (d.LastPolledUtc.HasValue)
                                            {
                                                <span>@RelativeTime(d.LastPolledUtc.Value)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">never</span>
                                            }
                                        </td>
                                        <td style="text-align: right;">
                                            <span class="issue-type-chevron snmp-row-chevron">@(isExpanded ? "▲" : "▼")</span>
                                        </td>
                                    </tr>
                                    @if (isExpanded)
                                    {
                                        <tr class="snmp-detail-row">
                                            <td colspan="5">
                                                <div class="snmp-detail-panel">
                                                    <div class="snmp-detail-section">
                                                        <div class="snmp-detail-header">
                                                            <h4>Custom OID Polling</h4>
                                                            @if (!_showAddForm)
                                                            {
                                                                <button class="btn btn-sm btn-primary" @onclick:stopPropagation="true" @onclick="ShowAddForm">Add OID</button>
                                                            }
                                                        </div>

                                                        @if (_customOids.Count > 0)
                                                        {
                                                            <div class="table-responsive">
                                                                <table class="data-table snmp-oid-table">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>OID</th>
                                                                            <th>Field Name</th>
                                                                            <th class="hide-mobile">Type</th>
                                                                            <th class="hide-mobile">Scope</th>
                                                                            <th style="width: 5rem;"></th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var oid in _customOids)
                                                                        {
                                                                            <tr>
                                                                                <td><code class="snmp-oid-code">@oid.Oid</code></td>
                                                                                <td>@oid.FieldName</td>
                                                                                <td class="hide-mobile">@oid.ValueType</td>
                                                                                <td class="hide-mobile">@(oid.Scope == CustomOidScope.DeviceLevel ? "Device" : "Interface")</td>
                                                                                <td style="text-align: right;">
                                                                                    <button class="btn btn-sm btn-danger" @onclick:stopPropagation="true" @onclick="() => DeleteOid(oid.Id)">
                                                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                                                                    </button>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        }
                                                        else if (!_showAddForm)
                                                        {
                                                            <p class="text-muted" style="margin: 0.5rem 0;">No custom OIDs configured. Add one to start polling additional SNMP data.</p>
                                                        }

                                                        @if (_showAddForm)
                                                        {
                                                            <div class="snmp-add-oid-form" @onclick:stopPropagation="true">
                                                                <div class="snmp-form-row">
                                                                    <div class="snmp-form-field snmp-form-field-oid">
                                                                        <label>OID</label>
                                                                        <div class="snmp-oid-input-group">
                                                                            <input type="text" @bind="_editOid" placeholder="1.3.6.1.4.1.41112..." />
                                                                            <button class="btn btn-sm btn-secondary" @onclick="TestOid" disabled="@_testingOid">
                                                                                @(_testingOid ? "..." : "Test")
                                                                            </button>
                                                                        </div>
                                                                        @if (_testResult != null)
                                                                        {
                                                                            <div class="snmp-test-result @(_testResult.Success ? "snmp-test-success" : "snmp-test-error")">
                                                                                @if (_testResult.Success)
                                                                                {
                                                                                    <span>Value: <code>@_testResult.Value</code></span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <span>@_testResult.ErrorMessage</span>
                                                                                }
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                    <div class="snmp-form-field">
                                                                        <label>Field Name</label>
                                                                        <input type="text" @bind="_editFieldName" placeholder="InfluxDB field name, e.g. fan_speed_rpm" />
                                                                    </div>
                                                                </div>
                                                                <div class="snmp-form-row">
                                                                    <div class="snmp-form-field">
                                                                        <label>Value Type</label>
                                                                        <select @bind="_editValueType">
                                                                            <option value="@CustomOidValueType.Integer">Integer</option>
                                                                            <option value="@CustomOidValueType.Float">Float</option>
                                                                            <option value="@CustomOidValueType.String">String</option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="snmp-form-field">
                                                                        <label>Scope</label>
                                                                        <select @bind="_editScope">
                                                                            <option value="@CustomOidScope.DeviceLevel">Device (scalar)</option>
                                                                            <option value="@CustomOidScope.InterfaceLevel">Interface (per-port)</option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="snmp-form-field">
                                                                        <label>Description</label>
                                                                        <input type="text" @bind="_editDescription" placeholder="Optional description" />
                                                                    </div>
                                                                </div>
                                                                <div class="snmp-form-actions">
                                                                    <button class="btn btn-sm btn-primary" @onclick="SaveOid" disabled="@_saving">Save</button>
                                                                    <button class="btn btn-sm btn-secondary" @onclick="CancelAdd">Cancel</button>
                                                                    @if (!string.IsNullOrEmpty(_saveError))
                                                                    {
                                                                        <span class="snmp-save-error">@_saveError</span>
                                                                    }
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>Per-device SNMP polling status, supplied by the parent page.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<SnmpDeviceStatus> Devices { get; set; } = Array.Empty<SnmpDeviceStatus>();

    private bool _collapsed = true;
    private string? _expandedDeviceMac;
    private bool _autoExpandedFirst;
    private List<CustomOidDto> _customOids = new();

    // Add/edit form state
    private bool _showAddForm;
    private string _editOid = string.Empty;
    private string _editFieldName = string.Empty;
    private CustomOidValueType _editValueType = CustomOidValueType.Integer;
    private CustomOidScope _editScope = CustomOidScope.DeviceLevel;
    private string _editDescription = string.Empty;
    private bool _saving;
    private string? _saveError;

    // Test OID state
    private bool _testingOid;
    private TestOidResult? _testResult;

    protected override async Task OnParametersSetAsync()
    {
        // Nudge users who haven't touched custom OIDs yet: auto-expand the first device so the
        // Custom OID Polling section (and its "Add OID" action) is visible without a hint. But if
        // ANY device already has a custom OID configured, the feature is discovered - leave it
        // collapsed. Runs once, and never overrides a row the user opened themselves.
        if (_autoExpandedFirst || Devices.Count == 0 || _expandedDeviceMac != null) return;
        _autoExpandedFirst = true;

        bool anyCustomOids;
        try
        {
            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            anyCustomOids = await db.CustomOidConfigurations.AnyAsync();
        }
        catch
        {
            anyCustomOids = true; // fail safe: if we can't tell, don't auto-expand
        }
        if (anyCustomOids) return;

        var first = Devices.OrderBy(d => d.DeviceType).ThenBy(d => d.Name).FirstOrDefault();
        if (first != null)
        {
            _expandedDeviceMac = first.Mac;
            await LoadCustomOids(first.Mac);
        }
    }

    private void ToggleCollapse() => _collapsed = !_collapsed;

    /// <summary>Expand the table from outside (e.g. when a banner links here).</summary>
    public void Expand()
    {
        _collapsed = false;
        StateHasChanged();
    }

    private async Task ToggleDevice(string mac)
    {
        if (_expandedDeviceMac == mac)
        {
            _expandedDeviceMac = null;
            _showAddForm = false;
            _testResult = null;
        }
        else
        {
            _expandedDeviceMac = mac;
            _showAddForm = false;
            _testResult = null;
            await LoadCustomOids(mac);
        }
    }

    private async Task LoadCustomOids(string mac)
    {
        try
        {
            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            _customOids = await db.CustomOidConfigurations
                .Where(c => c.DeviceMac == mac)
                .OrderBy(c => c.FieldName)
                .Select(c => new CustomOidDto
                {
                    Id = c.Id,
                    Oid = c.Oid,
                    FieldName = c.FieldName,
                    ValueType = c.ValueType,
                    Scope = c.Scope,
                    Enabled = c.Enabled,
                    Description = c.Description
                })
                .ToListAsync();
        }
        catch
        {
            _customOids = new();
        }
    }

    private void ShowAddForm()
    {
        _showAddForm = true;
        _editOid = string.Empty;
        _editFieldName = string.Empty;
        _editValueType = CustomOidValueType.Integer;
        _editScope = CustomOidScope.DeviceLevel;
        _editDescription = string.Empty;
        _saveError = null;
        _testResult = null;
    }

    private void CancelAdd()
    {
        _showAddForm = false;
        _saveError = null;
        _testResult = null;
    }

    private async Task TestOid()
    {
        if (string.IsNullOrWhiteSpace(_editOid) || _expandedDeviceMac == null) return;
        _testingOid = true;
        _testResult = null;
        StateHasChanged();

        try
        {
            // Agent-covered site: the server can't reach the device directly, so run the GET
            // through the site's agent. Main and any site without an online agent fall through
            // to the direct poll below (unchanged).
            if (!SiteCtx.IsDefault && AgentSnmpQuery.HasAgentForSite(SiteCtx.Slug))
            {
                var agentIp = await SnmpEndpoints.ResolveDeviceIpAsync(_expandedDeviceMac, ConnectionService);
                if (agentIp == null)
                {
                    _testResult = new TestOidResult { ErrorMessage = "Could not resolve device IP." };
                    return;
                }
                var agentRes = await AgentSnmpQuery.QueryAsync(SiteCtx.Slug, agentIp, _editOid.Trim(), TimeSpan.FromSeconds(10), CancellationToken.None);
                if (agentRes != null)
                {
                    _testResult = agentRes.Success
                        ? new TestOidResult { Success = true, Value = agentRes.Value }
                        : new TestOidResult { ErrorMessage = string.IsNullOrEmpty(agentRes.Error) ? "No response." : agentRes.Error };
                    return;
                }
                // agentRes == null: the agent's tunnel dropped between the check and the send;
                // fall through to a direct attempt rather than failing outright.
            }

            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            var settings = await db.MonitoringSettings.FirstOrDefaultAsync();
            if (settings == null)
            {
                _testResult = new TestOidResult { ErrorMessage = "Monitoring not configured." };
                return;
            }

            var poller = SnmpEndpoints.BuildPollerFromSettings(settings, CredentialProtection, LoggerFactory);
            if (poller == null)
            {
                _testResult = new TestOidResult { ErrorMessage = "SNMP credentials not configured." };
                return;
            }

            var deviceIp = await SnmpEndpoints.ResolveDeviceIpAsync(_expandedDeviceMac, ConnectionService);
            if (deviceIp == null || !IPAddress.TryParse(deviceIp, out var ip))
            {
                _testResult = new TestOidResult { ErrorMessage = "Could not resolve device IP." };
                return;
            }

            var value = await poller.GetAsync<string>(ip, _editOid.Trim());
            _testResult = value != null
                ? new TestOidResult { Success = true, Value = value }
                : new TestOidResult { ErrorMessage = "No response (OID may not exist on this device)." };
        }
        catch (Exception ex)
        {
            _testResult = new TestOidResult { ErrorMessage = $"SNMP error: {ex.Message}" };
        }
        finally
        {
            _testingOid = false;
        }
    }

    private record TestOidResult
    {
        public bool Success { get; init; }
        public string? Value { get; init; }
        public string? ErrorMessage { get; init; }
    }

    private async Task SaveOid()
    {
        if (string.IsNullOrWhiteSpace(_editOid) || string.IsNullOrWhiteSpace(_editFieldName) || _expandedDeviceMac == null)
        {
            _saveError = "OID and Field Name are required.";
            return;
        }

        _saving = true;
        _saveError = null;
        StateHasChanged();

        try
        {
            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            var now = DateTime.UtcNow;
            db.CustomOidConfigurations.Add(new CustomOidConfiguration
            {
                DeviceMac = _expandedDeviceMac,
                Oid = _editOid.Trim(),
                FieldName = _editFieldName.Trim(),
                ValueType = _editValueType,
                Scope = _editScope,
                Enabled = true,
                Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim(),
                CreatedAt = now,
                UpdatedAt = now
            });
            await db.SaveChangesAsync();

            _showAddForm = false;
            await LoadCustomOids(_expandedDeviceMac);
        }
        catch (Exception ex)
        {
            _saveError = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteOid(int id)
    {
        if (_expandedDeviceMac == null) return;

        try
        {
            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            var entry = await db.CustomOidConfigurations.FindAsync(id);
            if (entry != null)
            {
                db.CustomOidConfigurations.Remove(entry);
                await db.SaveChangesAsync();
            }
            await LoadCustomOids(_expandedDeviceMac);
        }
        catch (Exception ex)
        {
            _saveError = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private string SummaryLabel()
    {
        var polling = Devices.Count(d => d.PollState == SnmpPollState.Polling);
        return $"{polling}/{Devices.Count} polling";
    }

    private static string StatusBadgeClass(SnmpPollState state) => state switch
    {
        SnmpPollState.Polling => "status-active",
        SnmpPollState.NotYetPolled => "status-inactive",
        SnmpPollState.Excluded => "status-disconnected",
        SnmpPollState.SnmpDisabled => "status-neutral",
        _ => "status-inactive"
    };

    private static string StatusLabel(SnmpPollState state) => state switch
    {
        SnmpPollState.Polling => "Polling",
        SnmpPollState.NotYetPolled => "Not yet polled",
        SnmpPollState.Excluded => "Excluded",
        SnmpPollState.SnmpDisabled => "Not polled",
        _ => "Unknown"
    };

    private static string StatusTooltip(SnmpDeviceStatus d) => d.PollState switch
    {
        SnmpPollState.Polling => "SNMP is responding; this device is feeding monitoring data.",
        SnmpPollState.NotYetPolled => "SNMP is enabled but the agent hasn't recorded a successful poll yet this session.",
        SnmpPollState.Excluded => $"Dropped from polling after {d.FailureCount} consecutive SNMP failures. Retried automatically.",
        SnmpPollState.SnmpDisabled => "Not polled because SNMP isn't confirmed for this device.",
        _ => ""
    };

    private static string RelativeTime(DateTime when)
    {
        var delta = DateTime.UtcNow - DateTime.SpecifyKind(when, DateTimeKind.Utc);
        if (delta < TimeSpan.FromSeconds(15)) return "just now";
        if (delta < TimeSpan.FromMinutes(1)) return $"{(int)delta.TotalSeconds}s ago";
        if (delta < TimeSpan.FromHours(1)) return $"{(int)delta.TotalMinutes}m ago";
        if (delta < TimeSpan.FromDays(1)) return $"{(int)delta.TotalHours}h ago";
        return $"{(int)delta.TotalDays}d ago";
    }
}
