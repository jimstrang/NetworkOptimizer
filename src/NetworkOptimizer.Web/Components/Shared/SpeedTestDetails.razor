    /// <summary>
    /// Get device tooltip showing type, model, and firmware for UniFi devices.
    /// For wireless client hops, shows the WiFi tooltip from the connector.
    /// </summary>
    private string? GetDeviceTooltip(NetworkHop hop)
    {
        // Wireless client hop: show WiFi stats (same as connector, mutually exclusive via Tippy)
        if (hop.Type == HopType.WirelessClient && Result?.PathAnalysis?.Path?.Hops is { } hops)
        {
            var hopIdx = hops.IndexOf(hop);
            var adjacentHop = hopIdx >= 0 && hopIdx < hops.Count - 1 ? hops[hopIdx + 1] : null;
            if (adjacentHop != null)
                return GetWifiTooltip(hop, adjacentHop, hop.IsBottleneck);
        }

        // WAN hops: show Smart Queues status if available
        if (hop.Type == HopType.Wan && hop.SmartQueueEnabled.HasValue)
        {
            var sqmStatus = hop.SmartQueueEnabled.Value ? "Enabled" : "Disabled";
            return $"<div class='device-tooltip-row'><span class='device-tooltip-label'>Smart Queues:</span> {sqmStatus}</div>";
        }

        // Only show tooltip for UniFi devices (those with a model)
        if (string.IsNullOrEmpty(hop.DeviceModel))
            return null;

        var deviceType = GetDeviceTypeName(hop.Type);
        var lines = new List<string>();

        lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Type:</span> {deviceType}</div>");
        lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Model:</span> {hop.DeviceModel}</div>");

        if (!string.IsNullOrEmpty(hop.DeviceFirmware))
        {
            lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Firmware:</span> {hop.DeviceFirmware}</div>");
        }

        // Show MLO status for access points
        if (hop.Type == HopType.AccessPoint && hop.MloEnabled.HasValue)
        {
            var mloStatus = hop.MloEnabled.Value ? "Enabled" : "Disabled";
            lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>MLO:</span> {mloStatus}</div>");
        }

        // Show device settings
        if (hop.HardwareAccelerationEnabled.HasValue)
        {
            var status = hop.HardwareAccelerationEnabled.Value ? "Enabled" : "Disabled";
            lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Hardware Acceleration:</span> {status}</div>");
        }
        if (hop.JumboFramesEnabled.HasValue)
        {
            var status = hop.JumboFramesEnabled.Value ? "Enabled" : "Disabled";
            lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Jumbo Frames:</span> {status}</div>");
        }
        if (hop.FlowControlEnabled.HasValue)
        {
            var status = hop.FlowControlEnabled.Value ? "Enabled" : "Disabled";
            lines.Add($"<div class='device-tooltip-row'><span class='device-tooltip-label'>Flow Control:</span> {status}</div>");
        }

        return string.Join("", lines);
    }

