@using Microsoft.EntityFrameworkCore
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.Monitoring.Models
@using NetworkOptimizer.Web.Services
@implements IDisposable
@inject MonitoringLiveStats LiveStats
@inject NetworkOptimizer.Storage.Services.SiteDbContextFactory SiteDb
@inject SiteContextService SiteCtx
@inject UniFiConnectionService ConnectionService
@inject OntMonitorService ExternalOntService

@if (_isLoading)
{
    <div class="loading-state">
        <span class="spinner"></span>
        <span>Loading fiber stats...</span>
    </div>
}
else if (IsShowingExternal && _externalOntStats != null)
{
    <div class="sqm-header">
        <div class="sqm-status">
            <span class="status-indicator status-@(_externalOntStats.LinkState?.Contains("Up", StringComparison.OrdinalIgnoreCase) == true ? "active" : "warning")"></span>
            <span class="status-label">@_externalOntStats.DeviceName</span>
        </div>
        @if (_externalOntStats.Timestamp.Year > 1)
        {
            <div class="tc-timestamp">
                <small>Updated: @_externalOntStats.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small>
            </div>
        }
    </div>

    <div class="signal-quality-section signal-centered">
        <div class="ont-rx-gauge">
            <span class="rx-power-value @ExternalRxClass()">
                @(_externalOntStats.RxPowerDbm.HasValue ? $"{_externalOntStats.RxPowerDbm.Value:0.0#} dBm" : "-")
            </span>
            <span class="rx-power-label">RX optical power</span>
        </div>
        <div class="modem-nav">
            @if (TotalCount > 1)
            {
                <button class="nav-btn" @onclick="Previous" @onclick:stopPropagation disabled="@(_currentIndex == 0)">&#x2039;</button>
                <span class="modem-counter">@(_currentIndex + 1)/@TotalCount</span>
                <button class="nav-btn" @onclick="Next" @onclick:stopPropagation disabled="@(_currentIndex >= TotalCount - 1)">&#x203A;</button>
            }
        </div>
    </div>

    <div class="cellular-metrics" style="margin-top: 0.75rem;">
        <div class="metric-box">
            <div class="metric-header">Connection</div>
            <div class="metric-content">
                @{ var extModel = SfpModelLabel(_externalOntStats.VendorName, _externalOntStats.VendorPn); }
                @if (!string.IsNullOrEmpty(extModel))
                {
                    <div class="metric-row">
                        <span class="metric-label">Model:</span>
                        <span class="metric-value ont-model-value">@extModel</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_externalOntStats.PonType))
                {
                    <div class="metric-row">
                        <span class="metric-label">Link Type:</span>
                        <span class="metric-value">@ExternalLinkTypeLabel()</span>
                    </div>
                }
                @if (_externalOntStats.PonLinkStatus != PonLinkState.Unknown)
                {
                    <div class="metric-row">
                        <span class="metric-label">PON Status:</span>
                        <span class="metric-value">@_externalOntStats.PonLinkStatus.ToDisplayString()</span>
                    </div>
                }
                @if (_externalOntStats.BwpSpeedMbps.HasValue)
                {
                    <div class="metric-row">
                        <span class="metric-label">BWP:</span>
                        <span class="metric-value">@(_externalOntStats.BwpSpeedMbps >= 1000 ? $"{_externalOntStats.BwpSpeedMbps / 1000.0:0.##} Gbps" : $"{_externalOntStats.BwpSpeedMbps} Mbps")</span>
                    </div>
                }
            </div>
        </div>
        <div class="metric-box">
            <div class="metric-header">Stats</div>
            <div class="metric-content">
                <div class="metric-row">
                    <span class="metric-label">RX:</span>
                    <span class="metric-value @ExternalRxClass()">@(_externalOntStats.RxPowerDbm.HasValue ? $"{_externalOntStats.RxPowerDbm.Value:0.0#} dBm" : "-")</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">TX:</span>
                    <span class="metric-value">@(_externalOntStats.TxPowerDbm.HasValue ? $"{_externalOntStats.TxPowerDbm.Value:0.0#} dBm" : "-")</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">SFP Temp:</span>
                    <span class="metric-value">@(_externalOntStats.TemperatureC.HasValue ? $"{_externalOntStats.TemperatureC.Value:0.0#} °C" : "-")</span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">SFP Voltage:</span>
                    <span class="metric-value">@(_externalOntStats.VoltageV.HasValue ? $"{_externalOntStats.VoltageV.Value:0.0#} V" : "-")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="sqm-actions">
        <button class="btn btn-secondary" @onclick="RefreshExternal" @onclick:stopPropagation disabled="@_isRefreshing">
            @if (_isRefreshing) { <span class="spinner-sm"></span> } else { <span>Refresh</span> }
        </button>
        <a href="/settings#ont-monitoring" class="btn btn-primary" @onclick:stopPropagation>ONT Settings</a>
    </div>
}
else if (IsShowingExternal)
{
    var extIdx = _currentIndex - _monitoredOnts.Count;
    var extName = extIdx < _externalOnts.Count ? _externalOnts[extIdx].Name : "ONT";
    <div class="sqm-header">
        <div class="sqm-status">
            <span class="status-indicator status-disconnected"></span>
            <span class="status-label">@extName</span>
        </div>
    </div>

    <div class="signal-quality-section signal-centered">
        <div class="ont-rx-gauge">
            <span class="rx-power-value">-</span>
            <span class="rx-power-label">RX optical power</span>
        </div>
        <div class="modem-nav">
            @if (TotalCount > 1)
            {
                <button class="nav-btn" @onclick="Previous" @onclick:stopPropagation disabled="@(_currentIndex == 0)">&#x2039;</button>
                <span class="modem-counter">@(_currentIndex + 1)/@TotalCount</span>
                <button class="nav-btn" @onclick="Next" @onclick:stopPropagation disabled="@(_currentIndex >= TotalCount - 1)">&#x203A;</button>
            }
        </div>
    </div>

    <div class="cellular-metrics" style="margin-top: 0.75rem;">
        <div class="metric-box">
            <div class="metric-header">Optical</div>
            <div class="metric-content">
                <div class="metric-row"><span class="metric-label">RX:</span><span class="metric-value">-</span></div>
                <div class="metric-row"><span class="metric-label">TX:</span><span class="metric-value">-</span></div>
                <div class="metric-row"><span class="metric-label">Temp:</span><span class="metric-value">-</span></div>
            </div>
        </div>
        <div class="metric-box">
            <div class="metric-header">Module</div>
            <div class="metric-content">
                <div class="metric-row"><span class="metric-label">Wavelength:</span><span class="metric-value">-</span></div>
                <div class="metric-row"><span class="metric-label">Voltage:</span><span class="metric-value">-</span></div>
            </div>
        </div>
    </div>

    <div class="sqm-actions">
        <button class="btn btn-secondary" @onclick="RefreshExternal" @onclick:stopPropagation disabled="@_isRefreshing">
            @if (_isRefreshing) { <span class="spinner-sm"></span> } else { <span>Refresh</span> }
        </button>
        <a href="/settings#ont-monitoring" class="btn btn-primary" @onclick:stopPropagation>ONT Settings</a>
    </div>
}
else if (TotalCount == 0)
{
    <div class="sqm-unavailable">
        <div class="sqm-status">
            <span class="status-indicator status-disconnected"></span>
            <span class="status-label">No ONT monitoring configured</span>
        </div>
        <p class="status-message">
            <b>SFP ONT in your gateway?</b> Network Optimizer auto-detects PON modules on
            switch and gateway ports. Open Monitoring to find and enable yours.
        </p>
        <p class="status-message">
            <b>Standalone ONT?</b> Configure external polling for AT&amp;T gateways, Realtek
            ONT sticks, and other devices in Settings.
        </p>
        <div class="sqm-actions">
            <a href="/monitoring?tab=sfp" class="btn btn-secondary" @onclick:stopPropagation>SFP Monitoring</a>
            <a href="/settings#ont-monitoring" class="btn btn-primary" @onclick:stopPropagation>Configure ONT</a>
        </div>
    </div>
}
else
{
    var current = _monitoredOnts[_currentIndex];
    var stats = LiveStats.GetSfpStats(current.DeviceMac, current.PortName);
    var rxClass = OpticalHealthClass(stats?.RxPowerDbm, current.Category);
    var deviceName = ResolveDeviceName(current.DeviceMac);
    var statusLabel = !string.IsNullOrEmpty(current.FriendlyName)
        ? $"{deviceName} - {current.FriendlyName}"
        : $"{deviceName} - Port {current.PortName}";
    <div class="sqm-header">
        <div class="sqm-status">
            <span class="status-indicator status-@(rxClass == "signal-excellent" || rxClass == "signal-good" ? "active" : (rxClass == "signal-fair" ? "warning" : "danger"))"></span>
            <span class="status-label">@statusLabel</span>
        </div>
        @if (stats?.LastUpdate.Year > 1)
        {
            <div class="tc-timestamp">
                <small>Updated: @stats.LastUpdate.ToLocalTime().ToString("HH:mm:ss")</small>
            </div>
        }
    </div>

    <div class="signal-quality-section signal-centered">
        <div class="ont-rx-gauge">
            <span class="rx-power-value @rxClass">
                @(stats?.RxPowerDbm.HasValue == true ? $"{stats.RxPowerDbm.Value:0.0#} dBm" : "-")
            </span>
            <span class="rx-power-label">RX optical power</span>
        </div>
        <div class="modem-nav">
            @if (TotalCount > 1)
            {
                <button class="nav-btn" @onclick="Previous" @onclick:stopPropagation disabled="@(_currentIndex == 0)">‹</button>
                <span class="modem-counter">@(_currentIndex + 1)/@TotalCount</span>
                <button class="nav-btn" @onclick="Next" @onclick:stopPropagation disabled="@(_currentIndex >= TotalCount - 1)">›</button>
            }
        </div>
    </div>

    <div class="cellular-metrics" style="margin-top: 0.75rem;">
        <div class="metric-box">
            <div class="metric-header">Connection</div>
            <div class="metric-content">
                @{ var model = SfpModelLabel(current.SfpVendor, current.SfpPart); }
                @if (!string.IsNullOrEmpty(model))
                {
                    <div class="metric-row">
                        <span class="metric-label">Model:</span>
                        <span class="metric-value ont-model-value">@model</span>
                    </div>
                }
                <div class="metric-row">
                    <span class="metric-label">Link Type:</span>
                    <span class="metric-value @(current.IsActiveEthernet ? "ont-ae-value" : "")">@LinkTypeLabel(current)</span>
                </div>
                @if (current.LinkSpeedMbps.HasValue)
                {
                    <div class="metric-row">
                        <span class="metric-label">SFP Link:</span>
                        <span class="metric-value">
                            @FormatLinkSpeed(current.LinkSpeedMbps.Value)
                            @if (current.IsPon
                                && current.LinkSpeedMbps <= 1000
                                && PonVariantLabel(current.SfpPart, current.SfpVendor) == "GPON"
                                && IsUpgradableGateway())
                            {
                                <a href="/perf-tweaks" class="tooltip-icon tooltip-icon-sm"
                                   data-tooltip="Most GPON SFP ONTs support 2.5 Gbps on this gateway. Check Performance Tweaks."
                                   style="margin-left: 0.35rem;">?</a>
                            }
                        </span>
                    </div>
                }
                <div class="metric-row">
                    <span class="metric-label">SFP Voltage:</span>
                    <span class="metric-value">
                        @(stats?.VoltageV.HasValue == true ? $"{stats.VoltageV.Value:0.0#} V" : "-")
                    </span>
                </div>
            </div>
        </div>
        <div class="metric-box">
            <div class="metric-header">Stats</div>
            <div class="metric-content">
                <div class="metric-row">
                    <span class="metric-label">RX:</span>
                    <span class="metric-value @rxClass">
                        @(stats?.RxPowerDbm.HasValue == true ? $"{stats.RxPowerDbm.Value:0.0#} dBm" : "-")
                    </span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">TX:</span>
                    <span class="metric-value">
                        @(stats?.TxPowerDbm.HasValue == true ? $"{stats.TxPowerDbm.Value:0.0#} dBm" : "-")
                    </span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">Bias:</span>
                    <span class="metric-value">
                        @(stats?.BiasMa.HasValue == true ? $"{stats.BiasMa.Value:0.##} mA" : "-")
                    </span>
                </div>
                <div class="metric-row">
                    <span class="metric-label">SFP Temp:</span>
                    <span class="metric-value">
                        @(stats?.TemperatureC.HasValue == true ? $"{stats.TemperatureC.Value:0.0#} °C" : "-")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="sqm-actions">
        <a href="/monitoring?tab=sfp" class="btn btn-primary" @onclick:stopPropagation>SFP Monitoring</a>
    </div>
}

<style>
    .metric-value.ont-model-value {
        font-size: 0.95rem;
    }
    .metric-value.ont-ae-value {
        font-size: 1.1rem;
    }
    .metric-label {
        color: var(--text-muted, #888);
        flex-shrink: 0;
    }
    .metric-value {
        font-family: monospace;
        color: var(--text-primary);
        text-align: right;
    }
</style>

@code {
    [Parameter]
    public EventCallback OnDataLoaded { get; set; }

    private bool _isLoading = true;
    private List<MonitoredSfp> _monitoredOnts = new();
    private List<OntConfiguration> _externalOnts = new();
    private List<MonitoringTarget> _fabricTargets = new();
    private int _currentIndex = 0;
    private System.Threading.Timer? _refreshTimer;
    private OntStats? _externalOntStats;
    private bool _isRefreshing;

    private int TotalCount => _monitoredOnts.Count + _externalOnts.Count;
    private bool IsShowingExternal => _currentIndex >= _monitoredOnts.Count;

    public bool HasAnyAe => _monitoredOnts.Any(s => s.IsActiveEthernet);

    /// <summary>Whether the current item is an external ONT (for navigation routing)</summary>
    public bool IsCurrentExternal => IsShowingExternal;


    protected override async Task OnInitializedAsync()
    {
        await LoadOntsAsync();
        await OnDataLoaded.InvokeAsync();
        _refreshTimer = new System.Threading.Timer(_ =>
        {
            try
            {
                _ = InvokeAsync(() =>
                {
                    RefreshExternalStats();
                    StateHasChanged();
                });
            }
            catch { }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task LoadOntsAsync()
    {
        _isLoading = true;
        try
        {
            // Monitored SFPs and fabric targets are per-site rows; the main-DB factory
            // showed the main site's ONT vendor/model on every site's card.
            await using var db = SiteDb.CreateForSite(SiteCtx.Slug, SiteCtx.IsDefault);
            _monitoredOnts = await db.MonitoredSfps.AsNoTracking()
                .Where(s => s.IsMonitoredOnt && s.Category != SfpCategory.Standard)
                .OrderBy(s => s.DeviceMac).ThenBy(s => s.PortName)
                .ToListAsync();
            _fabricTargets = await db.MonitoringTargets.AsNoTracking()
                .Where(t => t.TargetType == MonitoringTargetType.Fabric)
                .ToListAsync();
            _externalOnts = await ExternalOntService.GetConfigsAsync();
            if (_currentIndex >= TotalCount) _currentIndex = 0;
            RefreshExternalStats();

            try
            {
                var devices = await ConnectionService.GetDiscoveredDevicesAsync();
                _isUpgradableGateway = devices.Any(d =>
                    d.Type == NetworkOptimizer.Core.Enums.DeviceType.Gateway
                    && (d.Model?.Contains("UXG-Fiber", StringComparison.OrdinalIgnoreCase) == true
                        || d.Model?.Contains("UCG-Fiber", StringComparison.OrdinalIgnoreCase) == true));
            }
            catch { }
        }
        catch { _monitoredOnts = new List<MonitoredSfp>(); }
        finally { _isLoading = false; }
    }

    private string ResolveDeviceName(string deviceMac)
    {
        if (string.IsNullOrEmpty(deviceMac)) return deviceMac;
        var normalized = deviceMac.Replace("-", ":").ToLowerInvariant();
        var target = _fabricTargets.FirstOrDefault(t =>
            !string.IsNullOrEmpty(t.DeviceMac)
            && t.DeviceMac.Replace("-", ":").ToLowerInvariant() == normalized);
        return !string.IsNullOrEmpty(target?.Name) ? target.Name : deviceMac;
    }

    private void Previous()
    {
        if (_currentIndex > 0) { _currentIndex--; RefreshExternalStats(); }
        StateHasChanged();
    }

    private void Next()
    {
        if (_currentIndex < TotalCount - 1) { _currentIndex++; RefreshExternalStats(); }
        StateHasChanged();
    }

    private void RefreshExternalStats()
    {
        if (IsShowingExternal)
        {
            var extIdx = _currentIndex - _monitoredOnts.Count;
            if (extIdx >= 0 && extIdx < _externalOnts.Count)
                _externalOntStats = ExternalOntService.GetCachedStats(_externalOnts[extIdx].Id);
            else
                _externalOntStats = null;
        }
    }

    private async Task RefreshExternal()
    {
        var extIdx = _currentIndex - _monitoredOnts.Count;
        if (extIdx < 0 || extIdx >= _externalOnts.Count || _isRefreshing) return;
        _isRefreshing = true;
        StateHasChanged();
        try
        {
            await ExternalOntService.PollOntAsync(_externalOnts[extIdx].Id);
            RefreshExternalStats();
        }
        finally
        {
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private string ExternalRxClass()
    {
        if (_externalOntStats?.RxPowerDbm == null) return "";
        var v = _externalOntStats.RxPowerDbm.Value;
        if (v >= -22.5 && v <= -8) return "signal-excellent";
        if (v >= -25 && v <= -6) return "signal-good";
        if (v >= -27 && v <= -4) return "signal-fair";
        if (v >= -28.5) return "signal-weak";
        return "signal-poor";
    }

    private static string LinkTypeLabel(MonitoredSfp sfp) => sfp.Category switch
    {
        SfpCategory.ActiveEthernet => "Active Ethernet",
        _ => NetworkOptimizer.Core.Helpers.NetworkFormatHelpers.PonVariantLabel(sfp.SfpPart, sfp.SfpVendor)
    };

    private string ExternalLinkTypeLabel()
    {
        var ponType = _externalOntStats?.PonType;
        var wl = _externalOntStats?.WaveLength;
        if (string.IsNullOrEmpty(ponType)) return "Unknown";
        if (!string.IsNullOrEmpty(wl)) return $"{ponType} ({wl})";
        return ponType;
    }

    private static string OpticalHealthClass(double? rxDbm, SfpCategory category)
    {
        if (!rxDbm.HasValue) return "";
        var v = rxDbm.Value;
        if (category == SfpCategory.ActiveEthernet)
        {
            if (v >= -8 && v <= -1) return "signal-excellent";
            if (v >= -10 && v <= 0) return "signal-good";
            if (v >= -14 && v <= 1) return "signal-fair";
            return "signal-poor";
        }
        if (v >= -22 && v <= -8) return "signal-excellent";
        if (v >= -25 && v <= -6) return "signal-good";
        if (v >= -28 && v <= -4) return "signal-fair";
        return "signal-poor";
    }

    private static string SfpModelLabel(string? vendor, string? part)
    {
        var v = NetworkOptimizer.Core.Helpers.NetworkFormatHelpers.CleanOrgName(vendor);
        var p = part?.Trim();
        if (string.IsNullOrEmpty(v) && string.IsNullOrEmpty(p)) return "";
        if (string.IsNullOrEmpty(v)) return p!;
        if (string.IsNullOrEmpty(p)) return v;
        return $"{v} {p}";
    }

    private static string PonVariantLabel(string? sfpPart, string? sfpVendor) =>
        NetworkOptimizer.Core.Helpers.NetworkFormatHelpers.PonVariantLabel(sfpPart, sfpVendor);

    private bool _isUpgradableGateway;

    private bool IsUpgradableGateway() => _isUpgradableGateway;

    private static string FormatLinkSpeed(int mbps) => mbps >= 1000
        ? $"{mbps / 1000.0:0.##} Gbps"
        : $"{mbps} Mbps";

    public string? CurrentModuleKey
    {
        get
        {
            if (IsShowingExternal) return null;
            if (_monitoredOnts.Count == 0) return null;
            return $"{_monitoredOnts[_currentIndex].DeviceMac.Replace("-", ":").ToLowerInvariant()}:{_monitoredOnts[_currentIndex].PortName}";
        }
    }

    public string? CurrentExternalOntId
    {
        get
        {
            if (!IsShowingExternal) return null;
            var extIdx = _currentIndex - _monitoredOnts.Count;
            if (extIdx >= 0 && extIdx < _externalOnts.Count)
                return _externalOnts[extIdx].Id.ToString();
            return null;
        }
    }

    public void Dispose() => _refreshTimer?.Dispose();
}
