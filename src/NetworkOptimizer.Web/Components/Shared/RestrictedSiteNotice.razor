@using NetworkOptimizer.Web.Services.Licensing
@implements IDisposable
@inject LicenseStateService LicenseState
@inject SiteContextService SiteContext

@if (!LicenseState.IsSiteOperational(SiteContext.Slug))
{
    <div class="connection-banner connection-error license-restricted-banner">
        <div class="banner-content">
            <span class="banner-icon">!</span>
            <div class="banner-text">
                <strong>Operations disabled for this site</strong>
                <span>This site's license expired. Historic data below remains available; enter or renew a license key in Settings &gt; Application &gt; Licensing to restore operations.</span>
            </div>
            <a href="/settings#licensing" class="btn btn-primary">Open Settings</a>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        LicenseState.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => LicenseState.OnStateChanged -= HandleStateChanged;
}
