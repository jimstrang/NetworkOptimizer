@using NetworkOptimizer.Core.Helpers
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.Web.Services
@inject SiteManagementService SiteManagement
@inject SiteConnectionRegistry SiteConnections
@inject AgentEnrollmentService AgentEnrollment
@inject NetworkOptimizer.Storage.Services.SiteDbContextFactory SiteDb
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="site-wizard">
    @if (_step == 1)
    {
        <label class="form-label">Add Site <span class="form-help">(Step 1 of 4)</span></label>
        @if (_remainingSlots <= 0)
        {
            <p class="section-description">
                You've reached the @SiteManagementService.FreeSiteLimit-site limit for this license
                (personal, non-commercial use). Remove a site to add another, or contact
                <a href="mailto:tj@ozarkconnect.net">tj@@ozarkconnect.net</a> about licensing for more sites.
            </p>
        }
        else
        {
            <div class="form-group">
                <div class="input-with-button">
                    <input type="text" class="form-control" @bind="_name" @bind:event="oninput"
                           placeholder="Site name (e.g. Lake House)" autocomplete="off" data-1p-ignore data-lpignore="true" data-bwignore />
                    <button type="button" class="btn btn-primary btn-sm" @onclick="CreateSiteAsync"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_name))">
                        @if (_busy)
                        {
                            <span class="spinner"></span>
                        }
                        else
                        {
                            <span>Create Site</span>
                        }
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_name))
                {
                    <small class="form-help">Site ID: <code>@StringUtilities.ToSlug(_name)</code> - permanent identifier used for the site's database file, InfluxDB buckets, and agent configuration.</small>
                }
            </div>
        }
    }
    else if (_step == 2 && _site != null)
    {
        <label class="form-label">Connect the UniFi Console for @_site.Name <span class="form-help">(Step 2 of 4)</span></label>
        <p class="section-description">
            If this site's UniFi Console is reachable from this server (site-to-site VPN or a public address),
            connect it now. You can also skip this and connect later from Settings after switching to the site.
        </p>
        <div class="form-group">
            <label class="form-label">Console URL</label>
            <input type="text" class="form-control" @bind="_consoleUrl" placeholder="https://192.168.1.1" autocomplete="off" data-1p-ignore data-lpignore="true" data-bwignore />
        </div>
        <div class="form-group">
            <label class="form-label">Authentication Method</label>
            <div class="auth-method-toggle">
                <label class="radio-label">
                    <input type="radio" name="siteWizardAuth" checked="@(!_useApiKey)" @onchange="() => _useApiKey = false" />
                    <span>Local Account</span>
                </label>
                <label class="radio-label">
                    <input type="radio" name="siteWizardAuth" checked="@_useApiKey" @onchange="() => _useApiKey = true" />
                    <span>API Key</span>
                </label>
            </div>
        </div>
        @if (!_useApiKey)
        {
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" class="form-control" @bind="_username" autocomplete="off" data-1p-ignore data-lpignore="true" data-bwignore />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" @bind="_password" autocomplete="new-password" data-1p-ignore data-lpignore="true" data-bwignore />
            </div>
        }
        else
        {
            <div class="form-group">
                <label class="form-label">Network API Key</label>
                <input type="password" class="form-control" @bind="_apiKey" autocomplete="new-password" data-1p-ignore data-lpignore="true" data-bwignore />
            </div>
        }
        <div class="action-buttons">
            <button type="button" class="btn btn-primary" @onclick="ConnectAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_consoleUrl))">
                @if (_busy)
                {
                    <span class="spinner"></span>
                    <span>Connecting...</span>
                }
                else
                {
                    <span>Connect &amp; Save</span>
                }
            </button>
            <button type="button" class="btn btn-secondary" @onclick="() => _step = 3" disabled="@_busy">Skip for Now</button>
        </div>
    }
    else if (_step == 3 && _site != null)
    {
        <label class="form-label">On-site agent for @_site.Name <span class="form-help">(Step 3 of 4)</span></label>
        @if (!_wantAgent && _agentToken == null)
        {
            <p class="section-description">
                An agent runs at the site and dials out to this server - no inbound access to the
                site needed. It's what powers this site's network monitoring (SNMP, device stats,
                Live View), ISP Health, LAN speed tests, and cable modem / ONT status from here.
                Set one up unless this server already reaches the whole site over a VPN - and even
                then, modem/ONT management IPs usually make an agent the cleaner path.
            </p>
            <div class="action-buttons">
                <button type="button" class="btn btn-primary" @onclick="() => _wantAgent = true">Set Up an Agent</button>
                <button type="button" class="btn btn-secondary" @onclick="() => _step = 4">No Agent Needed</button>
            </div>
        }
        else if (_agentToken == null)
        {
            <p class="section-description">Choose what the agent does at the site:</p>
            <label class="checkbox-toggle">
                <input type="checkbox" checked disabled />
                <span><strong>Site monitoring</strong> - reaches the site's devices for SNMP polling,
                    latency/loss probing, and modem/ONT status pages. Always on; it's what the agent is for.</span>
            </label>
            <label class="checkbox-toggle">
                <input type="checkbox" @bind="_featureLanSpeedTest" />
                <span><strong>LAN speed test server</strong>
                    <span class="tooltip-icon tooltip-icon-sm" data-tooltip="Hosts an OpenSpeedTest page and an iperf3 server at the site for the site's own clients">?</span>
                    - lets the site's clients run speed tests against the agent.</span>
            </label>
            <label class="checkbox-toggle">
                <input type="checkbox" @bind="_featureProxy" />
                <span><strong>SSH and UniFi Console proxy</strong> - this server reaches the site's console,
                    gateway, and devices through the agent tunnel. Enables audits, gateway WAN speed
                    tests, deployments, and modem / ONT monitoring with no VPN.</span>
            </label>
            <div class="action-buttons">
                <button type="button" class="btn btn-primary" @onclick="CreateAgentAsync" disabled="@_busy">
                    @if (_busy)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <span>Create Agent Token</span>
                    }
                </button>
                <button type="button" class="btn btn-secondary" @onclick="() => { _wantAgent = false; _step = 4; }" disabled="@_busy">Skip</button>
            </div>
        }
        else
        {
            <AgentInstallInstructions Token="@_agentToken" LanSpeedTest="_featureLanSpeedTest" />
            <div class="action-buttons">
                <button type="button" class="btn btn-primary" @onclick="() => _step = 4">Continue</button>
            </div>
        }
    }
    else if (_step == 4 && _site != null)
    {
        <label class="form-label">@_site.Name is ready <span class="form-help">(Step 4 of 4)</span></label>
        <p class="section-description">
            The site's database is provisioned@(_connected ? ", its UniFi Console is connected" : "")@(_agentToken != null ? ", and its agent token is issued" : "").
            Switch to the site to configure monitoring, speed tests, and everything else, exactly like a
            single-site install.
        </p>
        <div class="action-buttons">
            <button type="button" class="btn btn-primary" @onclick="SwitchToSiteAsync">Switch to @_site.Name</button>
            <button type="button" class="btn btn-secondary" @onclick="ResetAsync">Add Another Site</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-@_messageClass">@_message</div>
    }
</div>

@code {
    [Parameter]
    public EventCallback OnSitesChanged { get; set; }

    private int _remainingSlots = int.MaxValue;

    protected override async Task OnInitializedAsync() => await RefreshLimitAsync();

    private async Task RefreshLimitAsync() => _remainingSlots = await SiteManagement.RemainingSiteSlotsAsync();

    private int _step = 1;
    private bool _busy;
    private Site? _site;
    private string _name = "";
    private string _message = "";
    private string _messageClass = "";

    private string _consoleUrl = "";
    private bool _useApiKey;
    private string _username = "";
    private string _password = "";
    private string _apiKey = "";
    private bool _connected;
    private string? _consoleName;

    private bool _wantAgent;
    private string? _agentToken;
    private bool _featureLanSpeedTest;
    private bool _featureProxy;

    /// <summary>
    /// Re-enters the wizard at the agent step (step 3) for a site that already
    /// exists, landing on the feature selection so a site whose agent was never
    /// finished can be set up without recreating the site. Called by the
    /// Multi-Site settings panel when an agent is not fully enrolled.
    /// </summary>
    public void StartAgentSetupFor(Site site)
    {
        _site = site;
        _connected = SiteConnections.GetFor(site.Slug).IsConnected;
        _step = 3;
        _wantAgent = true;
        _agentToken = null;
        _featureLanSpeedTest = false;
        _featureProxy = false;
        _message = "";
        _messageClass = "";
        StateHasChanged();
    }

    private async Task CreateSiteAsync()
    {
        _busy = true;
        _message = "";
        StateHasChanged();

        try
        {
            _site = await SiteManagement.CreateSiteAsync(_name);
            _step = 2;
            _message = $"Site '{_site.Name}' created with ID '{_site.Slug}'";
            _messageClass = "success";
            await OnSitesChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _message = $"Error creating site: {ex.Message}";
            _messageClass = "danger";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ConnectAsync()
    {
        if (_site == null)
            return;

        _busy = true;
        _message = "";
        StateHasChanged();

        try
        {
            var connection = SiteConnections.GetFor(_site.Slug);
            var config = new UniFiConnectionConfig
            {
                ControllerUrl = _consoleUrl.Trim(),
                Username = _username,
                Password = _password,
                ApiKey = _useApiKey ? _apiKey : null,
            };

            _connected = await connection.ConnectAsync(config);
            if (_connected)
            {
                _consoleName = await connection.GetCachedConsoleNameAsync();
                _message = string.IsNullOrWhiteSpace(_consoleName)
                    ? "Console connected. Credentials saved to the site's database."
                    : $"Connected to {_consoleName}. Credentials saved to the site's database.";
                _messageClass = "success";
                _step = 3;
                await OnSitesChanged.InvokeAsync();
            }
            else
            {
                _message = $"Connection failed: {connection.LastError ?? "unknown error"}";
                _messageClass = "danger";
            }
        }
        catch (Exception ex)
        {
            _message = $"Connection failed: {ex.Message}";
            _messageClass = "danger";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateAgentAsync()
    {
        if (_site == null)
            return;

        _busy = true;
        _message = "";
        StateHasChanged();

        try
        {
            // Reuse the site's not-yet-enrolled agent if one exists (re-entering
            // setup should refresh its token, not stack up duplicate agents);
            // only create a row when the site has none.
            var existing = await AgentEnrollment.GetAgentsForSiteAsync(_site.Id);
            var pending = existing.FirstOrDefault(a => a.EnrolledAt == null);
            _agentToken = pending != null
                ? await AgentEnrollment.ReissueTokenAsync(pending.Id)
                : null;
            _agentToken ??= (await AgentEnrollment.CreateAgentAsync(_site.Id, "Agent")).Token;

            if (_featureProxy)
            {
                // Same per-site flags the Multi-Site panel toggles expose: console
                // and device reach through the agent tunnel, stored in the site's
                // own database.
                await using var db = SiteDb.CreateForSite(_site.Slug, _site.IsDefault);
                UpsertSetting(db, UniFiConnectionService.ConsoleViaAgentKey, "True");
                UpsertSetting(db, SiteTunnelRouting.DevicesViaAgentKey, "True");
                await db.SaveChangesAsync();
            }

            await OnSitesChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _message = $"Failed to create agent: {ex.Message}";
            _messageClass = "danger";
        }
        finally
        {
            _busy = false;
        }
    }

    private static void UpsertSetting(NetworkOptimizerDbContext db, string key, string value)
    {
        var setting = db.SystemSettings.Find(key);
        if (setting == null)
        {
            db.SystemSettings.Add(new SystemSetting { Key = key, Value = value });
        }
        else
        {
            setting.Value = value;
            setting.UpdatedAt = DateTime.UtcNow;
        }
    }

    private async Task SwitchToSiteAsync()
    {
        if (_site == null)
            return;

        await JS.InvokeVoidAsync("eval",
            $"document.cookie = '{SiteContextService.CookieName}={_site.Slug}; path=/; max-age=31536000; SameSite=Lax'");
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private async Task ResetAsync()
    {
        await RefreshLimitAsync();
        _step = 1;
        _site = null;
        _name = "";
        _consoleUrl = "";
        _username = "";
        _password = "";
        _apiKey = "";
        _useApiKey = false;
        _connected = false;
        _wantAgent = false;
        _agentToken = null;
        _featureLanSpeedTest = false;
        _featureProxy = false;
        _message = "";
        await OnSitesChanged.InvokeAsync();
    }
}
