@page "/login"
@rendermode InteractiveServer
@layout AuthLayout
@using NetworkOptimizer.Web.Services
@inject NavigationManager Navigation
@inject IAdminAuthService AdminAuth
@inject IJwtService JwtService
@inject SiteSwitchService SiteSwitch

<PageTitle>Login - Network Optimizer</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <img src="/images/ozark-connect-logo.png" alt="Network Optimizer" class="login-logo" />
            <h1>Network Optimizer</h1>
            <p class="login-subtitle">for UniFi</p>
        </div>

        <form @onsubmit="HandleLogin" @onsubmit:preventDefault>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password"
                       class="form-control"
                       @bind="password"
                       @bind:event="oninput"
                       placeholder="Enter admin password"
                       autofocus
                       disabled="@(isLoading || isRedirecting)" />
            </div>

            <button type="submit" class="btn btn-primary login-btn" disabled="@(isLoading || isRedirecting)">
                @if (isRedirecting)
                {
                    <span class="spinner"></span>
                    <span>Loading...</span>
                }
                else if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">
                    @errorMessage
                </div>
            }
        </form>

        @if (isAutoGenerated)
        {
            <div class="login-footer">
                <small class="text-muted">
                    Using auto-generated password from startup logs.<br/>
                    Set a permanent password in Settings after login.
                </small>
            </div>
        }
    </div>
</div>

@code {
    private string password = "";
    private string? errorMessage;
    private bool isLoading;
    private bool isRedirecting;
    private bool isAutoGenerated;

    protected override async Task OnInitializedAsync()
    {
        var source = await AdminAuth.GetPasswordSourceAsync();
        isAutoGenerated = source == AdminPasswordSource.AutoGenerated;
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrEmpty(password))
        {
            errorMessage = "Please enter a password";
            return;
        }

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var isValid = await AdminAuth.ValidatePasswordAsync(password);

            if (isValid)
            {
                // Generate JWT token
                var token = await JwtService.GenerateTokenAsync();

                // Keep spinner showing during redirect
                isLoading = false;
                isRedirecting = true;
                StateHasChanged();

                // Set cookie and redirect to home, keeping the tab's ?site= pin (the
                // auth middleware carries it onto /login) so re-auth lands on the
                // same site the tab was on.
                // Note: forceLoad navigation will throw TaskCanceledException as the circuit
                // is destroyed during the page reload - this is expected behavior
                var returnUrl = await SiteSwitch.StampSiteAsync("/");
                try
                {
                    Navigation.NavigateTo($"/api/auth/set-cookie?token={Uri.EscapeDataString(token)}&returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
                }
                catch (TaskCanceledException)
                {
                    // Expected - circuit destroyed during forceLoad navigation
                }
            }
            else
            {
                errorMessage = "Invalid password";
                password = "";
                isLoading = false;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            errorMessage = "Login failed. Please try again.";
            isLoading = false;
            StateHasChanged();
        }
    }
}
