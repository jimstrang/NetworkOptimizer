        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .pt-modal {
        background: var(--bg-secondary);
        border-radius: 0.75rem;
        max-width: 540px;
        width: 100%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
