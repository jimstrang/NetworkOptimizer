    private void TransformChartData()
    {
        // Discover distinct WANs from ALL history (not just time-filtered)
        var allWanKeys = _testHistory
            .Where(r => r.Success)
            .Select(r => GetWanKey(r))
            .Distinct()
            .OrderBy(k => k)
            .ToList();

        // Preserve selection state from previous series
        var previousSelection = _wanSeries.ToDictionary(w => w.Key, w => w.IsSelected);

        _wanSeries = allWanKeys.Select((key, i) => new WanSeriesInfo
        {
            Key = key,
            DisplayName = GetWanDisplayNameForKey(key),
            Color = WanColors[i % WanColors.Length],
            IsSelected = !previousSelection.TryGetValue(key, out var selected) || selected,
            DownloadData = new(),
            UploadData = new()
        }).ToList();

        // Ensure at least one WAN series exists for single-WAN users
        if (_wanSeries.Count == 0 && _testHistory.Any(r => r.Success))
        {
            _wanSeries.Add(new WanSeriesInfo
            {
                Key = "WAN",
                DisplayName = "WAN1",
                Color = WanColors[0],
                DownloadData = new(),
                UploadData = new()
            });
        }

        UpdateChartOptions();
        UpdateLatencyChartOptions();
        UpdateLoadedLatencyChartOptions();
        UpdateJitterChartOptions();
    }

    private List<Iperf3Result> GetTimeFilteredResults()
    {
        var clampedIndex = Math.Clamp(_sliderValue, 0, TimeBreakpoints.Length - 1);
        var hours = TimeBreakpoints[clampedIndex].hours;
        if (hours <= 0)
            return _testHistory;

        var cutoff = DateTime.UtcNow.AddHours(-hours);
        return _testHistory.Where(r => r.TestTime >= cutoff).ToList();
    }

    /// <summary>
    /// Collapse dense clusters of similar values into representative points.
    /// Only collapses points that are close in BOTH value AND time - points
    /// spread far apart in time are kept even if similar values (they show stability).
    /// </summary>
    private static List<WanChartDataPoint> CollapseClusters(List<WanChartDataPoint> data)
    {
        if (data.Count <= 3)
            return data;

        var range = (double)(data.Max(d => d.Value) - data.Min(d => d.Value));
        if (range < 1) return data;
        var valueThreshold = range * 0.15; // 15% of range to count as "different"
        var timeThreshold = TimeSpan.FromHours(2); // Points >2 hrs apart are always kept

        var result = new List<WanChartDataPoint> { data[0] };

        for (int i = 1; i < data.Count - 1; i++)
        {
            var lastKept = result[^1];
            var curr = data[i];
            var timeSinceLastKept = curr.Timestamp - lastKept.Timestamp;

            // Always keep if enough time has passed (shows stability over time)
            if (timeSinceLastKept >= timeThreshold)
            {
                result.Add(curr);
                continue;
            }

            // Within a time cluster: only keep if value changed significantly
            if (Math.Abs((double)curr.Value - (double)lastKept.Value) > valueThreshold)
                result.Add(curr);
        }

        result.Add(data[^1]);
        return result;
    }

    /// <summary>
    /// Largest-Triangle-Three-Buckets downsampling. Selects real data points
    /// that best preserve the visual shape of the time series.
    /// Data must be sorted by Timestamp ascending.
    /// </summary>
    private static List<WanChartDataPoint> DownsampleLttb(List<WanChartDataPoint> data, int targetCount)
    {
        if (data.Count <= targetCount || targetCount < 3)
            return data;

        var result = new List<WanChartDataPoint>(targetCount);
        result.Add(data[0]);

        double bucketSize = (double)(data.Count - 2) / (targetCount - 2);
        int prevSelectedIndex = 0;

        for (int bucket = 0; bucket < targetCount - 2; bucket++)
        {
            int currStart = (int)Math.Floor(bucket * bucketSize) + 1;
            int currEnd = (int)Math.Floor((bucket + 1) * bucketSize) + 1;
            currEnd = Math.Min(currEnd, data.Count - 1);

            double avgX, avgY;
            if (bucket == targetCount - 3)
            {
                avgX = data[^1].X;
                avgY = (double)data[^1].Value;
            }
            else
            {
                int nextStart = currEnd;
                int nextEnd = (int)Math.Floor((bucket + 2) * bucketSize) + 1;
                nextEnd = Math.Min(nextEnd, data.Count - 1);

                avgX = 0; avgY = 0;
                int count = 0;
                for (int j = nextStart; j < nextEnd; j++)
                {
                    avgX += data[j].X;
                    avgY += (double)data[j].Value;
                    count++;
                }
                if (count > 0) { avgX /= count; avgY /= count; }
                else { avgX = data[nextStart].X; avgY = (double)data[nextStart].Value; }
            }

            double maxArea = -1;
            int bestIndex = currStart;
            double prevX = data[prevSelectedIndex].X;
            double prevY = (double)data[prevSelectedIndex].Value;

            for (int j = currStart; j < currEnd; j++)
            {
                double area = Math.Abs(
                    (prevX - avgX) * ((double)data[j].Value - prevY) -
                    (prevX - data[j].X) * (avgY - prevY)
                );
                if (area > maxArea)
                {
                    maxArea = area;
                    bestIndex = j;
                }
            }

            result.Add(data[bestIndex]);
            prevSelectedIndex = bestIndex;
        }

        result.Add(data[^1]);
        return result;
    }

    private void ApplyFilters()
    {
        var timeFiltered = GetTimeFilteredResults();

        // Apply WAN badge filter (none selected or no series = show all)
        var visibleWanKeys = _wanSeries.Where(w => IsWanVisible(w)).Select(w => w.Key).ToHashSet();
        _filteredHistory = visibleWanKeys.Count == 0
            ? timeFiltered.ToList()
            : timeFiltered
                .Where(r =>
                {
                    // Failed results without WAN metadata: only show when no filter is active
                    if (!r.Success && string.IsNullOrEmpty(r.WanNetworkGroup))
                        return false;
                    // Everything else (successful or failed with WAN metadata): filter by connection
                    return visibleWanKeys.Contains(GetWanKey(r));
                })
                .ToList();

        // Update chart data for the active time window
        var clampedIndex = Math.Clamp(_sliderValue, 0, TimeBreakpoints.Length - 1);
        var shouldDownsample = TimeBreakpoints[clampedIndex].hours is 0 or > 4;

        foreach (var wan in _wanSeries)
        {
            var wanResults = timeFiltered
                .Where(r => r.Success && GetWanKey(r) == wan.Key)
                .OrderBy(r => r.TestTime)
                .ToList();

            // Speed chart data
            var downloadRaw = wanResults
                .Select(r => new WanChartDataPoint(r.TestTime, r.DownloadMbps, r.Id))
                .ToList();
            var uploadRaw = wanResults
                .Select(r => new WanChartDataPoint(r.TestTime, r.UploadMbps, r.Id))
                .ToList();

            if (shouldDownsample)
            {
                // Downsample download, then sync upload to the same timestamps
                // so shared tooltips can pair both values at each point
                wan.DownloadData = DownsampleLttb(CollapseClusters(downloadRaw), MaxChartPoints);
                var keptResultIds = wan.DownloadData.Select(d => d.ResultId).ToHashSet();
                wan.UploadData = uploadRaw.Where(u => keptResultIds.Contains(u.ResultId)).ToList();
            }
            else
            {
                wan.DownloadData = downloadRaw;
                wan.UploadData = uploadRaw;
            }

            // Latency chart data (unloaded ping)
            var latencyRaw = wanResults
                .Where(r => r.PingMs.HasValue)
                .Select(r => new WanChartDataPoint(r.TestTime, r.PingMs!.Value, r.Id))
                .ToList();
            wan.LatencyData = shouldDownsample
                ? DownsampleLttb(CollapseClusters(latencyRaw), MaxChartPoints)
                : latencyRaw;

            // Loaded latency chart data (base + loaded down + loaded up)
            // Only include results that have all three values for consistent tooltip alignment
            var loadedResults = wanResults
                .Where(r => r.PingMs.HasValue && r.DownloadLatencyMs.HasValue && r.UploadLatencyMs.HasValue)
                .ToList();
            var loadedBaseRaw = loadedResults
                .Select(r => new WanChartDataPoint(r.TestTime, r.PingMs!.Value, r.Id))
                .ToList();
            var loadedDownRaw = loadedResults
                .Select(r => new WanChartDataPoint(r.TestTime, r.DownloadLatencyMs!.Value, r.Id))
                .ToList();
            var loadedUpRaw = loadedResults
                .Select(r => new WanChartDataPoint(r.TestTime, r.UploadLatencyMs!.Value, r.Id))
                .ToList();

            if (shouldDownsample)
            {
                // Downsample base as anchor, sync loaded down & up to same result IDs
                var baseDownsampled = DownsampleLttb(CollapseClusters(loadedBaseRaw), MaxChartPoints);
                var keptIds = baseDownsampled.Select(d => d.ResultId).ToHashSet();
                wan.LoadedLatencyBaseData = baseDownsampled;
                wan.LoadedLatencyDownData = loadedDownRaw.Where(p => keptIds.Contains(p.ResultId)).ToList();
                wan.LoadedLatencyUpData = loadedUpRaw.Where(p => keptIds.Contains(p.ResultId)).ToList();
            }
            else
            {
                wan.LoadedLatencyBaseData = loadedBaseRaw;
                wan.LoadedLatencyDownData = loadedDownRaw;
                wan.LoadedLatencyUpData = loadedUpRaw;
            }

            // Jitter chart data (unloaded jitter)
            var jitterRaw = wanResults
                .Where(r => r.JitterMs.HasValue)
                .Select(r => new WanChartDataPoint(r.TestTime, r.JitterMs!.Value, r.Id))
                .ToList();
            wan.JitterData = shouldDownsample
                ? DownsampleLttb(CollapseClusters(jitterRaw), MaxChartPoints)
                : jitterRaw;
        }
    }

    private static string GetWanKey(Iperf3Result result)
    {
        // Group by WAN name alone when the name is custom (user-provided like "Fiber Link"),
        // so results stay grouped even if the WAN group changes (e.g., WAN -> WAN4).
        // For generic names (WAN, WAN2, Internet), include the group to distinguish interfaces.
        var group = !string.IsNullOrEmpty(result.WanNetworkGroup) ? result.WanNetworkGroup : "WAN";
        var name = !string.IsNullOrEmpty(result.WanName) ? result.WanName : null;

        if (name != null && name.Contains(" + "))
        {
            // Combo test: sort parts for consistent keying
            var nameParts = name.Split(" + ").Order().ToArray();
            var sortedName = string.Join(" + ", nameParts);

            // If all parts are custom names, key by name only
            if (nameParts.All(p => !DisplayFormatters.IsGenericWanName(p)))
                return sortedName;

            // Any generic name: include group to distinguish
            var sortedGroup = string.Join("+", group.Split('+').Order());
            return $"{sortedGroup}|{sortedName}";
        }

        if (name != null && !DisplayFormatters.IsGenericWanName(name))
            return name; // Custom name: key by name alone

        return name != null ? $"{group}|{name}" : group;
    }



    private static string GetWanDisplayName(Iperf3Result result)
    {
        if (!string.IsNullOrEmpty(result.WanName))
        {
            if (result.WanName.Contains(" + "))
                return string.Join(" + ", result.WanName.Split(" + ").Order());
            return result.WanName;
        }
        if (!string.IsNullOrEmpty(result.WanNetworkGroup))
            return DisplayFormatters.NormalizeWanDisplay(result.WanNetworkGroup);
        return "WAN1";
    }

    private static string GetWanDisplayNameForKey(string key)
    {
        // Key format: "GROUP|Name" (generic), just "Name" (custom), or "GROUP" (legacy)
        if (key.Contains('|'))
            return key.Split('|')[1];
        if (string.Equals(key, "ALL_WAN", StringComparison.OrdinalIgnoreCase))
            return "All WAN Links";
        // If it's not a generic WAN name, it's a custom name key - return as-is
        if (!DisplayFormatters.IsGenericWanName(key))
            return key;
        return DisplayFormatters.NormalizeWanDisplay(key);
    }

    private static string TruncateServerList(string? serverList, int max = 4)
    {
        if (string.IsNullOrEmpty(serverList)) return "WAN";
        var parts = serverList.Split(" | ");
        if (parts.Length <= max) return serverList;
        return string.Join(" | ", parts.Take(max)) + $" + {parts.Length - max} more";
    }

