    private int MaxSignalChartPoints => _isMobile ? 30 : 60;
    private int MaxSpeedChartPoints => _isMobile ? 30 : 60;

    /// <summary>
    /// Largest-Triangle-Three-Buckets downsampling. Selects real data points
    /// that best preserve the visual shape of the time series.
    /// Works with any list that has X (epoch ms) and Value (decimal) properties.
    /// </summary>
    private static List<T> DownsampleLttb<T>(List<T> data, int targetCount, Func<T, long> getX, Func<T, double> getY)
    {
        if (data.Count <= targetCount || targetCount < 3)
            return data;

        var result = new List<T>(targetCount);
        result.Add(data[0]);

        double bucketSize = (double)(data.Count - 2) / (targetCount - 2);
        int prevSelectedIndex = 0;

        for (int bucket = 0; bucket < targetCount - 2; bucket++)
        {
            int currStart = (int)Math.Floor(bucket * bucketSize) + 1;
            int currEnd = (int)Math.Floor((bucket + 1) * bucketSize) + 1;
            currEnd = Math.Min(currEnd, data.Count - 1);

            double avgX, avgY;
            if (bucket == targetCount - 3)
            {
                avgX = getX(data[^1]);
                avgY = getY(data[^1]);
            }
            else
            {
                int nextStart = currEnd;
                int nextEnd = (int)Math.Floor((bucket + 2) * bucketSize) + 1;
                nextEnd = Math.Min(nextEnd, data.Count - 1);

                avgX = 0; avgY = 0;
                int count = 0;
                for (int j = nextStart; j < nextEnd; j++)
                {
                    avgX += getX(data[j]);
                    avgY += getY(data[j]);
                    count++;
                }
                if (count > 0) { avgX /= count; avgY /= count; }
                else { avgX = getX(data[nextStart]); avgY = getY(data[nextStart]); }
            }

            double maxArea = -1;
            int bestIndex = currStart;
            double prevX = getX(data[prevSelectedIndex]);
            double prevY = getY(data[prevSelectedIndex]);

            for (int j = currStart; j < currEnd; j++)
            {
                double area = Math.Abs(
                    (prevX - avgX) * (getY(data[j]) - prevY) -
                    (prevX - getX(data[j])) * (avgY - prevY)
                );
                if (area > maxArea)
                {
                    maxArea = area;
                    bestIndex = j;
                }
            }

            result.Add(data[bestIndex]);
            prevSelectedIndex = bestIndex;
        }

        result.Add(data[^1]);
        return result;
    }

    private List<CollapsedSignalRow> _cachedCollapsed = new();

    private List<CollapsedSignalRow> GetSortedSignalHistory()
    {
        // Downsample based on selected time range
        var data = DownsampleForDisplay(_signalHistory);

        // Sort the data
        data = _signalSortCol switch
        {
            "signal" => _signalSortAsc
                ? data.OrderBy(e => e.SignalDbm ?? int.MinValue)
                : data.OrderByDescending(e => e.SignalDbm ?? int.MinValue),
            "band" => _signalSortAsc
                ? data.OrderBy(e => e.Band ?? "")
                : data.OrderByDescending(e => e.Band ?? ""),
            "ap" => _signalSortAsc
                ? data.OrderBy(e => e.ApName ?? "")
                : data.OrderByDescending(e => e.ApName ?? ""),
            "channel" => _signalSortAsc
                ? data.OrderBy(e => e.Channel ?? 0)
                : data.OrderByDescending(e => e.Channel ?? 0),
            _ => _signalSortAsc
                ? data.OrderBy(e => e.Timestamp).ThenByDescending(e => e.DataSource)
                : data.OrderByDescending(e => e.Timestamp).ThenBy(e => e.DataSource)
        };

        // Collapse consecutive identical rows into ranges
        var collapsed = new List<CollapsedSignalRow>();
        CollapsedSignalRow? current = null;

        foreach (var entry in data)
        {
            if (current != null && current.IsSameAs(entry))
            {
                current.EndTime = entry.Timestamp;
                current.Count++;
            }
            else
            {
                current = new CollapsedSignalRow(entry);
                collapsed.Add(current);
            }
        }

        _cachedCollapsed = collapsed;
        return collapsed;
    }

    private int SignalTotalPages => Math.Max(1, (int)Math.Ceiling(_cachedCollapsed.Count / (double)SignalPageSize));

    private IEnumerable<CollapsedSignalRow> GetPagedSignalHistory()
