    private async Task DismissIssue(Services.AuditIssue issue)
    {
        await AuditService.DismissIssueAsync(issue);

        // Move from active to dismissed
        issues.Remove(issue);
        dismissedIssues.Add(issue);

        // Update counts
        criticalCount = issues.Count(i => i.Severity == AuditSeverity.Critical);
        warningCount = issues.Count(i => i.Severity == AuditSeverity.Recommended);
        infoCount = issues.Count(i => i.Severity == AuditSeverity.Informational);

        StateHasChanged();
    }

    private async Task RestoreIssue(Services.AuditIssue issue)
    {
        await AuditService.RestoreIssueAsync(issue);

        // Move from dismissed to active
        dismissedIssues.Remove(issue);
        issues.Add(issue);

        // Update counts
        criticalCount = issues.Count(i => i.Severity == AuditSeverity.Critical);
        warningCount = issues.Count(i => i.Severity == AuditSeverity.Recommended);
        infoCount = issues.Count(i => i.Severity == AuditSeverity.Informational);

        StateHasChanged();
    }

    private string GetEffectivePurpose(string networkId, string auditPurpose)
    {
        // Show the override if one exists, otherwise the audit-detected purpose
        if (_purposeOverrides.TryGetValue(networkId, out var overridePurpose))
            return overridePurpose;
        // Map display strings back to enum names (e.g., "DMZ" -> "Dmz", "Unclassified" -> "Unknown")
        return _purposeOptions.FirstOrDefault(p => p.Display == auditPurpose).Value ?? auditPurpose;
    }

    private async Task OnPurposeChanged(string networkId, string? newPurpose)
    {
        if (string.IsNullOrEmpty(newPurpose)) return;

        _purposeOverrides[networkId] = newPurpose;
        await AuditService.SaveNetworkPurposeOverrideAsync(networkId, newPurpose);

        // Show "Saved" indicator
        _purposeSaved[networkId] = true;
        _purposeOverridesPending = true;
        StateHasChanged();

        // Clear "Saved" after 2 seconds
        if (_purposeSavedTimers.TryGetValue(networkId, out var existingTimer))
        {
            existingTimer.Stop();
            existingTimer.Dispose();
        }

        var timer = new System.Timers.Timer(2000) { AutoReset = false };
        timer.Elapsed += async (_, _) =>
        {
            try
            {
                await InvokeAsync(() =>
                {
                    _purposeSaved[networkId] = false;
                    StateHasChanged();
                });
            }
            catch { /* component may be disposed */ }
        };
        _purposeSavedTimers[networkId] = timer;
        timer.Start();
    }

    // Re-render only, so the banner clears and Run Audit enables when the console
    // connection comes up. Deliberately does not start an audit (manual action).
    private void HandleConnectionChanged() => _ = InvokeAsync(() =>
    {
        try { StateHasChanged(); }
        catch { /* circuit may be tearing down */ }
    });

    public void Dispose()
    {
        ConnectionService.OnConnectionChanged -= HandleConnectionChanged;
        foreach (var timer in _purposeSavedTimers.Values)
        {
            timer.Stop();
            timer.Dispose();
        }
        _purposeSavedTimers.Clear();
    }

