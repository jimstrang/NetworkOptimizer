    /// <summary>
    /// Applies connection-specific defaults based on WAN name.
    /// Centralizes logic for Starlink and other connection types.
    /// Always updates calculated speeds after applying defaults.
    /// </summary>
    private void ApplyConnectionDefaults(WanConfigModel config, string wanName)
    {
        var name = wanName ?? "";
        if (name.Contains("Starlink", StringComparison.OrdinalIgnoreCase))
        {
            config.ConnectionType = ConnectionType.Starlink;
            config.NominalDownload = 400;
            config.NominalUpload = 40;
            config.SpeedtestServerId = "59762";
        }
        else if (name.Contains("LTE", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("5G", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("Cellular", StringComparison.OrdinalIgnoreCase))
        {
            config.ConnectionType = ConnectionType.CellularHome;
        }
        else if (name.Contains("XGS-PON", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("XGSPON", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("XG-PON", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("10G", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("10 Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("5 Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("3 Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("2 Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("2Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("3Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("5Gig", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("10Gig", StringComparison.OrdinalIgnoreCase))
        {
            config.ConnectionType = ConnectionType.XgsPon;
        }
        else if (name.Contains("Fiber", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("FTTH", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("FTTP", StringComparison.OrdinalIgnoreCase) ||
                 name.Contains("GPON", StringComparison.OrdinalIgnoreCase))
        {
            config.ConnectionType = ConnectionType.Gpon;
        }
        else if (name.Contains("DSL", StringComparison.OrdinalIgnoreCase))
        {
            config.ConnectionType = ConnectionType.Dsl;
        }

        // Always update calculated speeds after applying defaults
        UpdateCalculatedSpeeds(config);
    }

    private void OnEnabledChanged(WanConfigModel config, List<WanInterfaceInfo> availableInterfaces)
    {
        // When enabling, auto-select if only one interface available
        if (config.Enabled && string.IsNullOrEmpty(config.Interface) && availableInterfaces.Count == 1)
        {
            var wan = availableInterfaces[0];
            config.Interface = wan.Interface;
            config.WanLinkSpeedMbps = wan.LinkSpeedMbps;

            // Apply all defaults as if user selected it
            if (!string.IsNullOrEmpty(wan.SuggestedPingIp))
                config.PingHost = wan.SuggestedPingIp;

            if (string.IsNullOrEmpty(config.Name) || config.Name == "WAN1" || config.Name == "WAN2")
                config.Name = wan.Name;

            ApplyConnectionDefaults(config, wan.Name);
        }
    }

    private static string SanitizeWanName(string? input)
    {
        if (string.IsNullOrEmpty(input))
            return string.Empty;
        return new string(input.Where(c => char.IsLetterOrDigit(c) || c == ' ' || c == '(' || c == ')' || c == '-' || c == '_').ToArray());
    }

    private void OnInterfaceChanged(WanConfigModel config)
    {
        // Find the WAN info for the selected interface
        var wanInfo = wanInterfaces.FirstOrDefault(w =>
            w.Interface.Equals(config.Interface, StringComparison.OrdinalIgnoreCase));

        if (wanInfo == null)
            return;

        // Reset all interface-dependent fields to defaults for the new WAN
        config.WanLinkSpeedMbps = wanInfo.LinkSpeedMbps;
        config.LinkSpeedOverrideMbps = null;
        config.Name = wanInfo.Name;
        config.ConnectionType = ConnectionType.DocsisCable;
        config.NominalDownload = 300;
        config.NominalUpload = 35;
        config.SpeedtestServerId = null;
        config.PingHost = !string.IsNullOrEmpty(wanInfo.SuggestedPingIp)
            ? wanInfo.SuggestedPingIp
            : "1.1.1.1";

        // Apply connection-specific overrides (Starlink, etc.)
        ApplyConnectionDefaults(config, wanInfo.Name);
    }

