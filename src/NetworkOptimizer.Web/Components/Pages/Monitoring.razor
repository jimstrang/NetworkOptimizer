    // A "key device" is one whose loss of monitoring data is most impactful. For now
    // that's the gateway. "Not being polled" means SNMP is off on the device, or it
    // was dropped from polling after repeated failures.
    private List<SnmpDeviceStatus> GetUnpolledKeyDevices() =>
        _snmpDeviceStatuses
            .Where(d => d.DeviceType == DeviceType.Gateway
                && (d.PollState == SnmpPollState.SnmpDisabled || d.PollState == SnmpPollState.Excluded))
            .ToList();

    private static string KeyDeviceReason(SnmpDeviceStatus d) => d.PollState == SnmpPollState.SnmpDisabled
        ? "isn't being polled. Enable SNMP and set a Location or Contact on it in UniFi to collect its metrics."
        : $"stopped responding to SNMP and was dropped after {d.FailureCount} failures. Retrying automatically.";

    private void GoToSnmpDevices()
    {
        _pendingExpandSnmpCard = true;
        SetActiveTab("setup");
    }

