@* TODO: Continue extracting Monitoring cards into standalone Razor components.
   LatencyTargetsCard and SfpModulesCard are done. Remaining candidates:
   - Live View stat cards → MonitoringStatCards
   - Monitoring Status / Setup card → MonitoringSetupCard
   - Investigate card → MonitoringInvestigateCard
   - Chart containers (latency, device health, SFP) are mostly thin wrappers
     around JS mount points but could still benefit from encapsulation.
*@
@page "/monitoring"
@rendermode InteractiveServer
@implements IDisposable
@using NetworkOptimizer.Web.Services
@using NetworkOptimizer.Storage.Models
@using Microsoft.EntityFrameworkCore
@inject SnmpDetectionService SnmpDetection
@inject UniFiConnectionService ConnectionService
@inject MonitoringInfluxClient InfluxClient
@inject MonitoringLiveStats LiveStats
@inject Microsoft.EntityFrameworkCore.IDbContextFactory<NetworkOptimizer.Storage.Models.NetworkOptimizerDbContext> DbFactory
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@inject NavigationManager NavigationManager

<PageTitle>Monitoring - Network Optimizer</PageTitle>

<div class="page-header">
    <h1>Monitoring</h1>
    <p class="page-description">Real-time network monitoring with SNMP polling, latency tracking, and SFP diagnostics</p>
</div>

@if (!ConnectionService.IsConnected)
{
    <div class="connection-banner">
        <div class="banner-content">
            <span class="banner-icon">!</span>
            <div class="banner-text">
                @if (!string.IsNullOrEmpty(ConnectionService.LastError))
                {
                    <strong>Connection Error</strong>
                    <span>@ConnectionService.LastError</span>
                }
                else
                {
                    <strong>Not Connected</strong>
                    <span>Configure your UniFi Console connection in Settings to get started.</span>
                }
            </div>
            <a href="/settings" class="btn btn-primary btn-sm">Settings</a>
        </div>
    </div>
}
else
{
    <!-- Tab bar -->
    <div class="wifi-view-tabs-wrapper">
        <button class="wifi-tabs-scroll-btn wifi-tabs-scroll-left" onclick="this.parentElement.querySelector('.wifi-view-tabs').scrollBy({left: -200, behavior: 'smooth'})">&#8249;</button>
        <div class="wifi-view-tabs">
            <button class="wifi-view-tab @(_activeTab == "live" ? "active" : "")"
                    @onclick="@(() => SetActiveTab("live"))"
                    disabled="@(!_monitoringReady)">
                Live View
            </button>
            <button class="wifi-view-tab @(_activeTab == "performance" ? "active" : "")"
                    @onclick="@(() => SetActiveTab("performance"))"
                    disabled="@(!_monitoringReady)">
                Network Performance
            </button>
            <button class="wifi-view-tab @(_activeTab == "devices" ? "active" : "")"
                    @onclick="@(() => SetActiveTab("devices"))"
                    disabled="@(!_monitoringReady)">
                Device Stats
            </button>
            <button class="wifi-view-tab @(_activeTab == "sfp" ? "active" : "")"
                    @onclick="@(() => SetActiveTab("sfp"))"
                    disabled="@(!_monitoringReady)">
                SFP Stats
            </button>
            <button class="wifi-view-tab @(_activeTab == "setup" ? "active" : "")"
                    @onclick="@(() => SetActiveTab("setup"))">
                Setup
            </button>
        </div>
        <button class="wifi-tabs-scroll-btn wifi-tabs-scroll-right" onclick="this.parentElement.querySelector('.wifi-view-tabs').scrollBy({left: 200, behavior: 'smooth'})">&#8250;</button>
    </div>

    @* ──────────────── Tab: Live View ──────────────── *@
    @if (_activeTab == "live" && _monitoringReady)
    {
        <!-- Top stat cards: WAN rates, gateway RTT/loss, ISP/Transit mean RTT/loss -->
        <div class="monitoring-stat-cards">
            @{ var wanRates = GetWanRates(); }
            <div class="monitoring-stat-card">
                <div class="stat-value" style="color: #3b82f6;">@FormatRate(wanRates.download)</div>
                <div class="stat-label">WAN Download</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value" style="color: #10b981;">@FormatRate(wanRates.upload)</div>
                <div class="stat-label">WAN Upload</div>
            </div>
            @{ var gwLatency = GetGatewayLatency(); }
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatRtt(gwLatency.rtt)</div>
                <div class="stat-label">Gateway RTT</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value @(gwLatency.loss > 0 ? "stat-danger" : "")">@FormatLoss(gwLatency.loss)</div>
                <div class="stat-label">Gateway Loss</div>
            </div>
            @{ var ispTarget = GetMeanTargetStats(MonitoringTargetType.AccessIsp); }
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatRtt(ispTarget.rtt)</div>
                <div class="stat-label">ISP RTT</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value @(ispTarget.loss > 0 ? "stat-danger" : "")">@FormatLoss(ispTarget.loss)</div>
                <div class="stat-label">ISP Loss</div>
            </div>
            @{ var transitTarget = GetMeanTargetStats(MonitoringTargetType.Transit); }
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatRtt(transitTarget.rtt)</div>
                <div class="stat-label">Transit RTT</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value @(transitTarget.loss > 0 ? "stat-danger" : "")">@FormatLoss(transitTarget.loss)</div>
                <div class="stat-label">Transit Loss</div>
            </div>
        </div>

        <!-- 3D LAN flow map -->
        <div class="card lan-flow-map-card" style="margin-top: 1.5rem;">
            <div class="card-header">
                <h2 class="card-title">3D LAN Flow Map</h2>
            </div>
            <div class="card-body lan-flow-map-body">
                <div class="lan-flow-map-stage" id="lan-flow-map-stage">
                    <canvas id="lan-flow-map-canvas" class="lan-flow-map-canvas"></canvas>
                </div>
            </div>
        </div>

        <!-- Bottom stat cards: Gateway health + fabric load -->
        <div class="monitoring-stat-cards" style="margin-top: 1.5rem;">
            @{ var gwStats = GetGatewayStats(); }
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatPercent(gwStats?.CpuPercent)</div>
                <div class="stat-label">Gateway CPU</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatPercent(gwStats?.MemoryUsedPercent)</div>
                <div class="stat-label">Gateway Memory</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value">@FormatTemp(gwStats?.TemperatureC)</div>
                <div class="stat-label">Gateway Temp</div>
            </div>
            @{ var fabricLoad = GetTotalFabricLoad(); }
            <div class="monitoring-stat-card">
                <div class="stat-value" style="color: #3b82f6;">@FormatRate(fabricLoad.ingress)</div>
                <div class="stat-label">Fabric Ingress</div>
            </div>
            <div class="monitoring-stat-card">
                <div class="stat-value" style="color: #10b981;">@FormatRate(fabricLoad.egress)</div>
                <div class="stat-label">Fabric Egress</div>
            </div>
        </div>
    }

    @* ──────────────── Tab: Network Performance ──────────────── *@
    @if (_activeTab == "performance" && _monitoringReady)
    {
        <!-- Latency time-series charts -->
        <div class="card" id="latency-charts-container">
            <div class="card-header" style="flex-wrap: wrap; gap: 0.75rem;">
                <h2 class="card-title">Latency &amp; Packet Loss</h2>
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                    <div class="time-range-selector">
                        <button class="time-btn active" data-category="Fabric">LAN</button>
                        <button class="time-btn" data-category="AccessIsp">ISP</button>
                        <button class="time-btn" data-category="Transit">Transit</button>
                        <button class="time-btn" data-category="InternetService">Internet</button>
                    </div>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <button class="time-btn" data-shift="back" data-tooltip="Shift window back">&#x25C0;</button>
                    <div class="time-range-selector" style="position: relative;">
                        <button class="time-btn" data-range="0">15m</button>
                        <button class="time-btn active" data-range="1">1h</button>
                        <button class="time-btn" data-range="6">6h</button>
                        <button class="time-btn" data-range="24">24h</button>
                        <button class="time-btn" data-range="168">7d</button>
                        <button class="time-btn" data-range="720">30d</button>
                        <button class="time-btn custom-range-btn" data-action="custom-range" data-tooltip="Custom date range" data-tooltip-hover-only>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </button>
                        <div class="custom-range-popover" data-popover="custom-range">
                            <div class="custom-range-form">
                                <div class="custom-range-title">Custom Range</div>
                                <div class="custom-range-field">
                                    <label>From</label>
                                    <input type="datetime-local" data-input="from" class="custom-range-input" />
                                </div>
                                <div class="custom-range-field">
                                    <label>To</label>
                                    <input type="datetime-local" data-input="to" class="custom-range-input" />
                                </div>
                                <div class="custom-range-actions">
                                    <button class="btn btn-sm btn-secondary" data-action="cancel-custom">Cancel</button>
                                    <button class="btn btn-sm btn-primary" data-action="apply-custom">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button class="time-btn" data-shift="forward" data-tooltip="Shift window forward">&#x25B6;</button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="latency-filter-badges wan-filter-badges"></div>
                <div class="chart-card">
                    <div class="chart-header"><h3 class="chart-title">Round-trip time</h3></div>
                    <div class="latency-rtt-chart"></div>
                </div>
                <div class="chart-card" style="margin-top: 1rem;">
                    <div class="chart-header"><h3 class="chart-title">Packet loss</h3></div>
                    <div class="latency-loss-chart"></div>
                </div>
                <div class="chart-card latency-wan-rate-card" style="margin-top: 1rem; display: none;">
                    <div class="chart-header"><h3 class="chart-title">WAN Throughput</h3></div>
                    <div class="latency-wan-rate-chart"></div>
                </div>
                <div class="latency-stats-table"></div>
            </div>
        </div>

        <!-- Quick investigation -->
        <div class="card" style="margin-top: 1.5rem;">
            <div class="card-header">
                <h2 class="card-title">Investigate</h2>
            </div>
            <div class="card-body" style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
                @if (_lossNavActive)
                {
                    <button class="btn btn-sm btn-secondary" @onclick="LossNavBack" disabled="@_investigatingLoss"
                            data-tooltip="Previous loss event">&#x25C0;</button>
                    <button class="btn btn-primary" @onclick="LossNavDeactivate"
                            data-tooltip="Exit packet loss investigation">
                        Packet Loss Events
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="LossNavForward" disabled="@_investigatingLoss"
                            data-tooltip="Next loss event">&#x25B6;</button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="InvestigatePacketLoss" disabled="@_investigatingLoss"
                            data-tooltip="Find the most recent packet loss event across ISP, Transit, and Internet targets and jump to it on the chart">
                        @if (_investigatingLoss) { <span class="spinner-sm"></span> }
                        else { <span>Packet Loss Events</span> }
                    </button>
                }
                @if (!string.IsNullOrEmpty(_lossInvestigateResult))
                {
                    <span class="page-description" style="align-self: center;">@_lossInvestigateResult</span>
                }
            </div>
        </div>

        <!-- Upstream tracer wizard -->
        <div style="margin-top: 1.5rem;">
            <UpstreamTracerPanel />
        </div>

        <div style="margin-top: 1.5rem;">
            <LatencyTargetsCard Targets="_targets" OnTargetsChanged="OnTargetsChanged" />
        </div>
    }

    @* ──────────────── Tab: Device Stats ──────────────── *@
    @if (_activeTab == "devices" && _monitoringReady)
    {
        <div class="card" id="device-health-charts-container">
            <div class="card-header" style="flex-wrap: wrap; gap: 0.75rem;">
                <h2 class="card-title">Device Health</h2>
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                    <button class="time-btn" data-shift="back" data-tooltip="Shift window back">&#x25C0;</button>
                    <div class="time-range-selector" style="position: relative;">
                        <button class="time-btn" data-range="0">15m</button>
                        <button class="time-btn active" data-range="1">1h</button>
                        <button class="time-btn" data-range="6">6h</button>
                        <button class="time-btn" data-range="24">24h</button>
                        <button class="time-btn" data-range="168">7d</button>
                        <button class="time-btn" data-range="720">30d</button>
                        <button class="time-btn custom-range-btn" data-action="custom-range" data-tooltip="Custom date range" data-tooltip-hover-only>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </button>
                        <div class="custom-range-popover" data-popover="custom-range">
                            <div class="custom-range-form">
                                <div class="custom-range-title">Custom Range</div>
                                <div class="custom-range-field">
                                    <label>From</label>
                                    <input type="datetime-local" data-input="from" class="custom-range-input" />
                                </div>
                                <div class="custom-range-field">
                                    <label>To</label>
                                    <input type="datetime-local" data-input="to" class="custom-range-input" />
                                </div>
                                <div class="custom-range-actions">
                                    <button class="btn btn-sm btn-secondary" data-action="cancel-custom">Cancel</button>
                                    <button class="btn btn-sm btn-primary" data-action="apply-custom">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button class="time-btn" data-shift="forward" data-tooltip="Shift window forward">&#x25B6;</button>
                </div>
            </div>
            <div class="card-body">
                <div class="health-filter-badges wan-filter-badges"></div>
                <div class="chart-card">
                    <div class="chart-header"><h3 class="chart-title">Temperature</h3></div>
                    <div class="health-temp-chart"></div>
                </div>
                <div class="chart-card" style="margin-top: 1rem;">
                    <div class="chart-header"><h3 class="chart-title">CPU</h3></div>
                    <div class="health-cpu-chart"></div>
                </div>
                <div class="chart-card" style="margin-top: 1rem;">
                    <div class="chart-header"><h3 class="chart-title">Memory</h3></div>
                    <div class="health-mem-chart"></div>
                </div>
            </div>
        </div>
    }

    @* ──────────────── Tab: SFP Stats ──────────────── *@
    @if (_activeTab == "sfp" && _monitoringReady)
    {
        <SfpModulesCard AllSfps="_allSfps" Targets="_targets" DeviceIpByMac="_deviceIpByMac" OnSfpChanged="OnSfpChanged" />

        @if (_monitoredSfps.Count > 0)
        {
        <!-- SFP DDM time-series: RX/TX power + temperature -->
        <div class="card" style="margin-top: 1.5rem;" id="sfp-charts-container">
            <div class="card-header" style="flex-wrap: wrap; gap: 0.75rem;">
                <h2 class="card-title">SFP Diagnostics</h2>
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                    <button class="time-btn" data-shift="back" data-tooltip="Shift window back">&#x25C0;</button>
                    <div class="time-range-selector" style="position: relative;">
                        <button class="time-btn" data-range="0">15m</button>
                        <button class="time-btn" data-range="1">1h</button>
                        <button class="time-btn" data-range="6">6h</button>
                        <button class="time-btn active" data-range="24">24h</button>
                        <button class="time-btn" data-range="168">7d</button>
                        <button class="time-btn" data-range="720">30d</button>
                        <button class="time-btn custom-range-btn" data-action="custom-range" data-tooltip="Custom date range" data-tooltip-hover-only>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </button>
                        <div class="custom-range-popover" data-popover="custom-range">
                            <div class="custom-range-form">
                                <div class="custom-range-title">Custom Range</div>
                                <div class="custom-range-field">
                                    <label>From</label>
                                    <input type="datetime-local" data-input="from" class="custom-range-input" />
                                </div>
                                <div class="custom-range-field">
                                    <label>To</label>
                                    <input type="datetime-local" data-input="to" class="custom-range-input" />
                                </div>
                                <div class="custom-range-actions">
                                    <button class="btn btn-sm btn-secondary" data-action="cancel-custom">Cancel</button>
                                    <button class="btn btn-sm btn-primary" data-action="apply-custom">Apply</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button class="time-btn" data-shift="forward" data-tooltip="Shift window forward">&#x25B6;</button>
                </div>
            </div>
            <div class="card-body">
                <div class="sfp-filter-badges wan-filter-badges"></div>
                <div class="chart-card">
                    <div class="chart-header"><h3 class="chart-title">RX / TX Power</h3></div>
                    <div class="sfp-power-chart"></div>
                </div>
                <div class="chart-card" style="margin-top: 1rem;">
                    <div class="chart-header"><h3 class="chart-title">Temperature</h3></div>
                    <div class="sfp-temp-chart"></div>
                </div>
            </div>
        </div>
        }

        <!-- SFP investigation -->
        <div class="card" style="margin-top: 1.5rem;">
            <div class="card-header">
                <h2 class="card-title">Investigate</h2>
            </div>
            <div class="card-body" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                <button class="btn btn-secondary" @onclick="InvestigateSfpAnomaly" disabled="@_investigatingSfp"
                        data-tooltip="Find the most recent SFP temperature or signal anomaly and jump to it on the chart">
                    @if (_investigatingSfp) { <span class="spinner-sm"></span> }
                    else { <span>SFP Anomalies</span> }
                </button>
                @if (!string.IsNullOrEmpty(_sfpInvestigateResult))
                {
                    <span class="page-description" style="align-self: center;">@_sfpInvestigateResult</span>
                }
            </div>
        </div>
    }

    @* ──────────────── Tab: Setup ──────────────── *@
    @if (_activeTab == "setup")
    {
        @if (_snmpState == SnmpDetectionState.NotChecked)
        {
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">SNMP Configuration</h2>
                </div>
                <div class="card-body">
                    <div class="empty-state">
                        <span class="spinner"></span>
                        <p>Detecting SNMP configuration from UniFi Console...</p>
                    </div>
                </div>
            </div>
        }
        else if (_snmpState == SnmpDetectionState.Disabled)
        {
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">SNMP Setup Required</h2>
                    <span class="status-badge status-disconnected">Disabled</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>SNMP is not enabled on your UniFi Console.</strong>
                        Network Optimizer needs SNMP to collect port-level traffic statistics, device health metrics, and interface data from your switches and gateway.
                    </div>

                    <details class="setup-guide" open>
                        <summary>How to Enable SNMP</summary>
                        <div class="setup-guide-content">
                            <ol>
                                <li>Open UniFi Network</li>
                                <li>Search Settings for <strong>"SNMP Monitoring"</strong></li>
                                <li>Enable <strong>SNMP v1/v2c</strong> and set a unique community string</li>
                            </ol>
                            <p>Currently at: Settings → CyberSecure → Traffic Logging → SNMP Monitoring. This menu has moved between UniFi versions - the search term is the reliable way to find it.</p>

                            <h4>Recommended configuration</h4>
                            <p><strong>SNMP v1/v2c</strong> with a unique community string is recommended over v3. SNMPv3's per-packet authentication and encryption adds measurable CPU load to your gateway and fabric devices. The recommended security posture is a <strong>management VLAN</strong> isolating your network devices, not per-packet crypto.</p>
                        </div>
                    </details>

                    <div class="action-buttons" style="margin-top: 1rem;">
                        <button class="btn btn-primary" @onclick="RunDetection" disabled="@_detecting">
                            @if (_detecting) { <span class="spinner-sm"></span> <span>Checking...</span> }
                            else { <span>Re-check</span> }
                        </button>
                    </div>
                </div>
            </div>
        }
        else if (_snmpState == SnmpDetectionState.PollFailing)
        {
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Monitoring Status</h2>
                    <span class="status-badge status-error">SNMP Error</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>SNMP polling is failing.</strong>
                        @(_detectionError ?? "Check that SNMP is still enabled on your UniFi Console and that firewall rules permit UDP/161 from this server to your network devices.")
                    </div>
                    <div class="action-buttons" style="margin-top: 1rem;">
                        <button class="btn btn-primary" @onclick="RunDetection" disabled="@_detecting">
                            @if (_detecting) { <span class="spinner-sm"></span> <span>Re-checking...</span> }
                            else { <span>Re-check SNMP</span> }
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @if (_showV3Recommendation && _snmpState == SnmpDetectionState.EnabledV3Only)
            {
                <div class="alert alert-info" style="margin-bottom: 1.5rem;">
                    <strong>SNMPv3 detected.</strong>
                    Consider switching to v1/v2c - the per-packet crypto adds CPU load to your network devices. The recommended security posture is a management VLAN, not v3 encryption.
                    <button class="btn btn-sm btn-secondary" style="margin-left: 0.5rem;" @onclick="() => _showV3Recommendation = false">Dismiss</button>
                </div>
            }

            @if (!_influxConfigured || _showInfluxWizard)
            {
                <InfluxSetupWizard TitlePrefix="Set up " OnProvisioned="OnInfluxProvisioned" OnDismissed="() => { _showInfluxWizard = false; StateHasChanged(); }" />
            }

            <div class="card" style="@(!_influxConfigured ? "margin-top: 1.5rem;" : "")">
                <div class="card-header">
                    <h2 class="card-title">Monitoring Status</h2>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span class="status-badge status-connected">@OverallStateBadge()</span>
                        <a href="/settings#monitoring" class="tooltip-icon settings-link" data-tooltip="Monitoring settings">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M7.84 1.804A1 1 0 018.82 1h2.36a1 1 0 01.98.804l.331 1.652a6.993 6.993 0 011.929 1.115l1.598-.54a1 1 0 011.186.447l1.18 2.044a1 1 0 01-.205 1.251l-1.267 1.113a7.047 7.047 0 010 2.228l1.267 1.113a1 1 0 01.206 1.25l-1.18 2.045a1 1 0 01-1.187.447l-1.598-.54a6.993 6.993 0 01-1.929 1.115l-.33 1.652a1 1 0 01-.98.804H8.82a1 1 0 01-.98-.804l-.331-1.652a6.993 6.993 0 01-1.929-1.115l-1.598.54a1 1 0 01-1.186-.447l-1.18-2.044a1 1 0 01.205-1.251l1.267-1.114a7.05 7.05 0 010-2.227L1.821 7.773a1 1 0 01-.206-1.25l1.18-2.045a1 1 0 011.187-.447l1.598.54A6.993 6.993 0 017.51 3.456l.33-1.652zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label">SNMP</label>
                        <div class="form-value">
                            <span class="status-indicator status-active"></span>
                            @(_snmpState == SnmpDetectionState.EnabledV2c ? "v2c" : _snmpState == SnmpDetectionState.EnabledV3Only ? "v3" : "Active")
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">InfluxDB</label>
                        <div class="form-value">
                            @if (_influxReachable == true)
                            {
                                <span class="status-indicator status-active"></span>
                                <span>Connected</span>
                            }
                            else if (_influxReachable == false)
                            {
                                <span class="status-indicator status-danger"></span>
                                <span>@ShortInfluxStatus()</span>
                            }
                            else if (!_influxConfigured)
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Not configured - follow the setup card above.</span>
                            }
                            else
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Not checked</span>
                            }
                            @if (_influxConfigured)
                            {
                                <button class="btn btn-sm btn-secondary" style="margin-left: 0.75rem;" @onclick="CheckInfluxHealth" disabled="@_checkingInflux">
                                    @if (_checkingInflux)
                                    {
                                        <span class="spinner-sm"></span>
                                        <span>Checking...</span>
                                    }
                                    else
                                    {
                                        <span>Test</span>
                                    }
                                </button>
                                @if (_influxReachable == false)
                                {
                                    <a href="/settings#monitoring" class="btn btn-sm btn-secondary" style="margin-left: 0.5rem;">
                                        Update Token
                                    </a>
                                    <button class="btn btn-sm btn-primary" style="margin-left: 0.25rem;" @onclick="ResetInfluxSetup">
                                        Re-run Setup
                                    </button>
                                }
                                @if (_lastInfluxTestAt.HasValue && !_checkingInflux)
                                {
                                    <span class="page-description" style="margin-left: 0.5rem;">
                                        @if (_influxReachable == true)
                                        {
                                            <span style="color: var(--success-color);">&#x2713; Connected</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--danger-color);">&#x2717; @(_influxError ?? "Unreachable")</span>
                                        }
                                    </span>
                                }
                            }
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Collection</label>
                        <div class="form-value">
                            @if (_monitoringEnabled && _influxReachable == true)
                            {
                                <span class="status-indicator status-active"></span>
                                <span>Agent running</span>
                            }
                            else if (_monitoringEnabled && _influxReachable != true)
                            {
                                <span class="status-indicator status-danger"></span>
                                <span>Enabled, but InfluxDB unreachable</span>
                            }
                            else
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Disabled</span>
                            }
                        </div>
                    </div>

                    <div class="action-buttons" style="margin-top: 1rem;">
                        @if (_monitoringEnabled)
                        {
                            <button class="btn btn-secondary" @onclick="() => SetMonitoringEnabled(false)" disabled="@_togglingEnable">
                                @if (_togglingEnable) { <span class="spinner-sm"></span> <span>Stopping...</span> }
                                else { <span>Disable Monitoring</span> }
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="() => SetMonitoringEnabled(true)" disabled="@(_togglingEnable || _influxReachable != true)">
                                @if (_togglingEnable) { <span class="spinner-sm"></span> <span>Starting...</span> }
                                else { <span>Enable Monitoring</span> }
                            </button>
                            @if (_influxReachable != true)
                            {
                                <span class="page-description" style="margin-left: 0.75rem;">
                                    Complete InfluxDB setup above to enable.
                                </span>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
}

