    @* ──────────────── Tab: Setup ──────────────── *@
    @if (_activeTab == "setup")
    {
        @if (_snmpState == SnmpDetectionState.NotChecked)
        {
            <div class="card">
                <div class="card-header monitoring-chart-header">
                    <h2 class="card-title">SNMP Configuration</h2>
                </div>
                <div class="card-body">
                    <div class="empty-state">
                        <span class="spinner"></span>
                        <p>Detecting SNMP configuration from UniFi Console...</p>
                    </div>
                </div>
            </div>
        }
        else if (_snmpState == SnmpDetectionState.Disabled)
        {
            <div class="card">
                <div class="card-header monitoring-chart-header">
                    <h2 class="card-title">SNMP Setup Required</h2>
                    <span class="status-badge status-disconnected">Disabled</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <strong>SNMP is not enabled on your UniFi Console.</strong>
                        Network Optimizer needs SNMP to collect port-level traffic statistics, device health metrics, and interface data from your switches and gateway.
                    </div>

                    <details class="setup-guide" open>
                        <summary>How to Enable SNMP</summary>
                        <div class="setup-guide-content">
                            <ol>
                                <li>Open UniFi Network</li>
                                <li>Search Settings for <strong>"SNMP Monitoring"</strong></li>
                                <li>Enable <strong>SNMP v1/v2c</strong> and set a unique community string</li>
                            </ol>
                            <p>Currently at: Settings → CyberSecure → Traffic Logging → SNMP Monitoring. This menu has moved between UniFi versions - the search term is the reliable way to find it.</p>

                            <h4>Per-device SNMP</h4>
                            <p>After enabling SNMP globally, you also need to enable it on each device you want to monitor:</p>
                            <ol>
                                <li>In UniFi Network, go to <strong>UniFi Devices</strong></li>
                                <li>Select a device</li>
                                <li>Open <strong>Settings</strong>, tick <strong>SNMP</strong> on</li>
                                <li>Set a <strong>Location</strong> or <strong>Contact</strong> value, then <strong>Save</strong></li>
                            </ol>
                            <p>Devices without SNMP enabled will not report port-level traffic or health metrics.</p>

                            <h4>Recommended configuration</h4>
                            <p><strong>SNMP v1/v2c</strong> with a unique community string is recommended over v3. SNMPv3's per-packet authentication and encryption adds measurable CPU load to your gateway and fabric devices. The recommended security posture is a <strong>management VLAN</strong> isolating your network devices, not per-packet crypto.</p>
                        </div>
                    </details>

                    <div class="action-buttons" style="margin-top: 1rem;">
                        <button class="btn btn-primary" @onclick="RunDetection" disabled="@_detecting">
                            @if (_detecting) { <span class="spinner-sm"></span> <span>Checking...</span> }
                            else { <span>Re-check</span> }
                        </button>
                    </div>
                </div>
            </div>
        }
        else if (_snmpState == SnmpDetectionState.PollFailing)
        {
            <div class="card">
                <div class="card-header monitoring-chart-header">
                    <h2 class="card-title">Monitoring Status</h2>
                    <span class="status-badge status-error">SNMP Error</span>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>SNMP polling is failing.</strong>
                        @(_detectionError ?? "Check that SNMP is still enabled on your UniFi Console and that firewall rules permit UDP/161 from this server to your network devices.")
                    </div>
                    <div class="action-buttons" style="margin-top: 1rem;">
                        <button class="btn btn-primary" @onclick="RunDetection" disabled="@_detecting">
                            @if (_detecting) { <span class="spinner-sm"></span> <span>Re-checking...</span> }
                            else { <span>Re-check SNMP</span> }
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @if (_showV3Recommendation && _snmpState == SnmpDetectionState.EnabledV3Only)
            {
                <div class="alert alert-info" style="margin-bottom: 1.5rem;">
                    <strong>SNMPv3 detected.</strong>
                    Consider switching to v1/v2c - the per-packet crypto adds CPU load to your network devices. The recommended security posture is a management VLAN, not v3 encryption.
                    <button class="btn btn-sm btn-secondary" style="margin-left: 0.5rem;" @onclick="() => _showV3Recommendation = false">Dismiss</button>
                </div>
            }

            @if (!_influxConfigured || _showInfluxWizard)
            {
                <InfluxSetupWizard TitlePrefix="Set up " OnProvisioned="OnInfluxProvisioned" OnDismissed="() => { _showInfluxWizard = false; StateHasChanged(); }" />
            }

            <div class="card" style="@(!_influxConfigured ? "margin-top: 1.5rem;" : "")">
                <div class="card-header monitoring-chart-header">
                    <h2 class="card-title">Monitoring Status</h2>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span class="status-badge status-connected">@OverallStateBadge()</span>
                        <a href="/settings#monitoring" class="tooltip-icon settings-link" data-tooltip="Monitoring settings">
                            <img src="/images/gear.svg" alt="" style="width:16px;height:16px;" />
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label">SNMP</label>
                        <div class="form-value">
                            <span class="status-indicator status-active"></span>
                            @(_snmpState == SnmpDetectionState.EnabledV2c ? "v2c" : _snmpState == SnmpDetectionState.EnabledV3Only ? "v3" : "Active")
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">InfluxDB</label>
                        <div class="form-value">
                            @if (_influxReachable == true)
                            {
                                <span class="status-indicator status-active"></span>
                                <span>Connected</span>
                            }
                            else if (_influxReachable == false)
                            {
                                <span class="status-indicator status-danger"></span>
                                <span>@ShortInfluxStatus()</span>
                            }
                            else if (!_influxConfigured)
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Not configured - follow the setup card above.</span>
                            }
                            else
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Not checked</span>
                            }
                            @if (_influxConfigured)
                            {
                                <button class="btn btn-sm btn-secondary" style="margin-left: 0.75rem;" @onclick="CheckInfluxHealth" disabled="@_checkingInflux">
                                    @if (_checkingInflux)
                                    {
                                        <span class="spinner-sm"></span>
                                        <span>Checking...</span>
                                    }
                                    else
                                    {
                                        <span>Test</span>
                                    }
                                </button>
                                @if (_influxReachable == false)
                                {
                                    <a href="/settings#monitoring" class="btn btn-sm btn-secondary" style="margin-left: 0.5rem;">
                                        Update Token
                                    </a>
                                    <button class="btn btn-sm btn-primary" style="margin-left: 0.25rem;" @onclick="ResetInfluxSetup">
                                        Re-run Setup
                                    </button>
                                }
                                @if (_lastInfluxTestAt.HasValue && !_checkingInflux)
                                {
                                    <span class="page-description" style="margin-left: 0.5rem;">
                                        @if (_influxReachable == true)
                                        {
                                            <span style="color: var(--success-color);">&#x2713; Connected</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--danger-color);">&#x2717; @(_influxError ?? "Unreachable")</span>
                                        }
                                    </span>
                                }
                            }
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Collection</label>
                        <div class="form-value">
                            @if (_monitoringEnabled && _influxReachable == true)
                            {
                                <span class="status-indicator status-active"></span>
                                <span>Agent running</span>
                            }
                            else if (_monitoringEnabled && _influxReachable != true)
                            {
                                <span class="status-indicator status-danger"></span>
                                <span>Enabled, but InfluxDB unreachable</span>
                            }
                            else
                            {
                                <span class="status-indicator status-inactive"></span>
                                <span>Disabled</span>
                            }
                        </div>
                    </div>

                    <div class="action-buttons" style="margin-top: 1rem;">
                        @if (_monitoringEnabled)
                        {
                            <button class="btn btn-secondary" @onclick="() => SetMonitoringEnabled(false)" disabled="@_togglingEnable">
                                @if (_togglingEnable) { <span class="spinner-sm"></span> <span>Stopping...</span> }
                                else { <span>Disable Monitoring</span> }
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="() => SetMonitoringEnabled(true)" disabled="@(_togglingEnable || _influxReachable != true)">
                                @if (_togglingEnable) { <span class="spinner-sm"></span> <span>Starting...</span> }
                                else { <span>Enable Monitoring</span> }
                            </button>
                            @if (_influxReachable != true)
                            {
                                <span class="page-description" style="margin-left: 0.75rem;">
                                    Complete InfluxDB setup above to enable.
                                </span>
                            }
                        }
                    </div>

                    <div id="snmp-devices" style="margin-top: 1.25rem;">
                        <SnmpDeviceStatusCard @ref="_snmpDeviceCard" Devices="_snmpDeviceStatuses" />
                    </div>

                    <details class="setup-guide" style="margin-top: 1.25rem;">
                        <summary>Not seeing data for some devices?</summary>
                        <div class="setup-guide-content">
                            <p>SNMP must be enabled on each device individually in addition to the global Console setting:</p>
                            <ol>
                                <li>In UniFi Network, go to <strong>UniFi Devices</strong></li>
                                <li>Select a device</li>
                                <li>Open <strong>Settings</strong>, tick <strong>SNMP</strong> on</li>
                                <li>Set a <strong>Location</strong> or <strong>Contact</strong> value, then <strong>Save</strong></li>
                            </ol>
                            <p>Devices without per-device SNMP enabled will not report port-level traffic or health metrics.</p>
                        </div>
                    </details>

                    <div style="margin-top: 1.25rem;">
                        <MonitoringInterfacesCard @ref="_miCard" PrefillTargetIp="@MiTargetParam" PrefillSourceType="@MiTypeParam" />
                    </div>
                </div>
            </div>
        }
    }
}

<style>
    .stat-hint-icon {
        width: 22px;
        height: 22px;
        font-size: 13px;
        cursor: pointer;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabParam { get; set; }

    [SupplyParameterFromQuery(Name = "discover")]
    public string? DiscoverParam { get; set; }

    [SupplyParameterFromQuery(Name = "investigate")]
    public string? InvestigateParam { get; set; }

    [SupplyParameterFromQuery(Name = "sfp")]
    public string? SfpParam { get; set; }

    [SupplyParameterFromQuery(Name = "device")]
    public string? DeviceParam { get; set; }

    [SupplyParameterFromQuery(Name = "category")]
    public string? CategoryParam { get; set; }

    [SupplyParameterFromQuery(Name = "target")]
    public string? TargetParam { get; set; }

    [SupplyParameterFromQuery(Name = "modem")]
    public string? ModemParam { get; set; }

    [SupplyParameterFromQuery(Name = "cm")]
    public string? CmParam { get; set; }

    [SupplyParameterFromQuery(Name = "ont")]
    public string? OntParam { get; set; }

    [SupplyParameterFromQuery(Name = "starlink")]
    public string? StarlinkParam { get; set; }

    [SupplyParameterFromQuery(Name = "expand")]
    public string? ExpandParam { get; set; }

    [SupplyParameterFromQuery(Name = "mifip")]
    public string? MiTargetParam { get; set; }

    [SupplyParameterFromQuery(Name = "mitype")]
    public string? MiTypeParam { get; set; }

    private string? _lastTabParam;
    private string? _soloCellularModemId;
    private string? _soloCmId;
    private string? _soloOntId;
    private string? _soloStarlinkId;

    private bool _upstreamDiscoveryPendingSave =>
        UpstreamTracer.State.Step == NetworkOptimizer.Web.Services.Monitoring.TracerStep.ReviewingResults;

    private SnmpDetectionState _snmpState = SnmpDetectionState.NotChecked;
    private bool _detecting;
    private bool _showV3Recommendation = true;
    private string? _detectionError;

    private bool? _influxReachable;
    private string? _influxError;
    private bool _influxConfigured;
    private bool _checkingInflux;
    private DateTime? _lastInfluxTestAt;
    private System.Threading.Timer? _testFeedbackTimer;
    private bool _monitoringEnabled;
    private bool _togglingEnable;
    private bool _showInfluxWizard;
    private List<MonitoringTarget> _targets = new();
    private List<WanContext> _wanContexts = new();
    private List<MonitoredSfp> _monitoredSfps = new();
    private List<MonitoredSfp> _allSfps = new();
    private Dictionary<string, string> _deviceIpByMac = new();
    private string? _gatewayMac;
    private List<string> _gatewayWanIfNames = new();
    private System.Threading.Timer? _liveRefreshTimer;
    private System.Threading.Timer? _dataRefreshTimer;
    private DotNetObjectReference<Monitoring>? _mapDotNetRef;
    private DateTime? _mapHistoricAt;
    private HistoricStatSnapshot? _historicSnapshot;

    private string _activeTab = "setup";

    private bool _monitoringReady => _monitoringEnabled && _influxConfigured;
    private bool _cmHasDevices;
    private bool _ontHasDevices;
    private bool _cellularHasDevices;
    private bool _starlinkHasDevices;
    // Per-site Monitoring tab visibility (from MonitoringSettings; default shown).
    private bool _showCmTab = true;
