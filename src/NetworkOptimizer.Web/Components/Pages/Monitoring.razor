            await ConnectionService.ReconnectAsync();
        }
        finally
        {
            _refreshingConnection = false;
        }
    }

    private async void OnConnectionChanged()
    {
        // Fires from a background thread (console reconnect); the reload is already
        // marshalled onto the dispatcher, but wrap it so this async void handler can't
        // crash the circuit if detection throws.
        try
        {
            if (ConnectionService.IsConnected)
            {
                await InvokeAsync(async () =>
                {
                    await RunDetection();
                    StateHasChanged();
                });
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* component may be disposed */ }
    }

    private async Task RunDetection()
    {
        _detecting = true;
        _detectionError = null;
        StateHasChanged();

        var result = await SnmpDetection.DetectSnmpSettingsAsync();
        if (result.Success)
        {
            await SnmpDetection.SaveDetectionResultAsync(result);
            var settings = await SnmpDetection.GetOrCreateSettingsAsync();
            _snmpState = settings.SnmpDetectionState;
        }
        else
        {
            _detectionError = result.ErrorMessage;
            _snmpState = SnmpDetectionState.PollFailing;
        }

        _detecting = false;
        StateHasChanged();
    }

    private string ShortInfluxStatus()
    {
        if (string.IsNullOrEmpty(_influxError)) return "Unreachable";
        if (_influxError.Contains("unauthorized", StringComparison.OrdinalIgnoreCase)) return "Auth error";
        if (_influxError.Contains("refused", StringComparison.OrdinalIgnoreCase)) return "Connection refused";
        if (_influxError.Contains("timeout", StringComparison.OrdinalIgnoreCase)) return "Timeout";
        if (_influxError.Contains("bucket", StringComparison.OrdinalIgnoreCase)
            && _influxError.Contains("not found", StringComparison.OrdinalIgnoreCase)) return "Bucket not found";
        if (_influxError.Contains("organization", StringComparison.OrdinalIgnoreCase)
            && _influxError.Contains("not found", StringComparison.OrdinalIgnoreCase)) return "Org not found";
        return "Unreachable";
    }

    private string OverallStateBadge()
    {
        if (_snmpState != SnmpDetectionState.EnabledV2c
            && _snmpState != SnmpDetectionState.EnabledV3Only
            && _snmpState != SnmpDetectionState.Working)
        {
            return _snmpState.ToString();
        }
        if (!_influxConfigured) return "InfluxDB not configured";
        if (_influxReachable == false) return "InfluxDB unreachable";
        if (!_monitoringEnabled) return "Ready (disabled)";
        return "Monitoring active";
    }

