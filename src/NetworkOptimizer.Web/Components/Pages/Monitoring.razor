    {
        var settings = await SnmpDetection.GetOrCreateSettingsAsync();
        await RefreshInfluxStateAsync(settings);
        StateHasChanged();
    }

    /// <summary>
    /// Populates the Setup tab's InfluxDB status. The default site reads its own row
    /// directly. A secondary site inherits the shared server/org/token from main and
    /// only differs in bucket names, so "configured" means main has a shared connection
    /// to derive from, and reachability is this site's own client hitting its own
    /// (slug-prefixed) buckets - never main's stored status, which would otherwise show
    /// a misleading "Connected" before this site's buckets exist.
    /// </summary>
    private async Task RefreshInfluxStateAsync(MonitoringSettings settings)
    {
        if (SiteCtx.IsDefault)
        {
            LoadInfluxStateFromSettings(settings);
            return;
        }

        _monitoringEnabled = settings.Enabled;

        bool sharedConnection;
        await using (var mainDb = SiteDb.CreateForSite(SiteManagementService.DefaultSiteSlug, isDefault: true))
        {
            var shared = await mainDb.MonitoringSettings.AsNoTracking().FirstOrDefaultAsync();
            sharedConnection = !string.IsNullOrEmpty(shared?.InfluxDbToken)
                && !string.IsNullOrEmpty(shared?.InfluxDbUrl);
        }

        // A secondary site counts as configured only once its own buckets are reachable
        // on the shared InfluxDB. Until then report not-configured so the Setup tab drops
        // straight into the wizard - which creates this site's buckets (silently when the
        // shared token is already org-scoped, otherwise prompting for one all-access token)
        // - rather than showing a misleading "Unreachable" with a Re-run Setup button.
        if (sharedConnection)
        {
            var health = await InfluxClient.CheckHealthAsync();
            _influxConfigured = health.Reachable;
            _influxReachable = health.Reachable ? true : null;
            _influxError = null;
        }
        else
        {
            _influxConfigured = false;
            _influxReachable = null;
            _influxError = null;
        }
    }

