    private void TransformChartData()
    {
        var serverKeys = _results
            .Where(r => r.Success)
            .Select(r => r.ExternalServerName ?? "unknown")
            .Distinct()
            .OrderBy(k => k)
            .ToList();

        var previousSelection = _chartSeries.ToDictionary(s => s.Key, s => s.IsSelected);

        _chartSeries = serverKeys.Select((key, i) => new ServerSeriesInfo
        {
            Key = key,
            DisplayName = ResolveServerName(key),
            Color = SeriesColors[i % SeriesColors.Length],
            IsSelected = previousSelection.TryGetValue(key, out var selected) && selected
        }).ToList();

        if (_chartSeries.Count == 0 && _results.Any(r => r.Success))
        {
            _chartSeries.Add(new ServerSeriesInfo
            {
                Key = "unknown",
                DisplayName = "Server",
                Color = SeriesColors[0]
            });
        }

        UpdateSpeedChartColors();
        UpdateMsChartColors(_latencyChartOptions);
        UpdateMsChartColors(_jitterChartOptions);
    }

    private void UpdateSpeedChartColors()
    {
        var colors = new List<string>();
        var dashArray = new List<int>();
        var fillTypes = new List<FillType>();
        foreach (var s in _chartSeries)
        {
            colors.Add(s.Color); colors.Add(s.Color);
            dashArray.Add(0); dashArray.Add(5);
            fillTypes.Add(FillType.Gradient); fillTypes.Add(FillType.Gradient);
        }
        _speedChartOptions.Colors = colors;
        if (_speedChartOptions.Stroke != null)
            _speedChartOptions.Stroke.DashArray = dashArray;
        _speedChartOptions.Fill = new Fill
        {
            Type = fillTypes,
            Gradient = new FillGradient { ShadeIntensity = 0.3, OpacityFrom = 0.4, OpacityTo = 0.05 }
        };
    }

    private void UpdateMsChartColors(ApexChartOptions<ChartPoint> opts)
    {
        var colors = _chartSeries.Select(s => s.Color).ToList();
        opts.Colors = colors;
        if (opts.Stroke != null)
            opts.Stroke.DashArray = colors.Select(_ => 0).ToList();
    }

    private List<Iperf3Result> GetTimeFilteredResults()
    {
        var idx = Math.Clamp(_sliderValue, 0, TimeBreakpoints.Length - 1);
        var hours = TimeBreakpoints[idx].hours;
        if (hours <= 0) return _results;
        var cutoff = DateTime.UtcNow.AddHours(-hours);
        return _results.Where(r => r.TestTime >= cutoff).ToList();
    }

    private void ApplyChartFilters()
    {
        IEnumerable<Iperf3Result> filtered = GetTimeFilteredResults();
        if (!string.IsNullOrEmpty(_deviceFilter))
            filtered = filtered.Where(r => string.Equals(r.DeviceHost, _deviceFilter, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(_serverFilter))
            filtered = filtered.Where(r => string.Equals(r.ExternalServerName, _serverFilter, StringComparison.OrdinalIgnoreCase));
        var timeFiltered = filtered.ToList();

        var idx = Math.Clamp(_sliderValue, 0, TimeBreakpoints.Length - 1);
        var shouldDownsample = TimeBreakpoints[idx].hours is 0 or > 4;

        foreach (var series in _chartSeries)
        {
            var results = timeFiltered
                .Where(r => r.Success && string.Equals(r.ExternalServerName ?? "unknown", series.Key, StringComparison.OrdinalIgnoreCase))
                .OrderBy(r => r.TestTime)
                .ToList();

            var downloadRaw = results.Select(r => new ChartPoint(r.TestTime, r.DownloadMbps, r.Id)).ToList();
            var uploadRaw = results.Select(r => new ChartPoint(r.TestTime, r.UploadMbps, r.Id)).ToList();

            if (shouldDownsample)
            {
                series.DownloadData = DownsampleLttb(CollapseClusters(downloadRaw), MaxChartPoints);
                var keptIds = series.DownloadData.Select(d => d.ResultId).ToHashSet();
                series.UploadData = uploadRaw.Where(u => keptIds.Contains(u.ResultId)).ToList();
            }
            else
            {
                series.DownloadData = downloadRaw;
                series.UploadData = uploadRaw;
            }

            var latencyRaw = results
                .Where(r => r.PingMs.HasValue)
                .Select(r => new ChartPoint(r.TestTime, r.PingMs!.Value, r.Id))
                .ToList();
            series.LatencyData = shouldDownsample ? DownsampleLttb(CollapseClusters(latencyRaw), MaxChartPoints) : latencyRaw;

            var jitterRaw = results
                .Where(r => r.JitterMs.HasValue)
                .Select(r => new ChartPoint(r.TestTime, r.JitterMs!.Value, r.Id))
                .ToList();
            series.JitterData = shouldDownsample ? DownsampleLttb(CollapseClusters(jitterRaw), MaxChartPoints) : jitterRaw;
        }
    }

    private static List<ChartPoint> CollapseClusters(List<ChartPoint> data)
    {
        if (data.Count <= 3) return data;
        var range = (double)(data.Max(d => d.Value) - data.Min(d => d.Value));
        if (range < 1) return data;
        var valueThreshold = range * 0.15;
        var timeThreshold = TimeSpan.FromHours(2);

        var result = new List<ChartPoint> { data[0] };
        for (int i = 1; i < data.Count - 1; i++)
        {
            var lastKept = result[^1];
            var curr = data[i];
            if (curr.Timestamp - lastKept.Timestamp >= timeThreshold ||
                Math.Abs((double)curr.Value - (double)lastKept.Value) > valueThreshold)
                result.Add(curr);
        }
        result.Add(data[^1]);
        return result;
    }

    private static List<ChartPoint> DownsampleLttb(List<ChartPoint> data, int targetCount)
    {
        if (data.Count <= targetCount || targetCount < 3) return data;

        var result = new List<ChartPoint>(targetCount) { data[0] };
        double bucketSize = (double)(data.Count - 2) / (targetCount - 2);
        int prevIdx = 0;

        for (int bucket = 0; bucket < targetCount - 2; bucket++)
        {
            int currStart = (int)Math.Floor(bucket * bucketSize) + 1;
            int currEnd = (int)Math.Floor((bucket + 1) * bucketSize) + 1;
            currEnd = Math.Min(currEnd, data.Count - 1);

            double avgX, avgY;
            if (bucket == targetCount - 3)
            {
                avgX = data[^1].X; avgY = (double)data[^1].Value;
            }
            else
            {
                int nextStart = currEnd;
                int nextEnd = Math.Min((int)Math.Floor((bucket + 2) * bucketSize) + 1, data.Count - 1);
                avgX = 0; avgY = 0; int count = 0;
                for (int j = nextStart; j < nextEnd; j++) { avgX += data[j].X; avgY += (double)data[j].Value; count++; }
                if (count > 0) { avgX /= count; avgY /= count; }
                else { avgX = data[nextStart].X; avgY = (double)data[nextStart].Value; }
            }

            double maxArea = -1; int bestIdx = currStart;
            double prevX = data[prevIdx].X, prevY = (double)data[prevIdx].Value;
            for (int j = currStart; j < currEnd; j++)
            {
                double area = Math.Abs((prevX - avgX) * ((double)data[j].Value - prevY) - (prevX - data[j].X) * (avgY - prevY));
                if (area > maxArea) { maxArea = area; bestIdx = j; }
            }
            result.Add(data[bestIdx]);
            prevIdx = bestIdx;
        }

        result.Add(data[^1]);
        return result;
    }

    private string GetTimeLabel() => TimeBreakpoints[_sliderValue].label;

    private async Task OnSliderChanged()
    {
        _page = 1;
        _expandedId = 0;
        ApplyChartFilters();
        await RenderActiveChart();
    }

    private async Task SwitchTab(string tab)
    {
        if (_activeTab == tab) return;
        _activeTab = tab;
        StateHasChanged();
        await Task.Delay(50);
        await RenderActiveChart();
    }

    private async Task RenderActiveChart()
    {
        StateHasChanged();
        try
        {
            var chart = _activeTab switch
            {
                "latency" => _latencyChart,
                "jitter" => _jitterChart,
                _ => _speedChart
            };
            if (chart != null) await chart.RenderAsync();
        }
        catch { }
    }

    private async Task OnChartClicked(SelectedData<ChartPoint> data)
    {
        if (data?.DataPoint?.Items?.FirstOrDefault() is ChartPoint point)
            await ScrollToResult(point.ResultId);
    }

    private async Task ScrollToResult(int resultId)
    {
        var index = _filteredResults.FindIndex(r => r.Id == resultId);
        if (index >= 0)
            _page = (index / PageSize) + 1;

        _expandedId = resultId;
        StateHasChanged();

        await Task.Delay(100);
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var el = document.getElementById('result-{resultId}');
                if (el) {{
                    el.scrollIntoView({{ behavior: 'smooth', block: 'center' }});
                    el.style.transition = 'background-color 0.3s';
                    el.style.backgroundColor = 'rgba(59, 130, 246, 0.3)';
                    setTimeout(function() {{ el.style.backgroundColor = ''; }}, 1500);
                }}
            }})();
        ");
    }

