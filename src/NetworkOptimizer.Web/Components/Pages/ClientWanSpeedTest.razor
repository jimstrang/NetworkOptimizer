        public List<ChartPoint> UploadData { get; set; } = new();
        public List<ChartPoint> LatencyData { get; set; } = new();
        public List<ChartPoint> JitterData { get; set; } = new();
        public bool IsSelected { get; set; }
    }

    private bool _noneSelected => !_chartSeries.Any(s => s.IsSelected);
    private bool _allSelected => _chartSeries.All(s => s.IsSelected);
    private bool _showAll => _noneSelected || _allSelected;
    private bool IsSeriesVisible(ServerSeriesInfo series) => _showAll || series.IsSelected;

    private List<Iperf3Result> _filteredResults
    {
        get
        {
            IEnumerable<Iperf3Result> q = GetTimeFilteredResults();
            if (!string.IsNullOrEmpty(_deviceFilter))
                q = q.Where(r => string.Equals(r.DeviceHost, _deviceFilter, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(_serverFilter))
                q = q.Where(r => string.Equals(r.ExternalServerName, _serverFilter, StringComparison.OrdinalIgnoreCase));
            return q.ToList();
        }
    }

    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_filteredResults.Count / (double)PageSize));
    private IEnumerable<Iperf3Result> _pagedResults => _filteredResults.Skip((_page - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        PtrState.RefreshCallback = () => LoadResults();
        PtrState.NotifyStateChanged = StateHasChanged;

        InitializeChartOptions();

        _servers = await SettingsService.GetExternalSpeedTestServersAsync();
        _selectedServer = _servers.FirstOrDefault(s => s.IsDefault) ?? _servers.FirstOrDefault();
        _selectedServerId = _selectedServer?.Id ?? 0;
        _siteTarget = await SiteTarget.ResolveAsync();

        if (_selectedServer != null)
            await LoadResults();

        _pollTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    if (await LoadResults())
                        await RenderActiveChart();
                    else
                        StateHasChanged();
                });
            }
            catch { }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void OnServerChanged()
    {
        _selectedServer = _servers.FirstOrDefault(s => s.Id == _selectedServerId);
    }

    private string ResolveServerName(string? serverId)
    {
        if (string.IsNullOrEmpty(serverId)) return "-";
        var server = _servers.FirstOrDefault(s => string.Equals(s.ServerId, serverId, StringComparison.OrdinalIgnoreCase));
        return server?.Name ?? serverId;
    }

    private async Task<bool> LoadResults()
    {
        _loading = true;
        try
        {
            _results = await ClientSpeedTestService.GetWanResultsAsync(200);
            var signature = (_results.Count, _results.Count == 0 ? 0 : _results.Max(r => r.Id));
            var changed = signature != _resultsSignature;
            _resultsSignature = signature;
            TransformChartData();
            ApplyChartFilters();
            return changed;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshHistory()
    {
        await LoadResults();
        await RenderActiveChart();
    }

    private void ToggleExpand(int id)
    {
        _expandedId = _expandedId == id ? 0 : id;
    }

    private void ChangePage(int delta)
    {
        _page = Math.Clamp(_page + delta, 1, _totalPages);
    }

