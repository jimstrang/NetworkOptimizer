        border: none;
        cursor: pointer;
        padding: 0.25rem;
        font-size: 1rem;
        opacity: 0.7;
        transition: opacity 0.15s;
    }

    .btn-icon:hover {
        opacity: 1;
    }

    .copy-check {
        color: var(--success-color);
    }

    .speed-value {
        font-weight: 600;
        font-size: 1rem;
    }

    .speed-unit {
        color: var(--text-muted);
        font-size: 0.75rem;
        margin-left: 0.25rem;
    }

    .badge-wan {
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
    }

    .history-card-header {
        flex-direction: column;
        align-items: stretch;
        gap: 0.75rem;
    }

    .header-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .device-filter-btn {
        color: var(--text-muted);
        margin-left: 4px;
        vertical-align: middle;
        opacity: 0;
        transition: opacity 0.15s, color 0.15s;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        line-height: 1;
    }

    .device-filter-btn.active {
        opacity: 1;
        color: var(--primary-color);
    }

    .history-row-clickable:hover .device-filter-btn {
        opacity: 1;
    }

    .device-filter-btn:hover {
        color: var(--primary-color);
    }

    .device-filter-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.5rem;
        background: rgba(5, 89, 201, 0.15);
        border: 1px solid rgba(5, 89, 201, 0.3);
        border-radius: 999px;
        font-size: 0.8125rem;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    .device-filter-pill svg {
        flex-shrink: 0;
        color: var(--primary-color);
    }

    .device-filter-clear {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 1.125rem;
        line-height: 1;
        cursor: pointer;
        padding: 0 0.125rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .device-filter-clear:hover {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.1);
    }

    .filter-area-empty {
        min-height: 0.5rem;
        padding-bottom: 0;
    }
</style>

@code {
    private List<ExternalSpeedTestServer> _servers = new();

    // On an agent-backed site the test starts at the on-site agent's /wan/ router,
    // whose interstitial forwards to the external server: the agent becomes the
    // page's referrer, so results post back through it with the real client LAN IP
    // and the site slug stamped on the trusted agent->server hop - no ?site= in
    // any user-facing URL. Direct/default sites link the external server directly.
    private SiteSpeedTestTargetResolver.Result? _siteTarget;

    // Site attribution for WAN results comes ONLY from the agent relay, so a
    // non-default site with no live agent target must not offer a test link at
    // all - the bare external URL would silently record against the default site.
    // A not-yet-resolved target (null) counts as offline for the same reason.
    private bool AgentRequiredButOffline =>
        !SiteContext.IsDefault && _siteTarget is null or { UsesAgent: false };

    private string ExternalBaseUrl
    {
        get
        {
            if (_siteTarget is { UsesAgent: true, BaseUrl: not null } target)
            {
                var isDefaultServer = _selectedServer == null || _selectedServer.IsDefault;
                return isDefaultServer
                    ? $"{target.BaseUrl}/wan/"
                    : $"{target.BaseUrl}/wan/{_selectedServer!.ServerId}/";
            }
            return _selectedServer?.Url ?? "";
        }
    }

