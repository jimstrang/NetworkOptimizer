    private async Task HandleDeleteResult(int resultId)
    {
        var deleted = await SpeedTestService.DeleteResultAsync(resultId);
        if (deleted)
        {
            testHistory.RemoveAll(r => r.Id == resultId);
            historyPathAnalysis.Remove(resultId);
            if (currentResult?.Id == resultId)
            {
                currentResult = testHistory.FirstOrDefault();
            }
            expandedHistoryId = null;
            StateHasChanged();
        }
    }

