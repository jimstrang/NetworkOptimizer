@code {
    private bool IsLicenseRestricted => !LicenseState.IsSiteOperational(SiteContext.Slug);

    // Resolve the current site's path analyzer (not the main-pinned singleton) so historical
    // and fallback path re-computes trace against this site's topology.
    private INetworkPathAnalyzer PathAnalyzer => SpeedTestRegistry.GetFor(SiteContext.Slug).PathAnalyzer;

    // Local iperf3 availability
    private LocalIperf3Status? localIperf3Status;
    private bool recheckingIperf3 = false;

    // Agent-backed secondary site whose on-site agent isn't currently connected.
    // LAN tests run through that agent (SSH to devices + throughput at the site),
