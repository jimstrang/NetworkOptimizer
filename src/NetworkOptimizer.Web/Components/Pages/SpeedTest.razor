        savedDeviceMessage = "";
        StateHasChanged();
    }

    private void ToggleAddDevice()
    {
        if (showAddDevice && editingDevice.Id == 0)
        {
            // Already in add mode, cancel it
            CancelEdit();
        }
        else
        {
            // Switch to add mode (reset any editing state)
            editingDevice = new DeviceSshConfiguration
            {
                DeviceType = DeviceType.Server,
                Enabled = true,
                StartIperf3Server = false
            };
            editingDevicePassword = "";
            editingDeviceHasSavedPassword = false; // New device has no saved password
            showAdvancedIperf3 = false;
            savedDeviceMessage = "";
            showAddDevice = true;
            StateHasChanged();
        }
    }

    private void CancelEdit()
    {
        editingDevice = new DeviceSshConfiguration
        {
            DeviceType = DeviceType.Server,
            Enabled = true,
            StartIperf3Server = false
        };
        editingDevicePassword = "";
        editingDeviceHasSavedPassword = false;
        showAdvancedIperf3 = false;
        showAddDevice = false;
        savedDeviceMessage = "";
        StateHasChanged();
