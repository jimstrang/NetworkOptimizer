    protected override async Task OnInitializedAsync()
    {
        PtrState.RefreshCallback = () => LoadHistory();
        PtrState.NotifyStateChanged = StateHasChanged;

        // Check schedule banner dismissal and local iperf3 availability
        _lanScheduleBannerDismissed = await SettingsService.GetAsync("banner.lan_schedule_dismissed") != null;
        localIperf3Status = await SettingsService.CheckLocalIperf3Async();

        // Wait for UniFi controller connection (auto-connect happens in background on startup)
        await ConnectionService.WaitForConnectionAsync();

        await CheckSshConfiguration();
        await LoadGatewayConfiguration();
        await LoadDevices();
        await LoadHistory();
        await LoadDiscoveredDevices();
        await LoadApMarkers();

        await RefreshAgentAvailabilityAsync();
        StartAgentStatusPolling();
    }

    /// <summary>
    /// Recomputes whether this site's on-site agent is offline. LAN tests run
    /// through the agent for an agent-backed secondary site, so an offline agent
    /// locks them out; <see cref="StartAgentStatusPolling"/> re-enables them when
    /// it reconnects. The default site never routes via agent.
    /// </summary>
    private async Task RefreshAgentAvailabilityAsync()
    {
        // A managed site with no live agent can't run LAN tests, full stop: a site
        // that is via-agent configured but momentarily disconnected gets the
        // "resumes when it reconnects" message, a site with no agent set up at all
        // gets pointed at agent setup instead of a runnable-but-wrong test.
        var agentOnline = TunnelRouting.IsAgentOnline(SiteContext.Slug);
        _agentRequired = !SiteContext.IsDefault && !agentOnline;
        _siteAgentOffline = _agentRequired && await TunnelRouting.IsViaAgentAsync(SiteContext.Slug);
    }

    /// <summary>
    /// Polls the site's agent tunnel status so LAN tests re-enable on their own
    /// once the agent reconnects. Only agent-backed secondary sites can go offline,
    /// so the default site skips the timer entirely.
    /// </summary>
    private void StartAgentStatusPolling()
    {
        if (SiteContext.IsDefault) return;
        _agentStatusTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    var before = (_siteAgentOffline, _agentRequired);
                    await RefreshAgentAvailabilityAsync();
                    var changed = before != (_siteAgentOffline, _agentRequired);

                    // The console comes back a moment after the agent tunnel does; once
                    // it's connected, load the UniFi device list so it populates without
                    // a manual Refresh.
                    if (!_discoveredDevicesLoaded && ConnectionService.IsConnected)
                    {
                        await LoadDiscoveredDevices();
                        changed = true;
                    }

                    if (changed)
                        StateHasChanged();
                });
            }
            catch { /* keep the timer alive */ }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

