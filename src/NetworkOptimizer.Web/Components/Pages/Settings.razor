    private async Task LoadThreatSettings()
    {
        try
        {
            var enabled = await SystemSettings.GetAsync("threats.enabled");
            threatCollectionEnabled = enabled != "false";

            var interval = await SystemSettings.GetAsync("threats.poll_interval_minutes");
            if (int.TryParse(interval, out var i)) threatPollInterval = i;

            var retention = await SystemSettings.GetAsync("threats.retention_days");
            if (int.TryParse(retention, out var r)) threatRetentionDays = r;

            // Build geo database status from service properties
            if (GeoService.IsCityAvailable && GeoService.IsAsnAvailable)
                threatGeoStatus = "City and ASN databases loaded";
            else if (GeoService.IsCityAvailable)
                threatGeoStatus = "City database loaded (ASN database missing)";
            else if (GeoService.IsAsnAvailable)
                threatGeoStatus = "ASN database loaded (City database missing)";
            else
                threatGeoStatus = "Not found - add a MaxMind license key below to auto-download";

            var mmAcct = await SystemSettings.GetAsync("maxmind.account_id");
            hasMaxmindAccountId = !string.IsNullOrEmpty(mmAcct);

            var mmKey = await SystemSettings.GetAsync("maxmind.license_key");
            hasMaxmindLicenseKey = !string.IsNullOrEmpty(mmKey);

            var csEnabled = await SystemSettings.GetAsync("crowdsec.enabled");
            crowdsecEnabled = csEnabled == "true";
            var csKey = await SystemSettings.GetAsync("crowdsec.api_key");
            hasCrowdsecApiKey = !string.IsNullOrEmpty(csKey);

            var csQuota = await SystemSettings.GetAsync("crowdsec.daily_quota");
            if (!string.IsNullOrEmpty(csQuota) && int.TryParse(csQuota, out var quota) && quota >= 1)
                crowdsecDailyQuota = quota;

            var rateLimitState = CrowdSecClient.GetRateLimitState();
            crowdsecUsageDisplay = $"{rateLimitState.RequestsToday}/{rateLimitState.DailyLimit}";
        }
        catch (Exception ex)
        {
            threatSettingsMessage = $"Error loading threat settings: {ex.Message}";
            threatSettingsMessageClass = "danger";
        }
    }

    private async Task SaveThreatSettings()
    {
        savingThreatSettings = true;
        threatSettingsMessage = "";
        StateHasChanged();

        try
        {
            await SystemSettings.SetAsync("threats.enabled", threatCollectionEnabled ? "true" : "false");
            await SystemSettings.SetAsync("threats.poll_interval_minutes", threatPollInterval.ToString());
            await SystemSettings.SetAsync("threats.retention_days", threatRetentionDays.ToString());

            if (!string.IsNullOrEmpty(maxmindAccountId))
            {
                var encAcct = CredentialService.Encrypt(maxmindAccountId);
                await SystemSettings.SetAsync("maxmind.account_id", encAcct);
                hasMaxmindAccountId = true;
                maxmindAccountId = "";
            }

            if (!string.IsNullOrEmpty(maxmindLicenseKey))
            {
                var encrypted = CredentialService.Encrypt(maxmindLicenseKey);
                await SystemSettings.SetAsync("maxmind.license_key", encrypted);
                hasMaxmindLicenseKey = true;
                maxmindLicenseKey = "";
            }

            threatSettingsMessage = "Threat intelligence settings saved.";
            threatSettingsMessageClass = "success";
        }
        catch (Exception ex)
        {
            threatSettingsMessage = $"Error saving settings: {ex.Message}";
            threatSettingsMessageClass = "danger";
        }
        finally
        {
            savingThreatSettings = false;
        }
    }

    private async Task DownloadMaxMindDatabases()
    {
        downloadingMaxmind = true;
        maxmindMessage = "";
        StateHasChanged();

        try
        {
            // Use entered values or load saved credentials
            var accountId = maxmindAccountId;
            if (string.IsNullOrEmpty(accountId))
            {
                var encAcct = await SystemSettings.GetAsync("maxmind.account_id");
                if (!string.IsNullOrEmpty(encAcct))
                    accountId = CredentialService.IsEncrypted(encAcct) ? CredentialService.Decrypt(encAcct) : encAcct;
            }

            var licenseKey = maxmindLicenseKey;
            if (string.IsNullOrEmpty(licenseKey))
            {
                var encrypted = await SystemSettings.GetAsync("maxmind.license_key");
                if (!string.IsNullOrEmpty(encrypted))
                    licenseKey = CredentialService.IsEncrypted(encrypted) ? CredentialService.Decrypt(encrypted) : encrypted;
            }

            if (string.IsNullOrEmpty(accountId) || string.IsNullOrEmpty(licenseKey))
            {
                maxmindMessage = "Please enter both MaxMind Account ID and License Key.";
                maxmindMessageClass = "warning";
                return;
            }

            // Save credentials if just entered
            if (!string.IsNullOrEmpty(maxmindAccountId))
            {
                var encAcct = CredentialService.Encrypt(maxmindAccountId);
                await SystemSettings.SetAsync("maxmind.account_id", encAcct);
                hasMaxmindAccountId = true;
                maxmindAccountId = "";
            }

            if (!string.IsNullOrEmpty(maxmindLicenseKey))
            {
                var encKey = CredentialService.Encrypt(maxmindLicenseKey);
                await SystemSettings.SetAsync("maxmind.license_key", encKey);
                hasMaxmindLicenseKey = true;
                maxmindLicenseKey = "";
            }

            var dataPath = GetGeoDataPath();
            using var httpClient = HttpClientFactory.CreateClient();
            httpClient.Timeout = TimeSpan.FromMinutes(5);

            var (success, message) = await GeoService.DownloadDatabasesAsync(accountId, licenseKey, dataPath, httpClient);
            maxmindMessage = message;
            maxmindMessageClass = success ? "success" : "danger";

            if (success)
            {
                await SystemSettings.SetAsync("maxmind.last_download", DateTime.UtcNow.ToString("O"));
                await LoadThreatSettings(); // Refresh geo status display
            }
        }
        catch (Exception ex)
        {
            maxmindMessage = $"Download failed: {ex.Message}";
            maxmindMessageClass = "danger";
        }
        finally
        {
            downloadingMaxmind = false;
        }
    }

    private static string GetGeoDataPath()
    {
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
            return "/app/data";
        if (OperatingSystem.IsWindows())
            return Path.Combine(AppContext.BaseDirectory, "data");
        return Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "NetworkOptimizer");
    }

    private async Task SaveCrowdSecSettings()
    {
        savingCrowdsecSettings = true;
        crowdsecMessage = "";
        StateHasChanged();

        try
        {
            await SystemSettings.SetAsync("crowdsec.enabled", crowdsecEnabled ? "true" : "false");

            var newKeyProvided = !string.IsNullOrEmpty(crowdsecApiKey);
            if (newKeyProvided)
            {
                var encrypted = CredentialService.Encrypt(crowdsecApiKey);
                await SystemSettings.SetAsync("crowdsec.api_key", encrypted);
                hasCrowdsecApiKey = true;
                crowdsecApiKey = "";
            }

            await SystemSettings.SetAsync("crowdsec.daily_quota", crowdsecDailyQuota.ToString());

            // Update the rate limiter. Reset counter when a new API key is saved
            // since the new key has its own fresh quota on CrowdSec's side.
            var requestsToday = newKeyProvided ? 0 : CrowdSecClient.GetRateLimitState().RequestsToday;
            CrowdSecClient.LoadRateLimitState(requestsToday, DateOnly.FromDateTime(DateTime.UtcNow), crowdsecDailyQuota);
            crowdsecUsageDisplay = $"{requestsToday}/{crowdsecDailyQuota}";

            crowdsecMessage = "CrowdSec settings saved.";
            crowdsecMessageClass = "success";
        }
        catch (Exception ex)
        {
            crowdsecMessage = $"Error saving settings: {ex.Message}";
            crowdsecMessageClass = "danger";
        }
        finally
        {
            savingCrowdsecSettings = false;
        }
    }

    private async Task TestCrowdSec()
    {
        testingCrowdsec = true;
        crowdsecMessage = "";
        StateHasChanged();

        try
        {
            var stored = await SystemSettings.GetAsync("crowdsec.api_key");
            if (string.IsNullOrEmpty(stored))
            {
                crowdsecMessage = "No CTI API key configured.";
                crowdsecMessageClass = "warning";
                return;
            }

            var apiKey = CredentialService.IsEncrypted(stored) ? CredentialService.Decrypt(stored) : stored;
            var result = await CrowdSecClient.TestApiKeyAsync(apiKey);
            if (result.Success)
            {
                crowdsecMessage = result.Message;
                crowdsecMessageClass = "success";
            }
            else
            {
                crowdsecMessage = result.Message;
                crowdsecMessageClass = "danger";
            }
        }
        catch (Exception ex)
        {
            crowdsecMessage = $"Test failed: {ex.Message}";
            crowdsecMessageClass = "danger";
        }
        finally
        {
            testingCrowdsec = false;
        }
    }

