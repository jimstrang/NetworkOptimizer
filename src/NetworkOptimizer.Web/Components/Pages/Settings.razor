    /// <summary>
    /// Parse a stored UTC digest schedule string into the local-time form fields.
    /// </summary>
    private void ParseDigestScheduleToLocal(string schedule)
    {
        var parts = schedule.Split(':');
        if (parts[0] == "weekly" && parts.Length >= 4 &&
            int.TryParse(parts[2], out var wh) && int.TryParse(parts[3], out var wm))
        {
            channelDigestFrequency = "weekly";
            channelDigestDay = parts[1].ToLowerInvariant();
            var utcDt = DateTime.UtcNow.Date.AddHours(wh).AddMinutes(wm);
            var localDt = utcDt.ToLocalTime();
            channelDigestTime = new TimeOnly(localDt.Hour, localDt.Minute);
        }
        else if (parts.Length >= 3 && int.TryParse(parts[1], out var dh) && int.TryParse(parts[2], out var dm))
        {
            channelDigestFrequency = "daily";
            var utcDt = DateTime.UtcNow.Date.AddHours(dh).AddMinutes(dm);
            var localDt = utcDt.ToLocalTime();
            channelDigestTime = new TimeOnly(localDt.Hour, localDt.Minute);
        }
        else
        {
            channelDigestFrequency = "daily";
            channelDigestTime = new TimeOnly(8, 0);
        }
    }

    /// <summary>
    /// Build a UTC digest schedule string from the local-time form fields.
    /// </summary>
    private string BuildDigestScheduleUtc()
    {
        var localDt = DateTime.Today.Add(channelDigestTime.ToTimeSpan());
        var utcDt = localDt.ToUniversalTime();
        var hh = utcDt.Hour.ToString("D2");
        var mm = utcDt.Minute.ToString("D2");

        return channelDigestFrequency == "weekly"
            ? $"weekly:{channelDigestDay}:{hh}:{mm}"
            : $"daily:{hh}:{mm}";
    }

    private static string GetServerTimezoneAbbrev()
    {
        var tz = TimeZoneInfo.Local;
        var now = DateTime.Now;
        var name = tz.IsDaylightSavingTime(now) ? tz.DaylightName : tz.StandardName;
        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return words.Length > 1 ? string.Concat(words.Select(w => w[0])) : name;
    }

    private async Task SaveAlertChannel()
    {
        savingAlertChannel = true;
        alertChannelMessage = "";
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(channelFormName))
            {
                alertChannelMessage = "Channel name is required.";
                alertChannelMessageClass = "warning";
                return;
            }

            var channelType = Enum.Parse<DeliveryChannelType>(channelFormType);

            // Validate required fields by channel type
            if (channelType == DeliveryChannelType.Email)
            {
                if (string.IsNullOrWhiteSpace(channelSmtpHost))
                {
                    alertChannelMessage = "SMTP host is required.";
                    alertChannelMessageClass = "warning";
                    return;
                }
                if (string.IsNullOrWhiteSpace(channelSmtpFrom))
                {
                    alertChannelMessage = "From address is required.";
                    alertChannelMessageClass = "warning";
                    return;
                }
                if (string.IsNullOrWhiteSpace(channelSmtpTo))
                {
                    alertChannelMessage = "At least one recipient address is required.";
                    alertChannelMessageClass = "warning";
                    return;
                }
                // Username set but no password: check if we have a stored password (edit) or if it's truly missing (new)
                if (!string.IsNullOrEmpty(channelSmtpUser) && string.IsNullOrEmpty(channelSmtpPass))
                {
                    var hasStoredPassword = false;
                    if (editingChannelId.HasValue)
                    {
                        var existingCh = await AlertRepository.GetChannelAsync(editingChannelId.Value);
                        if (existingCh != null)
                        {
                            var existingCfg = System.Text.Json.JsonSerializer.Deserialize<NetworkOptimizer.Alerts.Delivery.EmailChannelConfig>(existingCh.ConfigJson);
                            hasStoredPassword = existingCfg != null && !string.IsNullOrEmpty(existingCfg.Password);
                        }
                    }
                    if (!hasStoredPassword)
                    {
                        alertChannelMessage = "SMTP username is set but password is empty. Set a password or clear the username for unauthenticated relay.";
                        alertChannelMessageClass = "warning";
                        return;
                    }
                }
            }
            else if (channelType == DeliveryChannelType.Ntfy)
            {
                if (string.IsNullOrWhiteSpace(channelNtfyTopic))
                {
                    alertChannelMessage = "Topic is required.";
                    alertChannelMessageClass = "warning";
                    return;
                }
            }
            else
            {
                // Webhook, Slack, Discord, Teams all require a URL
                if (string.IsNullOrWhiteSpace(channelWebhookUrl))
                {
                    alertChannelMessage = "Webhook URL is required.";
                    alertChannelMessageClass = "warning";
                    return;
                }
            }

            var severity = Enum.Parse<NetworkOptimizer.Core.Enums.AlertSeverity>(channelMinSeverity);

            // Build digest schedule string from local time fields (convert to UTC for storage)
            if (channelDigestEnabled)
                channelDigestSchedule = BuildDigestScheduleUtc();

            if (editingChannelId.HasValue)
            {
                var existing = await AlertRepository.GetChannelAsync(editingChannelId.Value);
                if (existing != null)
                {
                    // Pass existing config so we can preserve encrypted secrets when fields are left blank
                    var configJson = BuildChannelConfigJson(channelType, existing.ConfigJson);
                    existing.Name = channelFormName;
                    existing.ChannelType = channelType;
                    existing.ConfigJson = configJson;
                    existing.MinSeverity = severity;
                    existing.IsEnabled = channelEnabled;
                    existing.DigestEnabled = channelDigestEnabled;
                    existing.DigestSchedule = channelDigestEnabled ? channelDigestSchedule : null;
                    await AlertRepository.UpdateChannelAsync(existing);
                }
            }
            else
            {
                var configJson = BuildChannelConfigJson(channelType);
                var channel = new DeliveryChannel
                {
                    Name = channelFormName,
                    ChannelType = channelType,
                    ConfigJson = configJson,
                    MinSeverity = severity,
                    IsEnabled = channelEnabled,
                    DigestEnabled = channelDigestEnabled,
                    DigestSchedule = channelDigestEnabled ? channelDigestSchedule : null
                };
                await AlertRepository.SaveChannelAsync(channel);
            }

            await LoadAlertChannels();
            showChannelForm = false;
            editingChannelId = null;
            alertChannelMessage = "Channel saved successfully.";
            alertChannelMessageClass = "success";
        }
        catch (Exception ex)
        {
            alertChannelMessage = $"Error saving channel: {ex.Message}";
            alertChannelMessageClass = "danger";
        }
        finally
        {
            savingAlertChannel = false;
            StateHasChanged();
        }
    }

    private string BuildChannelConfigJson(DeliveryChannelType type, string? existingConfigJson = null)
    {
        if (type == DeliveryChannelType.Email)
        {
            // When editing and password field is left blank, preserve the existing encrypted password
            var password = !string.IsNullOrEmpty(channelSmtpPass)
                ? SecretDecryptor.Encrypt(channelSmtpPass)
                : GetExistingSecret<NetworkOptimizer.Alerts.Delivery.EmailChannelConfig>(existingConfigJson, c => c.Password);

            var cfg = new NetworkOptimizer.Alerts.Delivery.EmailChannelConfig
            {
                SmtpHost = channelSmtpHost,
                SmtpPort = channelSmtpPort,
                UseSsl = channelSmtpSsl,
                UseStartTls = channelSmtpStartTls,
                Username = channelSmtpUser,
                Password = password,
                FromAddress = channelSmtpFrom,
                ToAddresses = channelSmtpTo
            };
            return System.Text.Json.JsonSerializer.Serialize(cfg);
        }

        if (type == DeliveryChannelType.Webhook)
        {
            string? secret = clearWebhookSecret
                ? null
                : !string.IsNullOrEmpty(channelWebhookSecret)
                    ? SecretDecryptor.Encrypt(channelWebhookSecret)
                    : GetExistingSecret<NetworkOptimizer.Alerts.Delivery.WebhookChannelConfig>(existingConfigJson, c => c.Secret);

            // Normalize empty string to null for webhook secrets (optional field)
            if (string.IsNullOrEmpty(secret)) secret = null;

            var cfg = new NetworkOptimizer.Alerts.Delivery.WebhookChannelConfig
            {
                Url = channelWebhookUrl,
                Secret = secret
            };
            return System.Text.Json.JsonSerializer.Serialize(cfg);
        }

        if (type == DeliveryChannelType.Ntfy)
        {
            string? token = clearNtfyToken
                ? null
                : !string.IsNullOrEmpty(channelNtfyAccessToken)
                    ? SecretDecryptor.Encrypt(channelNtfyAccessToken)
                    : GetExistingSecret<NetworkOptimizer.Alerts.Delivery.NtfyChannelConfig>(existingConfigJson, c => c.AccessToken);
            if (string.IsNullOrEmpty(token)) token = null;

            string? password = clearNtfyPassword
                ? null
                : !string.IsNullOrEmpty(channelNtfyPassword)
                    ? SecretDecryptor.Encrypt(channelNtfyPassword)
                    : GetExistingSecret<NetworkOptimizer.Alerts.Delivery.NtfyChannelConfig>(existingConfigJson, c => c.Password);
            if (string.IsNullOrEmpty(password)) password = null;

            var cfg = new NetworkOptimizer.Alerts.Delivery.NtfyChannelConfig
            {
                ServerUrl = channelNtfyServerUrl,
                Topic = channelNtfyTopic,
                AccessToken = token,
                Username = string.IsNullOrWhiteSpace(channelNtfyUsername) ? null : channelNtfyUsername,
                Password = password
            };
            return System.Text.Json.JsonSerializer.Serialize(cfg);
        }

        // Slack, Discord, Teams all use webhook URL
        return System.Text.Json.JsonSerializer.Serialize(new { WebhookUrl = channelWebhookUrl });
    }

    /// <summary>
    /// Extract an existing encrypted secret from a stored config JSON, so we can preserve it
    /// when the user edits other fields without re-entering the secret.
    /// </summary>
    private static string GetExistingSecret<T>(string? existingConfigJson, Func<T, string?> secretSelector) where T : class
    {
        if (string.IsNullOrEmpty(existingConfigJson)) return "";
        try
        {
            var existing = System.Text.Json.JsonSerializer.Deserialize<T>(existingConfigJson);
            return existing != null ? secretSelector(existing) ?? "" : "";
        }
        catch { return ""; }
    }

    private async Task TestAlertChannel(int channelId)
    {
        testingAlertChannel = true;
        testingAlertChannelId = channelId;
        alertChannelMessage = "";
        StateHasChanged();

        try
        {
            var channel = await AlertRepository.GetChannelAsync(channelId);
            if (channel == null)
            {
                alertChannelMessage = "Channel not found.";
                alertChannelMessageClass = "danger";
                return;
            }

            var handler = DeliveryChannels.FirstOrDefault(d => d.ChannelType == channel.ChannelType);
            if (handler == null)
            {
                alertChannelMessage = $"No handler for {channel.ChannelType}.";
                alertChannelMessageClass = "danger";
                return;
            }

            var (success, error) = await handler.TestAsync(channel);
            alertChannelMessage = success ? "Test message sent successfully!" : $"Test failed: {error}";
            alertChannelMessageClass = success ? "success" : "danger";
        }
        catch (Exception ex)
        {
            alertChannelMessage = $"Test error: {ex.Message}";
            alertChannelMessageClass = "danger";
        }
        finally
        {
            testingAlertChannel = false;
            testingAlertChannelId = 0;
            StateHasChanged();
        }
    }

