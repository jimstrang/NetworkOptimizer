    private async Task SaveExtServer()
    {
        if (string.IsNullOrWhiteSpace(extServerFormName) || string.IsNullOrWhiteSpace(extServerFormHost))
        {
            extServerMessage = "Server name and hostname are required";
            extServerMessageClass = "danger";
            return;
        }

        savingExtServer = true;
        extServerMessage = "";
        StateHasChanged();

        try
        {
            var server = new ExternalSpeedTestServer
            {
                Name = extServerFormName.Trim(),
                Host = extServerFormHost.Trim(),
                Port = Math.Clamp(extServerFormPort, 1, 65535),
                Scheme = extServerFormScheme
            };

            if (editingExtServerId.HasValue)
            {
                server.Id = editingExtServerId.Value;
                await SystemSettings.UpdateExternalSpeedTestServerAsync(server);
                extServerMessage = "Server updated";
            }
            else
            {
                await SystemSettings.AddExternalSpeedTestServerAsync(server);
                extServerMessage = "Server added";
            }
            extServerMessageClass = "success";

            await LoadExtServers();
            SystemSettings.UpdateCachedExternalOrigins(extServers);
            showExtServerForm = false;
            editingExtServerId = null;
        }
        catch (Exception ex)
        {
            extServerMessage = $"Error saving server: {ex.Message}";
            extServerMessageClass = "danger";
        }
        finally
        {
            savingExtServer = false;
            StateHasChanged();
        }
    }

