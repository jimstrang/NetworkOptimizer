                    </div>
                    <p class="form-hint" style="margin-top: 0.5rem;">Both include controller credentials, SSH keys, and data protection keys. Full adds floor plans, speed test history, audit results, signal logs, etc. Settings Only exports just configuration without history data.</p>
                    @if (!string.IsNullOrEmpty(exportError))
                    {
                        <div class="alert alert-danger" style="margin-top: 0.5rem;">@exportError</div>
                    }
                </div>

                <div class="action-item">
                    <h4>Import Configuration</h4>
                    <p>Restore settings from a .nopt backup file</p>

