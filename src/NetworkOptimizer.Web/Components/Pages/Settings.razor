    private void SwitchAuthMethod(bool toApiKey)
    {
        if (useApiKeyAuth == toApiKey) return;
        useApiKeyAuth = toApiKey;

        // Clear the field for the method we're switching away from
        if (toApiKey)
        {
            controllerPassword = "";
        }
        else
        {
            controllerApiKey = "";
        }
    }

    private async Task<UniFiConnectionConfig> BuildConfigAsync()
    {
        string? apiKey = null;
        var password = "";

        if (useApiKeyAuth)
        {
            // Use newly entered API key, or fall back to stored key from database
            apiKey = controllerApiKey;
            if (string.IsNullOrEmpty(apiKey))
            {
                apiKey = await ConnectionService.GetStoredApiKeyAsync();
            }
        }
        else
        {
            // Use newly entered password, or fall back to stored password from database
            password = controllerPassword;
            if (string.IsNullOrEmpty(password))
            {
                password = await ConnectionService.GetStoredPasswordAsync() ?? "";
            }
        }

        return new UniFiConnectionConfig
        {
            ControllerUrl = NetworkUtilities.NormalizeControllerUrl(controllerUrl),
            Username = controllerUsername,
            Password = password,
            ApiKey = apiKey,
            Site = string.IsNullOrWhiteSpace(controllerSite) ? "default" : controllerSite,
            RememberCredentials = rememberCredentials,
            IgnoreControllerSSLErrors = ignoreControllerSSLErrors
        };
    }

