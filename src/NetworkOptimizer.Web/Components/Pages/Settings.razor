    private async Task LoadMonitoringSettings()
    {
        try
        {
            _monitoringSettings = await SnmpDetection.GetOrCreateSettingsAsync();
            if (_monitoringSettings != null)
            {
                _influxUrl = _monitoringSettings.InfluxDbUrl ?? "http://localhost:8086";
                _influxOrg = _monitoringSettings.InfluxDbOrg ?? "network-optimizer";
                _influxBucket = _monitoringSettings.InfluxDbBucket ?? "network_monitoring";
                _influxLongtermBucket = _monitoringSettings.InfluxDbLongtermBucket ?? "network_monitoring_longterm";
                _influxTokenIsSet = !string.IsNullOrEmpty(_monitoringSettings.InfluxDbToken);
                _influxToken = string.Empty;
            }
        }
        catch
        {
            _monitoringSettings = null;
        }
    }

    private async Task SaveInfluxSettings()
    {
        _savingInflux = true;
        _monitoringMessage = "";
        StateHasChanged();

        try
        {
            // Make sure the row exists (handles first-run when MonitoringSettings is empty)
            await SnmpDetection.GetOrCreateSettingsAsync();

            await using var db = await DbFactory.CreateDbContextAsync();
            var settings = await db.MonitoringSettings.FirstAsync();
            settings.InfluxDbUrl = (_influxUrl ?? "").Trim();
            settings.InfluxDbOrg = string.IsNullOrWhiteSpace(_influxOrg) ? "network-optimizer" : _influxOrg.Trim();
            settings.InfluxDbBucket = string.IsNullOrWhiteSpace(_influxBucket) ? "network_monitoring" : _influxBucket.Trim();
            settings.InfluxDbLongtermBucket = string.IsNullOrWhiteSpace(_influxLongtermBucket) ? "network_monitoring_longterm" : _influxLongtermBucket.Trim();

            // Only update the token if the user typed a new value
            if (!string.IsNullOrEmpty(_influxToken))
            {
                settings.InfluxDbToken = CredentialService.Encrypt(_influxToken);
            }
            settings.UpdatedAt = DateTime.UtcNow;
            await db.SaveChangesAsync();

            await InfluxClient.ReconfigureAsync();
            var health = await InfluxClient.CheckHealthAsync();

            await LoadMonitoringSettings();

            if (health.Reachable)
            {
                _monitoringMessage = "InfluxDB settings saved; connection successful.";
                _monitoringMessageClass = "success";
            }
            else
            {
                _monitoringMessage = $"Saved, but InfluxDB is unreachable: {health.Error}";
                _monitoringMessageClass = "warning";
            }
        }
        catch (Exception ex)
        {
            _monitoringMessage = $"Error saving InfluxDB settings: {ex.Message}";
            _monitoringMessageClass = "danger";
        }
        finally
        {
            _savingInflux = false;
        }
    }

    private async Task RedetectSnmp()
    {
        _redetectingSnmp = true;
        _monitoringMessage = "";
        StateHasChanged();

        try
        {
            var result = await SnmpDetection.DetectSnmpSettingsAsync();
            if (result.Success)
            {
                await SnmpDetection.SaveDetectionResultAsync(result);
                await LoadMonitoringSettings();
                _monitoringMessage = _monitoringSettings?.SnmpDetectionState switch
                {
                    SnmpDetectionState.EnabledV2c => "SNMP v2c detected and saved.",
                    SnmpDetectionState.EnabledV3Only => "SNMPv3 detected and saved.",
                    SnmpDetectionState.Disabled => "SNMP is not enabled on your UniFi Console.",
                    _ => "SNMP detection complete."
                };
                _monitoringMessageClass = "success";
            }
            else
            {
                _monitoringMessage = result.ErrorMessage ?? "Detection failed";
                _monitoringMessageClass = "danger";
            }
        }
        catch (Exception ex)
        {
            _monitoringMessage = $"Error: {ex.Message}";
            _monitoringMessageClass = "danger";
        }
        finally
        {
            _redetectingSnmp = false;
        }
    }
