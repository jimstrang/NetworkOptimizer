                                            {
                                                <span class="spinner spinner-sm"></span> <span>Importing...</span>
                                            }
                                            else
                                            {
                                                <span>Yes, Replace Settings</span>
                                            }
                                        </button>
                                        <button class="btn btn-secondary" @onclick="CancelImport" disabled="@isImporting">Cancel</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <label class="btn btn-secondary" style="cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem;">
                            @if (isValidatingImport)
                            {
                                <span class="spinner spinner-sm"></span> <span>Validating...</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
