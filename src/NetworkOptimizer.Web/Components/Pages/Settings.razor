    private async Task SaveModem()
    {
        var isUniFiProvider = string.IsNullOrWhiteSpace(editingModem.Provider) ||
                              editingModem.Provider == "qmicli";
        var isQuectelProvider = editingModem.Provider == "quectel-at";
        var isHttpProvider = !isUniFiProvider && !isQuectelProvider;

        // UniFi modems use shared SSH credentials; require them to be configured
        if (editingModem.Id == 0 && isUniFiProvider && sshSettings?.HasCredentials != true)
        {
            modemMessage = "SSH credentials must be configured before adding Ubiquiti modems. Please configure them in the Device SSH section above.";
            modemMessageClass = "warning";
            return;
        }

        if (string.IsNullOrWhiteSpace(editingModem.Name) || string.IsNullOrWhiteSpace(editingModem.Host))
        {
            modemMessage = "Name and Host are required";
            modemMessageClass = "danger";
            return;
        }

        // GL-iNet/Quectel modems need per-modem SSH credentials
        if (isQuectelProvider && string.IsNullOrWhiteSpace(editingModem.Username))
        {
            modemMessage = "SSH username is required for GL-iNet modems";
            modemMessageClass = "danger";
            return;
        }

        if (isQuectelProvider && string.IsNullOrWhiteSpace(editingModem.Password) && string.IsNullOrWhiteSpace(editingModem.PrivateKeyPath))
        {
            modemMessage = "SSH password or private key path is required for GL-iNet modems";
            modemMessageClass = "danger";
            return;
        }

        // HTTP-based providers don't use SSH/QMI fields
        if (isHttpProvider)
        {
            editingModem.Port = 80;
            editingModem.Username = "";
            editingModem.PrivateKeyPath = "";
            editingModem.QmiDevice = "";
            if (string.IsNullOrEmpty(editingModem.ModemType) ||
                editingModem.ModemType == "U5G-Max")
            {
                editingModem.ModemType = "Netgear Nighthawk Hotspot";
            }
        }

        // GL-iNet modems use the TransportPath for USB bus path, not QMI device
        if (isQuectelProvider)
        {
            if (string.IsNullOrEmpty(editingModem.ModemType) ||
                editingModem.ModemType == "U5G-Max")
            {
                editingModem.ModemType = "GL-iNet";
            }
        }

        savingModem = true;
        modemMessage = "";
        StateHasChanged();

        try
        {
            await ModemService.SaveModemAsync(editingModem);
            modemMessage = editingModem.Id > 0 ? "Modem updated successfully" : "Modem added successfully";
            modemMessageClass = "success";

            // Refresh list and reset form
            await LoadModemConfigs();
            CancelEditModem();
        }
        catch (Exception ex)
        {
            modemMessage = $"Error saving modem: {ex.Message}";
            modemMessageClass = "danger";
        }
        finally
        {
            savingModem = false;
            StateHasChanged();
        }
    }

