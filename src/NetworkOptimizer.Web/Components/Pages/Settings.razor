                isolated database with per-site monitoring, speed testing, and UniFi Console connection
                settings. Most installs manage a single network and can leave this off.
            </p>

            <div class="form-group">
                <label class="checkbox-label">
                    <input type="checkbox" checked="@_multiSiteEnabled" @onchange="OnMultiSiteEnabledChanged" />
                    <span>Enable multi-site management</span>
                </label>
            </div>

            @if (_multiSiteEnabled)
            {
                <div class="form-group">
                    <label class="form-label">Sites</label>
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Site ID</th>
                                    <th class="hide-mobile">Created</th>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var site in _sites)
                                {
                                    <tr>
                                        <td>@site.Name</td>
                                        <td><code>@site.Slug</code></td>
                                        <td class="hide-mobile">@site.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                        <td>
                                            @if (site.IsDefault)
                                            {
                                                <span class="status-badge">Default</span>
                                            }
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-secondary btn-sm" @onclick="() => ToggleAgents(site.Id)">
                                                Agents (@AgentCount(site.Id))
                                            </button>
                                        </td>
                                    </tr>
                                    @if (_expandedSiteId == site.Id)
                                    {
                                        <tr>
                                            <td colspan="5">
                                                @foreach (var agent in AgentsFor(site.Id))
                                                {
                                                    <div class="site-agent-row">
                                                        <span class="status-dot @(AgentEnrollmentService.IsOnline(agent.LastSeenAt) ? "online" : "offline")"></span>
                                                        <span>@agent.Name</span>
                                                        <span class="site-agent-status">
                                                            @if (!agent.Enabled)
                                                            {
                                                                <text>Disabled</text>
                                                            }
                                                            else if (agent.EnrolledAt == null)
                                                            {
                                                                <text>Awaiting enrollment</text>
                                                            }
                                                            else if (AgentEnrollmentService.IsOnline(agent.LastSeenAt))
                                                            {
                                                                <text>Online@(agent.LastVersion != null ? $" - v{agent.LastVersion}" : "")</text>
                                                            }
                                                            else
                                                            {
                                                                <text>Last seen @agent.LastSeenAt?.ToLocalTime().ToString("MMM d, h:mm tt")</text>
                                                            }
                                                        </span>
                                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="() => ToggleAgentEnabled(agent)">
                                                            @(agent.Enabled ? "Disable" : "Enable")
                                                        </button>
                                                    </div>
                                                }
                                                <div class="site-agent-actions">
                                                    <button type="button" class="btn btn-primary btn-sm" @onclick="() => CreateAgent(site)" disabled="@_creatingAgent">
                                                        New Agent Token
                                                    </button>
                                                </div>
