        {
            if (ch.ChannelType == DeliveryChannelType.Email)
            {
                var cfg = System.Text.Json.JsonSerializer.Deserialize<NetworkOptimizer.Alerts.Delivery.EmailChannelConfig>(ch.ConfigJson);
                if (cfg != null)
                {
                    channelSmtpHost = cfg.SmtpHost;
