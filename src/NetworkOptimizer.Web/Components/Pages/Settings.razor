    [Inject] private ConfigTransferService ConfigTransfer { get; set; } = default!;

    private async Task ExportConfig(ExportType type)
    {
        isExporting = true;
        isExportingFull = type == ExportType.Full;
        isExportingSettings = type == ExportType.SettingsOnly;
        exportError = null;
        StateHasChanged();

        try
        {
            var bytes = await ConfigTransfer.ExportAsync(type);
            var label = type == ExportType.Full ? "full" : "settings";
            var fileName = $"NetworkOptimizer-{label}-{DateTime.UtcNow:yyyyMMdd}.nopt";
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, "application/octet-stream", base64);
        }
        catch (Exception ex)
        {
            exportError = $"Export failed: {ex.Message}";
        }
        finally
        {
            isExporting = false;
            isExportingFull = false;
            isExportingSettings = false;
            StateHasChanged();
        }
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        importError = null;
        importPreview = null;
        showImportConfirm = false;
        isValidatingImport = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (file.Size > 500 * 1024 * 1024) // 500 MB limit
            {
                importError = "File is too large (max 500 MB)";
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            importPreview = await ConfigTransfer.ValidateImportAsync(ms);
        }
        catch (Exception ex)
        {
            importError = $"Invalid backup file: {ex.Message}";
        }
        finally
        {
            isValidatingImport = false;
            StateHasChanged();
        }
    }

    private async Task ApplyImport()
    {
        isImporting = true;
        importError = null;
        StateHasChanged();

        try
        {
            await ConfigTransfer.ApplyImportAsync();
            importApplied = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            importError = $"Import failed: {ex.Message}";
            isImporting = false;
            StateHasChanged();
        }
    }

    private void CancelImport()
    {
        ConfigTransfer.CancelPendingImport();
        importPreview = null;
        importError = null;
        showImportConfirm = false;
        StateHasChanged();
    }

