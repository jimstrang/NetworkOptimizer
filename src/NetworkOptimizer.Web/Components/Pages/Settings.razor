    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabParam { get; set; }

    private string _activeTab = "connection";
    private string? _lastTabParam;

    private static readonly HashSet<string> ValidTabs = new(StringComparer.OrdinalIgnoreCase)
    {
        "connection", "monitoring", "speedtests", "security", "application", "multisite"
    };

    // Maps card anchors (used by /settings#... deep links across the app) to their tab
    // so those links keep working: activate the tab, then scroll to and highlight the card.
    private static readonly Dictionary<string, string> AnchorTabMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["console-connection"] = "connection",
        ["gateway-ssh"] = "connection",
        ["device-ssh"] = "connection",
        ["monitoring"] = "monitoring",
        ["sqm-monitor"] = "monitoring",
        ["cellular-modem"] = "monitoring",
        ["cable-modem"] = "monitoring",
        ["ont-monitoring"] = "monitoring",
        ["speed-test-settings"] = "speedtests",
        ["external-speedtest-settings"] = "speedtests",
        ["security-audit"] = "security",
        ["alert-channels"] = "security",
        ["threat-intelligence"] = "security",
        ["maxmind"] = "security",
        ["crowdsec"] = "security",
        ["admin-password"] = "application",
        ["application-settings"] = "application",
        ["ui-display"] = "application",
        ["map"] = "application",
        ["data-management"] = "application",
        ["multi-site"] = "multisite",
    };

    private static string ResolveTab(string? param) =>
        param != null && ValidTabs.Contains(param) ? param.ToLowerInvariant() : "connection";

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        NavigationManager.NavigateTo("/settings?tab=" + tab, forceLoad: false, replace: false);
        _lastTabParam = tab;
    }

    protected override void OnParametersSet()
    {
        // Handle query param changes when already on this page (Blazor reuses the component)
        if (TabParam != _lastTabParam && _lastTabParam != null)
        {
            var newTab = ResolveTab(TabParam);
            if (newTab != _activeTab)
            {
                _activeTab = newTab;
                StateHasChanged();
            }
        }
        _lastTabParam = TabParam;
    }

    private async Task HandleFragmentNavigationAsync()
    {
        // The fragment is not part of the HTTP request, so it is only readable client-side.
        var hash = await JS.InvokeAsync<string>("eval", "window.location.hash");
        if (string.IsNullOrEmpty(hash))
            return;

        var anchor = hash.TrimStart('#');
        if (anchor.Equals("unifi-ssh", StringComparison.OrdinalIgnoreCase))
            anchor = "device-ssh";
        if (!AnchorTabMap.TryGetValue(anchor, out var tab))
            return;

        if (_activeTab != tab)
        {
            _activeTab = tab;
            StateHasChanged();
        }

        // Let the tab panel render before scrolling; same scroll-and-highlight
        // pattern as the Monitoring page.
        await Task.Delay(300);
        await JS.InvokeVoidAsync("eval", @"
            (function() {
                var el = document.getElementById('" + anchor + @"');
                if (el) {
                    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    el.style.transition = 'outline-color 0.3s';
                    el.style.outline = '2px solid rgba(59, 130, 246, 0.5)';
                    el.style.outlineOffset = '4px';
                    el.style.borderRadius = '12px';
                    setTimeout(function() { el.style.outline = ''; el.style.outlineOffset = ''; }, 2000);
                }
            })();");
    }

    // Multi-Site
    private bool _multiSiteEnabled = false;
    private List<Site> _sites = new();
    private string _multiSiteMessage = "";
    private string _multiSiteMessageClass = "";

    private async Task LoadMultiSiteSettings()
    {
        _multiSiteEnabled = await SiteManagement.IsMultiSiteEnabledAsync();
        if (_multiSiteEnabled)
        {
            _sites = await SiteManagement.GetSitesAsync();
            await LoadAgentsAsync();
        }
    }

    private async Task OnMultiSiteEnabledChanged(ChangeEventArgs e)
    {
        _multiSiteEnabled = e.Value is true;
        _multiSiteMessage = "";
        await SiteManagement.SetMultiSiteEnabledAsync(_multiSiteEnabled);
        if (_multiSiteEnabled)
            _sites = await SiteManagement.GetSitesAsync();
    }

    private async Task RefreshSites()
    {
        _sites = await SiteManagement.GetSitesAsync();
        await LoadAgentsAsync();
        StateHasChanged();
    }

    // Site agents (registry data, keyed by site id)
    private Dictionary<int, List<SiteAgent>> _agentsBySite = new();
    private int? _expandedSiteId;
    private bool _creatingAgent;
    private string? _newAgentToken;
    private int? _newAgentTokenSiteId;

    private async Task LoadAgentsAsync()
    {
        _agentsBySite = (await AgentEnrollment.GetAllAgentsAsync())
            .GroupBy(a => a.SiteId)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.CreatedAt).ToList());
    }

    private List<SiteAgent> AgentsFor(int siteId) =>
        _agentsBySite.TryGetValue(siteId, out var agents) ? agents : new List<SiteAgent>();

    private int AgentCount(int siteId) => AgentsFor(siteId).Count;

    private void ToggleAgents(int siteId)
    {
        _expandedSiteId = _expandedSiteId == siteId ? null : siteId;
        _newAgentToken = null;
    }

    private async Task CreateAgent(Site site)
    {
        _creatingAgent = true;
        try
        {
            var (agent, token) = await AgentEnrollment.CreateAgentAsync(site.Id, $"Agent {AgentCount(site.Id) + 1}");
            _newAgentToken = token;
            _newAgentTokenSiteId = site.Id;
            await LoadAgentsAsync();
        }
        finally
        {
            _creatingAgent = false;
        }
    }

    private async Task ToggleAgentEnabled(SiteAgent agent)
    {
        await AgentEnrollment.SetEnabledAsync(agent.Id, !agent.Enabled);
        await LoadAgentsAsync();
    }

