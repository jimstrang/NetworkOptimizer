                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <SiteSetupWizard OnSitesChanged="RefreshSites" />
            }

            @if (!string.IsNullOrEmpty(_multiSiteMessage))
