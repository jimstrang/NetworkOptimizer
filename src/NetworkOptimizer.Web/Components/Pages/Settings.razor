    private void StartEditChannel(DeliveryChannel ch)
    {
        editingChannelId = ch.Id;
        channelFormName = ch.Name;
        channelFormType = ch.ChannelType.ToString();
        channelMinSeverity = ch.MinSeverity.ToString();
        channelEnabled = ch.IsEnabled;
