    private async void OnConnectionChanged()
    {
        _sqmPanelKey++;
        _alertsListKey++;
        await Task.WhenAll(
            LoadDashboardData(),
            LoadSpeedTestData(),
            LoadWanTestData(),
            LoadThreatData()
        );
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAllDataAsync()
    {
        try
        {
            _passwordSource = await AdminAuthService.GetPasswordSourceAsync();
        }
        catch { }

        await ConnectionService.WaitForConnectionAsync();

        await Task.WhenAll(
            LoadDashboardData(),
            LoadSpeedTestData(),
            LoadWanTestData(),
            LoadThreatData()
        );

        await InvokeAsync(StateHasChanged);
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (e.Location.EndsWith("/") || e.Location.EndsWith("/dashboard", StringComparison.OrdinalIgnoreCase))
        {
            _sqmPanelKey++;
            _alertsListKey++;
            await Task.WhenAll(
                LoadDashboardData(),
                LoadSpeedTestData(),
                LoadThreatData()
            );
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ConnectionService.OnConnectionChanged -= OnConnectionChanged;
        _toastTimer?.Dispose();
    }

    private async Task LoadSpeedTestData()
    {
        _speedTestLoading = true;
        try
        {
            var results = await SpeedTestService.GetRecentResultsAsync(25);
            _recentSpeedTests = results.Where(r => r.Success).Take(5).ToList();
        }
        catch { }
        finally { _speedTestLoading = false; }
    }

    private async Task LoadWanTestData()
    {
        _wanTestLoading = true;
        try
        {
            var serverResults = await WanSpeedTestService.GetResultsAsync(count: 5);
            var gatewayResults = await GatewayWanTestService.GetResultsAsync(count: 5);
            _recentWanTests = serverResults.Concat(gatewayResults)
                .Where(r => r.Success)
                .OrderByDescending(r => r.TestTime)
                .Take(5)
                .ToList();
        }
        catch { }
        finally { _wanTestLoading = false; }
    }

    private async Task LoadDashboardData()
    {
        _loading = true;
        try
        {
            var data = await DashboardService.GetDashboardDataAsync();
            deviceCount = data.DeviceCount;
            securityScore = data.SecurityScore;
            sqmStatus = data.SqmStatus;
            alertCount = data.AlertCount;
            criticalIssues = data.CriticalIssues;
            warningIssues = data.WarningIssues;
            lastAuditTime = data.LastAuditTime;
            devices = data.Devices;
            _wifiHealthScore = data.WiFiHealthScore;
            _wifiHealthGrade = data.WiFiHealthGrade;
            _wifiHealthIssues = data.WiFiHealthIssues;
        }
        finally { _loading = false; }
    }

    private async Task OnAlertDismissed()
    {
        await LoadDashboardData();
        StateHasChanged();
    }

    private async Task LoadThreatData()
    {
        _threatLoading = true;
        try
        {
            var (total, points) = await ThreatService.GetThreatTrendAsync(24);
            _threatCount24h = total;
            _threatTrend = points;
        }
        catch { }
        finally { _threatLoading = false; }
    }

    private static string FormatNumber(int value) => value switch
    {
        >= 1_000_000 => $"{value / 1_000_000.0:F1}M",
        >= 10_000 => $"{value / 1_000.0:F1}K",
        >= 1_000 => $"{value:N0}",
        _ => value.ToString()
    };

    private static ApexChartOptions<ThreatTrendPoint> CreateThreatSparklineOptions()
    {
        return new ApexChartOptions<ThreatTrendPoint>
        {
            Chart = new Chart
            {
                Background = "transparent",
                Sparkline = new ChartSparkline { Enabled = true },
                Animations = new Animations { Enabled = true, Speed = 300 }
            },
            Colors = new List<string> { "#2ba89a" },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Fill = new Fill
            {
                Type = new List<FillType> { FillType.Gradient },
                Gradient = new FillGradient
                {
                    ShadeIntensity = 0.3,
                    OpacityFrom = 0.4,
                    OpacityTo = 0.05
                }
            },
            Tooltip = new Tooltip
            {
                Theme = Mode.Dark,
                X = new TooltipX { Format = "HH:mm" }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels { DatetimeUTC = false }
            },
            Yaxis = new List<YAxis> { new YAxis { Min = 0 } }
        };
    }

    private void NavigateToOntChart()
    {
        if (_ontPanel?.IsCurrentExternal == true)
        {
            var ontId = _ontPanel.CurrentExternalOntId;
            var url = ontId != null
                ? $"/monitoring?tab=ont&ont={Uri.EscapeDataString(ontId)}"
                : "/monitoring?tab=ont";
            NavigationManager.NavigateTo(url);
            return;
        }
        var key = _ontPanel?.CurrentModuleKey;
        var url2 = key != null
            ? $"/monitoring?tab=sfp&sfp={Uri.EscapeDataString(key)}"
            : "/monitoring?tab=sfp";
        NavigationManager.NavigateTo(url2);
    }

    private void NavigateToCellularChart()
    {
        var modemId = _cellularPanel?.CurrentModemId;
        var url = modemId != null
            ? $"/monitoring?tab=cellular&modem={Uri.EscapeDataString(modemId)}"
            : "/monitoring?tab=cellular";
        NavigationManager.NavigateTo(url);
    }

    private void NavigateToCmChart()
    {
        var cmId = _cmPanel?.CurrentCmId;
        var url = cmId != null
            ? $"/monitoring?tab=cm&cm={Uri.EscapeDataString(cmId)}"
            : "/monitoring?tab=cm";
        NavigationManager.NavigateTo(url);
    }

