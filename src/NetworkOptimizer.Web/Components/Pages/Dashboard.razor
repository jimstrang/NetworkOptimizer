@page "/"
@using NetworkOptimizer.Web.Services
@using NetworkOptimizer.Storage.Models
@using NetworkOptimizer.WiFi
@using Microsoft.AspNetCore.Components.Routing
@inject DashboardService DashboardService
@inject DashboardLayoutService LayoutService
@inject UniFiConnectionService ConnectionService
@inject Iperf3SpeedTestService SpeedTestService
@inject UwnSpeedTestService WanSpeedTestService
@inject GatewayWanSpeedTestService GatewayWanTestService
@inject IAdminAuthService AdminAuthService
@inject ThreatDashboardService ThreatService
@inject NavigationManager NavigationManager
@inject PullToRefreshState PtrState
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Dashboard - Network Optimizer</PageTitle>
<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation" ConfirmExternalNavigation="_editMode" />

<div class="page-header">
    <h1>Dashboard</h1>
    <div class="page-header-actions">
        @if (_editMode)
        {
            <button class="btn btn-sm btn-primary" @onclick="ExitEditMode">Done</button>
            <button class="btn btn-sm btn-secondary" @onclick="CancelEditMode">Cancel</button>
        }
        else
        {
            <button class="btn btn-sm btn-outline-primary" @onclick="EnterEditMode">Edit Layout</button>
        }
    </div>
    <p class="page-description">Network overview and health status</p>
</div>

<SitesOverviewCard />

@if (!string.IsNullOrEmpty(_editToast))
{
    <div class="edit-toast">@_editToast</div>
}

@if (_passwordSource == AdminPasswordSource.AutoGenerated)
{
    <div class="connection-banner" style="background: linear-gradient(135deg, #261c08 0%, #1a1305 100%); border-color: #3d2e0a;">
        <div class="banner-content">
            <span class="banner-icon" style="background: var(--warning-color); color: white;">!</span>
            <div class="banner-text">
                <strong style="color: var(--warning-color);">Using Auto-Generated Password</strong>
                <span style="color: #c9a86c;">Set a permanent admin password in Settings to secure your installation.</span>
            </div>
            <a href="/settings#admin-password" class="btn btn-warning">Set Password</a>
        </div>
    </div>
}

@if (!ConnectionService.IsConnected && ConnectionService.IsInitialized)
{
    <div class="connection-banner @(!string.IsNullOrEmpty(ConnectionService.LastError) ? "connection-error" : "")">
        <div class="banner-content">
            <span class="banner-icon">!</span>
            <div class="banner-text">
                @if (!string.IsNullOrEmpty(ConnectionService.LastError))
                {
                    <strong>Connection Error</strong>
                    <span>@ConnectionService.LastError</span>
                }
                else
                {
                    <strong>Not Connected</strong>
                    <span>Connect to your UniFi Console (Controller) to view network data.</span>
                }
            </div>
            <a href="/settings" class="btn btn-primary">@(!string.IsNullOrEmpty(ConnectionService.LastError) ? "Check Settings" : "Connect Now")</a>
        </div>
    </div>
}

<NetworkOptimizer.Web.Components.Shared.UpdateChecker />
<NetworkOptimizer.Web.Components.Shared.SponsorshipBanner />
<NetworkOptimizer.Web.Components.Shared.PwaBanner />

<div class="dashboard-grid">
    @if (_layout != null)
    {
        @* Visible top-level cards *@
        @foreach (var card in _layout.Cards.Where(c => c.Visible))
        {
            if (IsStackedChild(card.Id)) continue;

            var hasStack = card.StackedCards.Count > 0;

            <div class="dashboard-card-wrapper @(_editMode ? "dashboard-card-editing" : "") @(card.FullWidth ? "card-span-2" : "")">
                @if (_editMode)
                {
                    @RenderCardEditToolbar(card)
                }

                @if (hasStack)
                {
                    <div class="card-stack">
                        @RenderCard(card.Id)
                        @foreach (var childId in card.StackedCards)
                        {
                            @if (_editMode)
                            {
                                <div class="stacked-child-toolbar">
                                    <span class="card-edit-label">@DashboardCards.GetDisplayName(childId)</span>
                                    <button class="card-edit-btn" @onclick="() => UnstackCard(card.Id, childId)" data-tooltip="Unstack">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                                    </button>
                                </div>
                            }
                            @RenderCard(childId)
                        }
                    </div>
                }
                else
                {
                    @RenderCard(card.Id)
                }

                @if (_editMode)
                {
                    var stackable = GetStackableCards(card.Id);
                    @if (stackable.Count > 0)
                    {
                        <div class="stack-add-bar">
                            @foreach (var opt in stackable)
                            {
                                <button class="stat-add-btn" @onclick="() => StackCard(card.Id, opt)">
                                    + Stack @DashboardCards.GetDisplayName(opt)
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        }

        @* Hidden + stacked cards at the bottom in edit mode *@
        @if (_editMode)
        {
            var hiddenCards = _layout.Cards.Where(c => !c.Visible && !IsStackedChild(c.Id)).ToList();
            var stackedCards = _layout.Cards.SelectMany(c => c.StackedCards.Select(s => new { ChildId = s, HostId = c.Id })).ToList();

            @if (hiddenCards.Count > 0 || stackedCards.Count > 0)
            {
                <div class="hidden-cards-divider card-span-2">
                    <span>Hidden Cards</span>
                </div>
            }

            @foreach (var card in hiddenCards)
            {
                <div class="dashboard-card-wrapper dashboard-card-hidden dashboard-card-editing @(card.FullWidth ? "card-span-2" : "")">
                    @RenderCardEditToolbar(card)
                    @RenderCard(card.Id)
                </div>
            }

            @foreach (var stacked in stackedCards)
            {
                <div class="dashboard-card-wrapper dashboard-card-stacked dashboard-card-editing">
                    <div class="card-edit-toolbar">
                        <span class="card-edit-label">@DashboardCards.GetDisplayName(stacked.ChildId) <span class="stacked-in-label">stacked in @DashboardCards.GetDisplayName(stacked.HostId)</span></span>
                        <div class="card-edit-actions">
                            <button class="card-edit-btn" @onclick="() => UnstackCard(stacked.HostId, stacked.ChildId)" data-tooltip="Show as independent card">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </div>
                    </div>
                    @RenderCard(stacked.ChildId)
                </div>
            }
        }
    }
</div>

@code {
    private bool _loading = true;
    private bool _speedTestLoading = true;
    private bool _wanTestLoading = true;
    private bool _threatLoading = true;
    private bool _editMode;
    private OntStatsPanel? _ontPanel;
    private CellularStatsPanel? _cellularPanel;
    private CmStatsPanel? _cmPanel;
    private DashboardLayout? _layout;
    private int deviceCount = 0;
    private int securityScore = 0;
    private string sqmStatus = "Not Configured";
    private int alertCount = 0;
    private int criticalIssues = 0;
    private int warningIssues = 0;
    private string lastAuditTime = "Never";
    private int _threatCount24h;
    private List<ThreatTrendPoint> _threatTrend = [];
    private List<Services.DeviceInfo> devices = new();
    private List<Iperf3Result> _recentSpeedTests = new();
    private List<Iperf3Result> _recentWanTests = new();
    private int? _wifiHealthScore;
    private string? _wifiHealthGrade;
    private List<HealthIssue> _wifiHealthIssues = new();
    private int _sqmPanelKey = 0;
    private int _alertsListKey = 0;
    private AdminPasswordSource _passwordSource = AdminPasswordSource.None;
    private ApexChartOptions<ThreatTrendPoint> _threatSparklineOptions = CreateThreatSparklineOptions();

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        ConnectionService.OnConnectionChanged += OnConnectionChanged;
        PtrState.RefreshCallback = () => Task.WhenAll(
            LoadDashboardData(), LoadSpeedTestData(), LoadWanTestData(), LoadThreatData());
        PtrState.NotifyStateChanged = StateHasChanged;

        _layout = await LayoutService.GetLayoutAsync();

        // Fire and forget - page renders immediately with spinners, data loads in background
        _ = LoadAllDataAsync();
    }

    private RenderFragment RenderCard(string cardId) => cardId switch
    {
        DashboardCards.StatsRow => RenderStatsRow,
        DashboardCards.SecurityPosture => RenderSecurityPosture,
        DashboardCards.SqmStatus => RenderSqmStatus,
        DashboardCards.ThreatTrends => RenderThreatTrends,
        DashboardCards.CellularStats => RenderCellularStats,
        DashboardCards.CmStats => RenderCmStats,
        DashboardCards.OntStats => RenderOntStats,
        DashboardCards.SpeedTests => RenderSpeedTests,
        DashboardCards.WiFiOptimizer => RenderWiFiOptimizer,
        DashboardCards.RecentAlerts => RenderRecentAlerts,
        DashboardCards.DeviceStatus => RenderDeviceStatus,
        DashboardCards.LiveView => RenderLiveView,
        _ => builder => { }
    };

    // ──────────────────────────────────────────────────────────
    // Card render fragments
    // ──────────────────────────────────────────────────────────

    private RenderFragment RenderStatsRow => __builder =>
    {
        <div class="stats-row @(_editMode ? "stats-row-editing" : "")">
            @if (_layout != null)
            {
                @foreach (var statId in _layout.StatItems)
                {
                    <div class="stat-item-wrapper @(_editMode ? "stat-item-editing" : "")">
                        @if (_editMode)
                        {
                            <div class="stat-edit-actions">
                                <button class="stat-edit-btn" @onclick="() => MoveStatItem(statId, -1)" disabled="@(_layout.StatItems.IndexOf(statId) == 0)">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M15 18l-6-6 6-6"/></svg>
                                </button>
                                <button class="stat-edit-btn stat-edit-btn-remove" @onclick="() => RemoveStatItem(statId)">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg>
                                </button>
                                <button class="stat-edit-btn" @onclick="() => MoveStatItem(statId, 1)" disabled="@(_layout.StatItems.IndexOf(statId) == _layout.StatItems.Count - 1)">
                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 18l6-6-6-6"/></svg>
                                </button>
                            </div>
                        }
                        @RenderStatItem(statId)
                    </div>
                }

                @if (_editMode)
                {
                    var hiddenStats = DashboardStatItems.All.Where(s => !_layout.StatItems.Contains(s)).ToList();
                    @if (hiddenStats.Any())
                    {
                        <div class="stat-add-wrapper">
                            <div class="stat-add-dropdown">
                                @foreach (var statId in hiddenStats)
                                {
                                    <button class="stat-add-btn" @onclick="() => AddStatItem(statId)">
                                        + @DashboardStatItems.GetDisplayName(statId)
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    };

    private RenderFragment RenderStatItem(string statId) => statId switch
    {
        DashboardStatItems.TotalDevices => RenderStatTotalDevices,
        DashboardStatItems.SecurityScore => RenderStatSecurityScore,
        DashboardStatItems.SqmStatus => RenderStatSqmStatus,
        DashboardStatItems.ActiveAlerts => RenderStatActiveAlerts,
        DashboardStatItems.ThreatEvents => RenderStatThreatEvents,
        DashboardStatItems.WiFiHealth => RenderStatWiFiHealth,
        _ => builder => { }
    };

    private RenderFragment RenderStatTotalDevices => __builder =>
    {
        <a href="#device-status" class="stat-card stat-card-link">
            <div class="stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                    <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" opacity="0.7"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10Zm4-10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" opacity="0.6"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-1 0a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" style="fill: var(--primary-hover)"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M22 12c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2s10 4.477 10 10Zm-1 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-value">
                    @if (_loading) { <span class="spinner-sm"></span> } else { @deviceCount }
                </div>
                <div class="stat-label">Total Devices</div>
            </div>
        </a>
    };

    private RenderFragment RenderStatSecurityScore => __builder =>
    {
        <a href="/audit" class="stat-card stat-card-link">
            <img src="/icons/shield-v2.png" alt="" class="stat-icon-img" />
            <div class="stat-content">
                <div class="stat-value">
                    @if (_loading) { <span class="spinner-sm"></span> } else { @securityScore }
                </div>
                <div class="stat-label">Security Score</div>
            </div>
        </a>
    };

    private RenderFragment RenderStatSqmStatus => __builder =>
    {
        <a href="/sqm" class="stat-card stat-card-link stat-success">
            <img src="/icons/sqm-v3.png" alt="" class="stat-icon-img" />
            <div class="stat-content">
                <div class="stat-value stat-value-text">
                    @if (_loading)
                    {
                        <span class="spinner-sm"></span>
                    }
                    else if (sqmStatus == "Not Configured")
                    {
                        <span class="desktop-label">Not Configured</span>
                        <span class="mobile-label">Off</span>
                    }
                    else
                    {
                        @sqmStatus
                    }
                </div>
                <div class="stat-label">
                    <span class="desktop-label">Adaptive SQM Status</span>
                    <span class="mobile-label">Adaptive SQM</span>
                </div>
            </div>
        </a>
    };

    private RenderFragment RenderStatActiveAlerts => __builder =>
    {
        <a href="#recent-alerts" class="stat-card stat-card-link stat-warning">
            <img src="/icons/warning-v2.png" alt="" class="stat-icon-img stat-icon-sm" />
            <div class="stat-content">
                <div class="stat-value">
                    @if (_loading) { <span class="spinner-sm"></span> } else { @alertCount }
                </div>
                <div class="stat-label">Security Findings</div>
            </div>
        </a>
    };

    private RenderFragment RenderStatThreatEvents => __builder =>
    {
        <a href="/threats" class="stat-card stat-card-link">
            <img src="/icons/threats.png" alt="" class="stat-icon-img" />
            <div class="stat-content">
                <div class="stat-value">
                    @if (_threatLoading) { <span class="spinner-sm"></span> } else { @FormatNumber(_threatCount24h) }
                </div>
                <div class="stat-label">
                    <span class="desktop-label">Threat Events (24h)</span>
                    <span class="mobile-label">Threats 24h</span>
                </div>
            </div>
        </a>
    };

    private RenderFragment RenderStatWiFiHealth => __builder =>
    {
        <a href="/wifi-optimizer" class="stat-card stat-card-link">
            <img src="/icons/wifi-optimizer.png" alt="" class="stat-icon-img" />
            <div class="stat-content">
                <div class="stat-value">
                    @if (_loading)
                    {
                        <span class="spinner-sm"></span>
                    }
                    else if (_wifiHealthScore.HasValue)
                    {
                        <span>@_wifiHealthScore</span>
                    }
                    else
                    {
                        <span class="stat-value-text">--</span>
                    }
                </div>
                <div class="stat-label">
                    <span class="desktop-label">Wi-Fi Health</span>
                    <span class="mobile-label">Wi-Fi</span>
                </div>
            </div>
        </a>
    };

    private RenderFragment RenderSecurityPosture => __builder =>
    {
        <div class="card clickable-card" @onclick="@(() => NavigationManager.NavigateTo("/audit"))">
            <div class="card-header">
                <a href="/audit" class="card-title-link" @onclick:stopPropagation><h2 class="card-title">Security Posture</h2></a>
            </div>
            <div class="card-body">
                @if (_loading)
                {
                    <div class="loading-state">
                        <span class="spinner-sm"></span>
                        <span>Loading...</span>
                    </div>
                }
                else
                {
                    <SecurityScoreGauge Score="@securityScore" />
                }
                <div class="security-summary">
                    <div class="summary-item">
                        <span class="summary-label">Critical Issues:</span>
                        <span class="summary-value @(criticalIssues > 0 ? "critical" : "")">
                            @if (_loading) { <span class="spinner-sm"></span> } else { @criticalIssues }
                        </span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Recommended:</span>
                        <span class="summary-value @(warningIssues > 0 ? "recommended" : "")">
                            @if (_loading) { <span class="spinner-sm"></span> } else { @warningIssues }
                        </span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Last Audit:</span>
                        <span class="summary-value">
                            @if (_loading) { <span class="spinner-sm"></span> } else { @lastAuditTime }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    };

    private RenderFragment RenderSqmStatus => __builder =>
    {
        <div class="card">
            <div class="card-header">
                <a href="/sqm" class="card-title-link"><h2 class="card-title">Adaptive SQM</h2></a>
            </div>
            <div class="card-body">
                <SqmStatusPanel @key="_sqmPanelKey" />
            </div>
        </div>
    };

    private RenderFragment RenderThreatTrends => __builder =>
    {
        <div class="card clickable-card" @onclick="@(() => NavigationManager.NavigateTo("/threats"))">
            <div class="card-header">
                <a href="/threats" class="card-title-link" @onclick:stopPropagation><h2 class="card-title">Threat Trends</h2></a>
                <a href="/threats" class="card-action" @onclick:stopPropagation>View All →</a>
            </div>
            <div class="card-body">
                @if (_threatLoading)
                {
                    <div class="loading-state">
                        <span class="spinner-sm"></span>
                        <span>Loading...</span>
                    </div>
                }
                else if (_threatTrend.Count == 0)
                {
                    <div class="empty-state">
                        <p>No threat data yet</p>
                    </div>
                }
                else if (_editMode)
                {
                    <div style="height:120px"></div>
                }
                else
                {
                    <ApexChart TItem="ThreatTrendPoint"
                               Options="_threatSparklineOptions"
                               Height="@("120px")">
                        <ApexPointSeries TItem="ThreatTrendPoint"
                                         Items="_threatTrend"
                                         Name="Events"
                                         SeriesType="SeriesType.Area"
                                         XValue="e => e.Hour"
                                         YValue="e => (decimal)e.Count"
                                         OrderBy="e => e.X" />
                    </ApexChart>
                }
            </div>
        </div>
    };

    private RenderFragment RenderCellularStats => __builder =>
    {
        <div class="card clickable-card" @onclick="NavigateToCellularChart">
            <div class="card-header">
                <h2 class="card-title">Cellular Stats (5G / LTE)</h2>
            </div>
            <div class="card-body">
                <CellularStatsPanel @ref="_cellularPanel" />
            </div>
        </div>
    };

    private RenderFragment RenderOntStats => __builder =>
    {
        // The panel renders its own empty-state when no monitored ONT exists, so the
        // card stays on the dashboard but tells the user how to enable it. Mirrors the
        // CellularStats card's "configure" affordance.
        <div class="card clickable-card" @onclick="NavigateToOntChart">
            <div class="card-header">
                <h2 class="card-title">@(_ontPanel?.HasAnyAe == true ? "Fiber Stats" : "ONT Stats (GPON / XGS-PON)")</h2>
            </div>
            <div class="card-body">
                <OntStatsPanel @ref="_ontPanel" OnDataLoaded="StateHasChanged" />
            </div>
        </div>
    };

    private RenderFragment RenderCmStats => __builder =>
    {
        <div class="card clickable-card" @onclick="NavigateToCmChart">
            <div class="card-header">
                <h2 class="card-title">Cable Modem Stats (DOCSIS)</h2>
            </div>
            <div class="card-body">
                <CmStatsPanel @ref="_cmPanel" />
            </div>
        </div>
    };

    private RenderFragment RenderSpeedTests => __builder =>
    {
        <div class="card-stack">
            <div class="card clickable-card" @onclick="@(() => NavigationManager.NavigateTo("/wan-speedtest"))">
                <div class="card-header">
                    <a href="/wan-speedtest" class="card-title-link" @onclick:stopPropagation><h2 class="card-title">WAN Speed Test</h2></a>
                    <a href="/wan-speedtest" class="card-action" @onclick:stopPropagation>View All →</a>
                </div>
                <div class="card-body">
                    @if (_wanTestLoading)
                    {
                        <div class="loading-state">
                            <span class="spinner-sm"></span>
                            <span>Loading...</span>
                        </div>
                    }
                    else if (_recentWanTests.Count == 0)
                    {
                        <div class="empty-state">
                            <p>No WAN speed tests yet</p>
                        </div>
                    }
                    else
                    {
                        <div class="speed-test-list">
                            @foreach (var test in _recentWanTests)
                            {
                                <div class="speed-test-row">
                                    <span class="speed-test-device">@(test.WanName ?? test.WanNetworkGroup ?? "WAN")</span>
                                    <span class="speed-test-speeds">
                                        <span class="speed-down">↓@test.DownloadMbps.ToString("F0")</span>
                                        <span class="speed-up">↑@test.UploadMbps.ToString("F0")</span>
                                    </span>
                                    <span class="speed-test-time">@test.TestTime.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="card clickable-card" @onclick="@(() => NavigationManager.NavigateTo("/speedtest#test-history"))">
                <div class="card-header">
                    <a href="/speedtest" class="card-title-link" @onclick:stopPropagation><h2 class="card-title">LAN Speed Test</h2></a>
                    <a href="/speedtest#test-history" class="card-action" @onclick:stopPropagation>View All →</a>
                </div>
                <div class="card-body">
                    @if (_speedTestLoading)
                    {
                        <div class="loading-state">
                            <span class="spinner-sm"></span>
                            <span>Loading...</span>
                        </div>
                    }
                    else if (_recentSpeedTests.Count == 0)
                    {
                        <div class="empty-state">
                            <p>No speed tests yet</p>
                        </div>
                    }
                    else
                    {
                        <div class="speed-test-list">
                            @foreach (var test in _recentSpeedTests)
                            {
                                <div class="speed-test-row">
                                    @if (!string.IsNullOrEmpty(test.DeviceName))
                                    {
                                        <span class="speed-test-device">@test.DeviceName</span>
                                    }
                                    else if (!string.IsNullOrEmpty(test.DeviceHost))
                                    {
                                        <span class="speed-test-device"><code>@test.DeviceHost</code></span>
                                    }
                                    else
                                    {
                                        <span class="speed-test-device">Unknown</span>
                                    }
                                    <span class="speed-test-speeds">
                                        <span class="speed-down">↓@test.DownloadMbps.ToString("F0")</span>
                                        <span class="speed-up">↑@test.UploadMbps.ToString("F0")</span>
                                    </span>
                                    <span class="speed-test-time">@test.TestTime.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    };

    private RenderFragment RenderWiFiOptimizer => __builder =>
    {
