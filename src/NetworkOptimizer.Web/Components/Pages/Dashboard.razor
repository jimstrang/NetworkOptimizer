    private string? _layoutSnapshot;

    private async Task OnBeforeInternalNavigation(LocationChangingContext context)
    {
        if (_editMode)
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm",
                "You have unsaved dashboard changes. If you leave now, your changes will be lost.\n\nAre you sure you want to leave?");
            if (!confirmed)
            {
                context.PreventNavigation();
            }
        }
    }

    private void EnterEditMode()
    {
        _layoutSnapshot = System.Text.Json.JsonSerializer.Serialize(_layout);
        _editMode = true;
    }

    private async Task ExitEditMode()
    {
        _editMode = false;
        _layoutSnapshot = null;
        if (_layout != null)
        {
            await LayoutService.SaveLayoutAsync(_layout);
        }
    }

    private void CancelEditMode()
    {
        _editMode = false;
        if (_layoutSnapshot != null)
        {
            _layout = System.Text.Json.JsonSerializer.Deserialize<DashboardLayout>(_layoutSnapshot);
            _layoutSnapshot = null;
        }
    }

    private void MoveCard(string cardId, int direction)
    {
        if (_layout == null) return;

        // Build top-level visible card list (what the user sees in the grid)
        var topLevel = _layout.Cards
            .Where(c => c.Visible && !IsStackedChild(c.Id))
            .ToList();
        var tlIndex = topLevel.FindIndex(c => c.Id == cardId);
        if (tlIndex < 0) return;

        // Figure out how many top-level positions to jump to clear one visual row.
        // A full-width card = 1 row. Two consecutive half-width cards = 1 row.
        int positions = 1;
        if (direction < 0 && tlIndex > 0)
        {
            // Moving up: if the card above is half-width and the one above that is also
            // half-width, they share a row - need to jump past both
            var above = tlIndex - 1;
            if (!topLevel[above].FullWidth && above > 0 && !topLevel[above - 1].FullWidth)
            {
                // Check if those two half-width cards are actually on the same row
                // (the one at above-1 starts a row, above fills it)
                positions = 2;
            }
        }
        else if (direction > 0 && tlIndex < topLevel.Count - 1)
        {
            var below = tlIndex + 1;
            if (!topLevel[below].FullWidth && below < topLevel.Count - 1 && !topLevel[below + 1].FullWidth)
            {
                positions = 2;
            }
        }

        // Remove from current position and reinsert
        var fullIndex = _layout.Cards.FindIndex(c => c.Id == cardId);
        var card = _layout.Cards[fullIndex];
        _layout.Cards.RemoveAt(fullIndex);

        // Find the target position in the full list
        var targetTlIndex = tlIndex + (direction * positions);
        targetTlIndex = Math.Max(0, Math.Min(targetTlIndex, topLevel.Count - 1));
        if (targetTlIndex == tlIndex) { _layout.Cards.Insert(fullIndex, card); return; }

        var targetCardId = topLevel[targetTlIndex].Id;
        var insertIndex = _layout.Cards.FindIndex(c => c.Id == targetCardId);
        if (direction > 0) insertIndex++; // insert after target when moving down
        _layout.Cards.Insert(Math.Min(insertIndex, _layout.Cards.Count), card);
    }

    private string? _editToast;
    private System.Threading.Timer? _toastTimer;

    private void ToggleCard(string cardId)
    {
        if (_layout == null) return;
        var card = _layout.Cards.Find(c => c.Id == cardId);
        if (card == null) return;
        card.Visible = !card.Visible;
        if (!card.Visible)
        {
            ShowEditToast($"{DashboardCards.GetDisplayName(cardId)} moved to Hidden Cards below");
        }
    }

    private void ShowEditToast(string message)
    {
        _editToast = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _editToast = null;
            InvokeAsync(StateHasChanged);
        }, null, 3000, Timeout.Infinite);
    }

    private void ToggleWidth(string cardId)
    {
        if (_layout == null) return;
        var card = _layout.Cards.Find(c => c.Id == cardId);
        if (card != null) card.FullWidth = !card.FullWidth;
    }

    private bool IsFirstVisible(string cardId) =>
        _layout?.Cards.FindIndex(c => c.Id == cardId) == 0;

    private bool IsLastVisible(string cardId) =>
        _layout?.Cards.FindIndex(c => c.Id == cardId) == (_layout?.Cards.Count ?? 0) - 1;

    /// <summary>Check if a card is stacked inside another card</summary>
    private bool IsStackedChild(string cardId)
    {
        if (_layout == null) return false;
        return _layout.Cards.Any(c => c.StackedCards.Contains(cardId));
    }

    /// <summary>Get cards available to stack under a given host card</summary>
    private List<string> GetStackableCards(string hostCardId)
    {
        if (_layout == null) return new();
        var allStacked = new HashSet<string>(_layout.Cards.SelectMany(c => c.StackedCards));
        // Can't stack: stats-row, cards already stacked, the host itself
        return _layout.Cards
            .Where(c => c.Id != hostCardId
                && c.Id != DashboardCards.StatsRow
                && !allStacked.Contains(c.Id)
                && c.StackedCards.Count == 0) // can't stack a host card
            .Select(c => c.Id)
            .ToList();
    }

    private void StackCard(string hostId, string childId)
    {
        if (_layout == null) return;
        var host = _layout.Cards.Find(c => c.Id == hostId);
        host?.StackedCards.Add(childId);
    }

    private void UnstackCard(string hostId, string childId)
    {
        if (_layout == null) return;
        var host = _layout.Cards.Find(c => c.Id == hostId);
        host?.StackedCards.Remove(childId);
    }

    private void MoveStatItem(string statId, int direction)
    {
        if (_layout == null) return;
        var index = _layout.StatItems.IndexOf(statId);
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _layout.StatItems.Count) return;
        (_layout.StatItems[index], _layout.StatItems[newIndex]) = (_layout.StatItems[newIndex], _layout.StatItems[index]);
    }

    private void RemoveStatItem(string statId)
    {
        if (_layout == null) return;
        _layout.StatItems.Remove(statId);
        if (!_layout.RemovedStatItems.Contains(statId))
            _layout.RemovedStatItems.Add(statId);
    }

    private void AddStatItem(string statId)
    {
        if (_layout == null) return;
        _layout.StatItems.Add(statId);
        _layout.RemovedStatItems.Remove(statId);
    }

