    private string GetLiveViewMapMode()
    {
        var card = _layout?.Cards.FirstOrDefault(c => c.Id == DashboardCards.LiveView);
        return card?.MapMode ?? "2d";
    }

    private void ToggleMapMode(string cardId)
    {
        var card = _layout?.Cards.FirstOrDefault(c => c.Id == cardId);
        if (card == null) return;
        card.MapMode = (card.MapMode ?? "2d") switch
        {
            "2d" => "3d",
            "3d" => "off",
            _ => "2d",
        };
    }

