@using Microsoft.AspNetCore.Components.Web
@using NetworkOptimizer.Web.Components
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="@FileVersionProvider.AddFileVersionToPath("/", "css/app.css")" />
    <!-- PWA icons and manifest -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1a2029" />
    <meta name="msapplication-TileColor" content="#1a2029" />
    <meta name="msapplication-TileImage" content="mstile-150x150.png" />
    <!-- Custom Blazor reconnect modal styles -->
    <style>
        #components-reconnect-modal {
            position: fixed;
            inset: 0;
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            background-color: rgba(0, 0, 0, 0.5);
        }
        #components-reconnect-modal.components-reconnect-show,
        #components-reconnect-modal.components-reconnect-failed,
        #components-reconnect-modal.components-reconnect-rejected {
            display: flex;
        }
        #components-reconnect-modal .reconnect-dialog {
            background-color: #161618;
            color: #ededef;
            padding: 2rem 3rem;
            border-radius: 6px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
            text-align: center;
            min-width: 20rem;
        }
        #components-reconnect-modal .reconnect-dialog p {
            margin: 0;
            font-size: 1rem;
        }
        #components-reconnect-modal .reconnect-spinner {
            width: 2rem;
            height: 2rem;
            margin: 0 auto 1rem;
            border: 3px solid rgba(255, 255, 255, 0.2);
            border-top-color: #3b82f6;
            border-radius: 50%;
            animation: reconnect-spin 0.8s linear infinite;
        }
        @@keyframes reconnect-spin {
            to { transform: rotate(360deg); }
        }
    </style>
    <!-- Tippy.js for interactive tooltips/popovers -->
    <script src="https://unpkg.com/@@popperjs/core@2"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>
    <!-- Three.js importmap. Vendored under /lib/three/. Used by the 3D LAN flow map (spec 5.7). -->
    <script type="importmap">
    {
        "imports": {
            "three": "/lib/three/three.module.js",
            "three/addons/": "/lib/three/addons/"
        }
    }
    </script>
    <HeadOutlet @rendermode="RenderMode.InteractiveServer" />
</head>

<body>
    <Routes />

    <!-- Custom reconnect modal (prevents Blazor from injecting shadow DOM version) -->
    <div id="components-reconnect-modal">
        <div class="reconnect-dialog">
            <div class="reconnect-spinner"></div>
            <p>Reconnecting...</p>
        </div>
    </div>

    <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/chart-defaults.js")"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/scrollRestoration.js")"></script>
    <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/updateCheck.js")"></script>
    <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/steppedScaleBar.js")"></script>
    <script src="@FileVersionProvider.AddFileVersionToPath("/", "lib/heic2any.min.js")"></script>
    <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/floorPlanEditor.js")"></script>
    @if (!string.IsNullOrEmpty(Environment.GetEnvironmentVariable("DEMO_MODE_MAPPINGS")))
    {
        <script src="@FileVersionProvider.AddFileVersionToPath("/", "js/demo-mask.js")"></script>
    }
    <script>
        function downloadFile(fileName, contentType, base64Data) {
            const linkSource = `data:${contentType};base64,${base64Data}`;
            const downloadLink = document.createElement('a');
            downloadLink.href = linkSource;
            downloadLink.download = fileName;
            downloadLink.click();
        }

        // Copy text from sibling input element with visual feedback
        function copyFromInput(button) {
            const input = button.previousElementSibling;
            const text = input.value;

            // Try modern API first (requires HTTPS)
            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text);
            } else {
                // Fallback for HTTP contexts
                input.select();
                input.setSelectionRange(0, 99999);
                document.execCommand('copy');
            }
            input.blur();

            // Visual feedback
            const icon = button.querySelector('.copy-icon');
            const check = button.querySelector('.copy-check');
            icon.style.display = 'none';
            check.style.display = 'inline';
            setTimeout(() => {
                icon.style.display = 'inline';
                check.style.display = 'none';
            }, 2000);
        }

        // Initialize Tippy.js tooltips
        function initTooltips() {
            // Find all tooltip icons with content siblings
            document.querySelectorAll('.tooltip-icon').forEach(function(icon) {
                // Skip if already initialized
                if (icon._tippy) return;

                // Get content from sibling or data attribute
                const contentEl = icon.nextElementSibling;
                let content;

                // Check for wide tooltip class
                let isWide = false;
                if (contentEl && contentEl.classList.contains('tooltip-content')) {
                    content = contentEl.innerHTML;
                    isWide = contentEl.classList.contains('tooltip-wide');
                    contentEl.style.display = 'none'; // Hide the original content element
                } else if (icon.dataset.tooltip) {
                    content = icon.dataset.tooltip;
                } else {
                    return;
                }

                tippy(icon, {
                    content: content,
                    allowHTML: true,
                    interactive: true,
                    interactiveBorder: 10,
                    trigger: 'mouseenter click',
                    hideOnClick: true,
                    delay: [100, 200],
                    placement: 'top',
                    theme: 'custom',
                    appendTo: document.body,
                    maxWidth: isWide ? 380 : 320,
                    onShow(instance) {
                        // Close other open tooltips
                        document.querySelectorAll('.tooltip-icon').forEach(function(other) {
                            if (other !== icon && other._tippy) {
                                other._tippy.hide();
                            }
                        });
                    },
                    onMount(instance) {
                        // Hide tooltip when clicking links inside it (before Blazor navigation)
                        instance.popper.querySelectorAll('a').forEach(function(link) {
                            link.addEventListener('click', function() {
                                instance.unmount();
                            });
                        });
                    },
                    onClickOutside(instance, event) {
                        instance.hide();
                    }
                });
            });

            // Simple tooltips for elements with data-tooltip (not .tooltip-icon)
            document.querySelectorAll('[data-tooltip]:not(.tooltip-icon)').forEach(function(el) {
                // Destroy existing tippy if content changed (Blazor may reuse elements)
                if (el._tippy) {
                    if (el._tippy.props.content === el.dataset.tooltip) {
                        return; // Content unchanged, keep existing
                    }
                    el._tippy.destroy();
                }
                var isInteractive = el.hasAttribute('data-tooltip-interactive');
                var opts = {
                    content: el.dataset.tooltip,
                    allowHTML: true,
                    trigger: el.hasAttribute('data-tooltip-hover') ? 'mouseenter' : 'mouseenter click',
                    hideOnClick: true,
                    delay: [100, 200],
                    placement: 'top',
                    theme: 'custom',
                    appendTo: document.body,
                    maxWidth: el.hasAttribute('data-tooltip-wrap') ? 320 : 'none',
                    onShow: function(instance) {
                        // Suppress if an adjacent sibling already shows the same tooltip
                        var ref = instance.reference;
                        var siblings = [ref.previousElementSibling, ref.nextElementSibling];
                        for (var i = 0; i < siblings.length; i++) {
                            var sib = siblings[i];
                            if (sib && sib._tippy && sib._tippy.state.isVisible &&
                                sib._tippy.props.content === instance.props.content) {
                                return false; // Cancel showing
                            }
                        }
                    }
                };
                if (isInteractive) {
                    opts.interactive = true;
                    opts.interactiveBorder = 10;
                    opts.onMount = function(instance) {
                        instance.popper.querySelectorAll('a').forEach(function(link) {
                            link.addEventListener('click', function() { instance.unmount(); });
                        });
                    };
                }
                if (el.hasAttribute('data-tooltip-follow')) {
                    opts.followCursor = true;
                }
                if (el.hasAttribute('data-tooltip-hover-only') || el.tagName === 'BUTTON') {
                    opts.trigger = 'mouseenter';
                }
                // Desktop-hover only: no click trigger and no tap on touch devices,
                // so the tap just performs the element's action.
                if (el.hasAttribute('data-tooltip-no-touch')) {
                    opts.trigger = 'mouseenter';
                    opts.touch = false;
                }
                tippy(el, opts);
            });
        }

        // Periodically check for new/stale tooltips (handles Blazor element reuse and dynamic content)
        setInterval(function() {
            // Clean up orphaned tippy instances (elements that no longer have data-tooltip but still have _tippy)
            // This happens when Blazor reuses elements and removes the data-tooltip attribute
            document.querySelectorAll('.path-connector, .wireless-icon').forEach(function(el) {
                if (el._tippy && !el.hasAttribute('data-tooltip')) {
                    el._tippy.destroy();
                }
            });

            document.querySelectorAll('[data-tooltip]:not(.tooltip-icon)').forEach(function(el) {
                var isInteractive = el.hasAttribute('data-tooltip-interactive');
                var opts = {
                    content: el.dataset.tooltip,
                    allowHTML: true,
                    trigger: el.hasAttribute('data-tooltip-hover') ? 'mouseenter' : 'mouseenter click',
                    hideOnClick: true,
                    delay: [100, 200],
                    placement: 'top',
                    theme: 'custom',
                    appendTo: document.body,
                    maxWidth: el.hasAttribute('data-tooltip-wrap') ? 320 : 'none',
                    onShow: function(instance) {
                        var ref = instance.reference;
                        var siblings = [ref.previousElementSibling, ref.nextElementSibling];
                        for (var i = 0; i < siblings.length; i++) {
                            var sib = siblings[i];
                            if (sib && sib._tippy && sib._tippy.state.isVisible &&
                                sib._tippy.props.content === instance.props.content) {
                                return false;
                            }
                        }
                    }
                };
                if (isInteractive) {
                    opts.interactive = true;
                    opts.interactiveBorder = 10;
                    opts.onMount = function(instance) {
                        instance.popper.querySelectorAll('a').forEach(function(link) {
                            link.addEventListener('click', function() { instance.unmount(); });
                        });
                    };
                }
                if (el.hasAttribute('data-tooltip-follow')) {
                    opts.followCursor = true;
                }
                if (el.hasAttribute('data-tooltip-hover-only') || el.tagName === 'BUTTON') {
                    opts.trigger = 'mouseenter';
                }
                // Desktop-hover only: no click trigger and no tap on touch devices,
                // so the tap just performs the element's action.
                if (el.hasAttribute('data-tooltip-no-touch')) {
                    opts.trigger = 'mouseenter';
                    opts.touch = false;
                }
                if (el._tippy) {
                    // Update existing tooltip if content changed
                    if (el._tippy.props.content !== el.dataset.tooltip) {
                        el._tippy.destroy();
                        tippy(el, opts);
                    }
                } else {
                    // Initialize new tooltip for dynamically added element
                    tippy(el, opts);
                }
            });
        }, 500);

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', initTooltips);

        // Clean up tippy elements before navigation (covers absolute /path and relative ./path links)
        document.addEventListener('click', function(e) {
            var link = e.target.closest('a[href^="/"], a[href^="./"]');
            if (link) {
                document.querySelectorAll('[data-tippy-root]').forEach(function(el) {
                    el.remove();
                });
            }
        });

        // Also watch for DOM changes (for dynamic content)
        const observer = new MutationObserver(function(mutations) {
            let shouldInit = false;
            mutations.forEach(function(mutation) {
                if (mutation.addedNodes.length) {
                    mutation.addedNodes.forEach(function(node) {
                        if (node.nodeType === 1) {
                            // Check for tooltip elements
                            if (node.classList?.contains('tooltip-icon') ||
                                node.querySelector?.('.tooltip-icon') ||
                                node.hasAttribute?.('data-tooltip') ||
                                node.querySelector?.('[data-tooltip]')) {
                                shouldInit = true;
                            }
                        }
                    });
                }
            });
            if (shouldInit) {
                setTimeout(initTooltips, 50);
            }
        });
        observer.observe(document.body, { childList: true, subtree: true });

        // Scrollable tab bar overflow detection
        function updateTabScrollState() {
            document.querySelectorAll('.wifi-view-tabs-wrapper').forEach(function(wrapper) {
                var tabs = wrapper.querySelector('.wifi-view-tabs');
                if (!tabs) return;
                var hasOverflow = tabs.scrollWidth > tabs.clientWidth + 1;
                wrapper.classList.toggle('has-overflow', hasOverflow);
                wrapper.classList.toggle('at-start', tabs.scrollLeft <= 20);
                wrapper.classList.toggle('at-end', tabs.scrollLeft + tabs.clientWidth >= tabs.scrollWidth - 20);
            });
        }
        // Update on scroll
        document.addEventListener('scroll', function(e) {
            if (e.target.classList && e.target.classList.contains('wifi-view-tabs')) {
                var wrapper = e.target.closest('.wifi-view-tabs-wrapper');
                if (wrapper) {
                    var tabs = e.target;
                    wrapper.classList.toggle('at-start', tabs.scrollLeft <= 20);
                    wrapper.classList.toggle('at-end', tabs.scrollLeft + tabs.clientWidth >= tabs.scrollWidth - 20);
                }
            }
        }, true);
        // Update on resize and periodically for Blazor dynamic content
        window.addEventListener('resize', updateTabScrollState);
        setInterval(updateTabScrollState, 1000);

        // Auto-reload when Blazor reconnects after a real disconnection
        // After server restart, client state is stale and causes loading issues
        // But don't reload on quick reconnects during normal page refresh
        const reconnectModal = document.getElementById('components-reconnect-modal');
        if (reconnectModal) {
            let disconnectedAt = null;
            const MIN_DISCONNECT_TIME_MS = 1500; // Only reload if disconnected > 1.5s

            const reconnectObserver = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        const classList = reconnectModal.classList;
                        const isShowing = classList.contains('components-reconnect-show');
                        const isFailed = classList.contains('components-reconnect-failed') ||
                                        classList.contains('components-reconnect-rejected');

                        if (isShowing && !disconnectedAt) {
                            // Record when we started showing the reconnect modal
                            disconnectedAt = Date.now();
                        } else if (!isShowing && !isFailed && disconnectedAt) {
                            // Successfully reconnected - only reload if we were disconnected long enough
                            const disconnectDuration = Date.now() - disconnectedAt;
                            disconnectedAt = null;
                            if (disconnectDuration >= MIN_DISCONNECT_TIME_MS) {
                                location.reload();
                            }
                        } else if (isFailed) {
                            disconnectedAt = null;
                            location.reload();
                        }
                    }
                });
            });
            reconnectObserver.observe(reconnectModal, { attributes: true });
        }
    </script>
</body>

</html>
